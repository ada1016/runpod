local mt = {
	__call = function (table, key)
		return table[mapKeyIndex[key]]
	end,
	__index = function (table, key)
		local tKey = dup.dup(key)

		if mapKeyIndex[tKey] == nil then
			return nil
		end

		if key == "_nameSid" then
			if table[3] == nil then
				return nil
			end

			return SID["SID_BATTLE_ENEMY_NAMESID_" .. table[3]]
		elseif key == "_featureSid" then
			if table[4] == nil then
				return nil
			end

			return SID["SID_BATTLE_ENEMY_FEATURESID_" .. table[4]]
