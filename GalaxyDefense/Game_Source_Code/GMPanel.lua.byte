	btnAddShard = Types.Button,
	btnAddSkin = Types.Button,
	btnUnlockSkin = Types.Button,
	btnAddRanger = Types.Button,
	btnAddRangerEquip = Types.Button,
	btnAddRangerSPEquip = Types.Button,
	btnAddSparkGem = Types.Button,
	btnAddInvitePoint = Types.Button,
	btnCompleteDig = Types.Button,
