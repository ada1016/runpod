	btnAddTimeOffset = Types.Button,
	btnAddTimeOffsetDay = Types.Button,
	btnResetTimeOffset = Types.Button,
	btnAddOfflineTime = Types.Button,
	btnAddIncubateTime = Types.Button,
	btnAddDomeBpExp = Types.Button,
	btnAddSkinBpExp = Types.Button,
	btnAddKeyBpExp = Types.Button,
	btnFixDice = Types.Button,
	btnSetDomeGrade = Types.Button,
	btnWin = Types.Button,
	btnLose = Types.Button,
	btnJumpWave = Types.Button,
	btnTestMissionDrop = Types.Button,
