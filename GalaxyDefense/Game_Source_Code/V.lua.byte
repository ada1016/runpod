local bTable = {}

function M.getEnemyTypeBinary1Num(num)
	table.clear(bTable)

	local b1Num = 0
	local idx = 1

	for i = 1, 8 do
		if bit.band(num, 1) == 1 then
			b1Num = b1Num + 1
			bTable[#bTable + 1] = idx

			if #bTable == 2 then
				break
			end
		end

		num = bit.rshift(num, 1)
		idx = idx + 1
	end

	return bTable
end

function M.getEnemyDescAndWeakText(eid)
	local cfg = D._battleEnemyConfig[eid]
	local raceText = LcLocalization.getTextStr(SID.STR_RACE_X)
	raceText = string.gsub(raceText, "{0}", LcLocalization.getTextStr(SID["STR_RACE_" .. cfg._race]))
	local weak = cfg._weakness
	local weakText = nil

	if weak then
		local natureTypes = M.getEnemyTypeBinary1Num(weak)
		local typesNum = #natureTypes
		local t1 = nil

		if typesNum == 1 then
			t1 = LcLocalization.getTextStr(SID.ENEMY_PROP_EXTRA_DMG_DESC1)
			t1 = string.gsub(t1, "{0}", cfg._weaknessFactor)
			t1 = string.gsub(t1, "{1}", LcLocalization.getTextStr(SID["STR_NATURE_" .. natureTypes[1]]))
		else
			t1 = LcLocalization.getTextStr(SID.ENEMY_PROP_EXTRA_DMG_DESC2)
			t1 = string.gsub(t1, "{0}", cfg._weaknessFactor)
			t1 = string.gsub(t1, "{1}", LcLocalization.getTextStr(SID["STR_NATURE_" .. natureTypes[1]]))
			t1 = string.gsub(t1, "{2}", LcLocalization.getTextStr(SID["STR_NATURE_" .. natureTypes[2]]))
		end

		weakText = t1
	else
		weakText = ""
	end

	local resist = cfg._resistance
	local resistText = nil

	if resist then
		local natureTypes = M.getEnemyTypeBinary1Num(resist)
		local typesNum = #natureTypes
		local t1 = nil

		if typesNum == 1 then
			t1 = LcLocalization.getTextStr(SID.ENEMY_PROP_EXTRA_DEF_DESC1)
			t1 = string.gsub(t1, "{0}", D._battleEnemyConfig[eid]._resistanceFactor)
			t1 = string.gsub(t1, "{1}", LcLocalization.getTextStr(SID["STR_NATURE_" .. natureTypes[1]]))
		else
			t1 = LcLocalization.getTextStr(SID.ENEMY_PROP_EXTRA_DEF_DESC2)
			t1 = string.gsub(t1, "{0}", D._battleEnemyConfig[eid]._resistanceFactor)
			t1 = string.gsub(t1, "{1}", LcLocalization.getTextStr(SID["STR_NATURE_" .. natureTypes[1]]))
			t1 = string.gsub(t1, "{2}", LcLocalization.getTextStr(SID["STR_NATURE_" .. natureTypes[2]]))
		end

		resistText = t1
	else
		resistText = ""
	end

	local descText = LcLocalization.getTextStr(D._battleEnemyConfig[eid]._featureSid)
	descText = table.concat({
		raceText,
		descText,
		resistText,
		weakText
	})

	if descText == "" then
		return LcLocalization.getTextStr(SID.STR_NONE)
	end

	return descText
end

function M.showEnemyBubble(eid, targetObj)
	local tipsText = M.getEnemyDescAndWeakText(eid)

	UIManager.openPanel(PrefabDefine.BubbleMonsterTipsPanel, {
		name = D._battleEnemyConfig[eid]._nameSid,
		descTitle1 = SID.BATTLE_ENEMY_FEATURE,
		descTitle2 = SID.BATTLE_ENEMY_TIPS,
		desc1 = tipsText,
		desc2 = D._battleEnemyConfig[eid]._descSid or SID.STR_NONE
	}, {
		target = targetObj,
		offset = {
			0,
			50,
			0
		}
	})
end

function M.showWeaponBubble(weaponId, targetObj)
	M.showBubbleTips({
		name = D._weaponConfig[weaponId]._skillNameSid,
		desc = D._weaponConfig[weaponId]._skillDescSid
	}, {
		target = targetObj,
		offset = {
			0,
			50,
			0
		}
	})
end

function M.playAnimitonClipFrameSync(anim, strKey)
	local state = anim:get_Item(strKey)
	local time = C.getCurTime() % state.length

	anim:Play(strKey)

	state.time = time

	anim:Sample()
end

function M.resetAnimToStartFrame(anim, strKey)
	if strKey == nil then
		strKey = anim.clip.name
	end

	M.setAnimationToTargetFrame(anim, strKey, 0)
	anim:Stop()
end

function M.resetAnimToEndFrame(anim, strKey)
	if strKey == nil then
		strKey = anim.clip.name
	end

	M.setAnimationToTargetFrame(anim, strKey, anim.clip.length)
	anim:Stop()
end

function M.randomAnimitonClipFrame(anim)
	local clip = anim.clip
	local randomTime = math.random(0, clip.length)

	M.setAnimationToTargetFrame(anim, clip.name, randomTime)
	anim:Play()
end

function M.setAnimationToTargetFrame(anim, strKey, time)
	local state = anim:get_Item(strKey)

	if state then
		anim:Play(strKey)

		state.time = time or 0

		anim:Sample()

		state.enabled = false
	end
end

function M.animHaveClip(anim, clipName)
	if clipName == nil then
		return false
	end

	local state = anim:get_Item(clipName)

	return state ~= nil
end

function M.playChildEffectsFast(vfxTransform)
	local ps = vfxTransform:GetComponent(typeof(UnityEngine.ParticleSystem))

	ps:Play(true)
end

function M.playChildEffects(vfxTransform)
	local pses = vfxTransform:GetComponentsInChildren(typeof(UnityEngine.ParticleSystem))

	for i = 0, pses.Length - 1 do
		pses[i]:Play()
	end
end

function M.stopChildEffects(vfxTransform)
	local pses = vfxTransform:GetComponentsInChildren(typeof(UnityEngine.ParticleSystem))

	for i = 0, pses.Length - 1 do
		pses[i]:Stop()
	end
end

local TrailRenderer = typeof(UnityEngine.TrailRenderer)

function M.clearTrails(tfVfxParent)
	local pses = tfVfxParent:GetComponentsInChildren(TrailRenderer)

	for i = 0, pses.Length - 1 do
		pses[i]:Clear()
	end
end

function M.updateTaskDescProgress(tid, params)
	local showBreif = params.showBreifDesc
	local txtDesc = params.txtDesc
	local txtProgress = params.txtProgress
	local imgBar = params.imgBar
	local red = params.red or M.COMMON_COLOR.red
	local green = params.green or M.COMMON_COLOR.green
	local TaskHelper = TaskHelper
	local type = TaskHelper:getTaskType(tid)
	local value = TaskHelper:getTaskProgress(tid)
	local progress = TaskHelper:getTaskValue(tid)
	local descSid = showBreif and TaskHelper:getBreifSid(tid) or TaskHelper:getDescSid(tid)

	if txtDesc then
		if type == D.TaskType.FINISH_MISSION then
			txtDesc:SetLocalizeComplex(descSid, {
				{
					sid = -D._missionCommonConfig[value]._nameSid,
					vi = value - 10000
				}
			})
		elseif type == D.TaskType.FINISH_ELITE_MISSION then
			txtDesc:SetLocalizeComplex(descSid, {
				{
					sid = -D._missionEliteConfig[value]._nameSid,
					vi = value - 20000
				}
			})
		elseif type == D.TaskType.FINISH_GLOBAL_DEFENCE_MISSION then
			txtDesc:SetLocalize(descSid, -D._missionGlobalDefenseConfig[value]._nameSid)
		elseif type == D.TaskType.GET_CHIP then
			local param = TaskHelper:getTaskParam(tid)

			txtDesc:SetLocalize(TaskHelper:getDescSid(tid), value, -SID["STR_QUALITY_" .. param])
		elseif type == D.TaskType.SPARK_SCOUT_GRADE then
			local _, _, gradeStarNum = P._playerActivitySparkScout:parseGradeId(value)

			if gradeStarNum == 0 then
				gradeStarNum = nil
			end

			local p1, p2 = M.getSparkGradeTxtParam(value)

			if p2 then
				txtDesc:SetLocalizeComplex(descSid, {
					{
						sid = -p1,
						vs = gradeStarNum and string.format("%d<sprite name=\"grade_star\">x%d", p2, gradeStarNum) or tostring(p2)
					}
				})
			elseif gradeStarNum then
				txtDesc:SetLocalizeS(descSid, gradeStarNum and string.format("%s<sprite name=\"grade_star\">x%d", LcLocalization.getTextStr(p1), gradeStarNum) or p1)
			else
				txtDesc:SetLocalize(descSid, -p1)
			end
		else
			txtDesc:SetLocalize(descSid, value)
		end
	end

	local show01Pgs = type == D.TaskType.FINISH_MISSION or type == D.TaskType.FINISH_ELITE_MISSION or type == D.TaskType.FINISH_GLOBAL_DEFENCE_MISSION or type == D.TaskType.SPARK_SCOUT_GRADE

	if txtProgress then
		V.formatNeedStr1WithColor(txtProgress, show01Pgs and (TaskHelper:isFinished(tid) and 1 or 0) or progress, show01Pgs and 1 or value, green, red)
	end

	if imgBar then
		imgBar.fillAmount = show01Pgs and (TaskHelper:isFinished(tid) and 1 or 0) or progress / value
	end
end

function M.updateTaskTitleDesc(tid, txtTitle, txtDesc)
	local TaskHelper = TaskHelper
	local type = TaskHelper:getTaskType(tid)
	local value = TaskHelper:getTaskProgress(tid)
	local progress = TaskHelper:getTaskValue(tid)

	if type == D.TaskType.FINISH_MISSION or type == D.TaskType.FINISH_ELITE_MISSION then
		if type == D.TaskType.FINISH_MISSION then
			if txtTitle then
				txtTitle:SetLocalize(D._missionCommonConfig[value]._nameSid, value % 10000)
				txtTitle:SetLocalizeS(TaskHelper:getBreifSid(tid), txtTitle.text)
			end

			txtDesc:SetLocalize(D._missionCommonConfig[value]._nameSid, value % 10000)
			txtDesc:SetLocalizeS(TaskHelper:getDescSid(tid), txtDesc.text)
		else
			if txtTitle then
				txtTitle:SetLocalize(D._missionEliteConfig[value]._nameSid, value % 10000)
				txtTitle:SetLocalizeS(TaskHelper:getBreifSid(tid), txtTitle.text)
			end

			txtDesc:SetLocalize(D._missionEliteConfig[value]._nameSid, value % 10000)
			txtDesc:SetLocalizeS(TaskHelper:getDescSid(tid), txtDesc.text)
		end

		if progress < value then
			txtDesc.text = txtDesc.text .. string.format("(<color=#%s>%d</color>/%d)", M.COMMON_COLOR.red, 0, 1)
		else
			txtDesc.text = txtDesc.text .. string.format("(<color=#%s>%d</color>/%d)", M.COMMON_COLOR.green, 1, 1)
		end
	else
		if txtTitle then
			txtTitle:SetLocalize(TaskHelper:getDescSid(tid), value)
		end

		txtDesc:SetLocalize(TaskHelper:getDescSid(tid), value)

		if progress < value then
			txtDesc.text = txtDesc.text .. string.format("(<color=#%s>%d</color>/%d)", M.COMMON_COLOR.red, progress, value)
		else
			txtDesc.text = txtDesc.text .. string.format("(<color=#%s>%d</color>/%d)", M.COMMON_COLOR.green, progress, value)
		end
	end
end

function M.jumpTo(jumpConf, value)
	if not jumpConf then
		return
	end

	local panel = jumpConf._panel
	local tab = jumpConf._tab
	local systemId = jumpConf._systemId

	if systemId == nil or systemId == 0 then
		return
	end

	if jumpConf._id == D.JumpId.EquipRefine and not P._playerGuide:isGroupFinished(D.GuideGroupId.EquipRefine) then
		V.showToast(SID.TIP_GAIN_EPIC_GEAR_UNLOCK)

		return
	end

	if not D.isSystemUnlocked(systemId) then
		local type = D._systemUnlockConfig[systemId]._unlockType
		local val = D._systemUnlockConfig[systemId]._unlockVal

		if type == 3 or type == 4 then
			local sid = P._playerMission:readMissionName(val, math.floor(val / 10000))
			local str = LcLocalization.getTextStr(sid)
			val = string.gsub(str, "{0}", val % 10000)
		end

		local sid = SID["TIP_SYSTEM_UNLOCK_TIP_" .. type]

		if sid then
			V.showToast({
				sid,
				val
			})
		else
			V.showToast(SID.STR_NOT_UNLOCK)
		end

		return
	end

	if panel == "SevenDayPanel" and P._playerSevenDay:isExpired() then
		V.showToast(SID.TIP_EVENT_END)

		return
	end

	V.jumping = true

	UIManager.closeToPanelOrMain(panel)

	if panel == "HomePage" then
		local mainPanel = UIManager.getMainPanel()

		mainPanel:changePage(3)

		if systemId == D.SystemType.CommonMission then
			mainPanel._lastPage:changeMission(value or P._playerMission:getMissionIdByType(D.MissionType.Common), D.MissionType.Common)
		elseif systemId == D.SystemType.EliteMission then
			mainPanel._lastPage:changeMission(value and value - 10000 or P._playerMission:getMissionIdByType(D.MissionType.Elite), D.MissionType.Elite)
		end
	elseif panel == "ArmoryPage" then
		UIManager.getMainPanel():changePage(4)
	elseif panel == "RolePage" then
		local main = UIManager.getMainPanel()

		main:changePage(2)

		local page = main:getPageLb(2)

		if tab ~= 0 then
			page:changeTab(tab)
		end
	elseif panel == "ShopPage" then
		local main = UIManager.getMainPanel()

		main:changePage(1)

		local page = main:getPageLb(1)

		if tab ~= 0 then
			page:changePage(tab)
		end
	elseif panel == "ChallengePage" then
		UIManager.getMainPanel():changePage(5)
	elseif panel == "OfflineRewardPanel" then
		UIManager.openPanel(PrefabDefine.OfflineRewardPanel)
	elseif panel == "ResearchPanel" then
		UIManager.getMainPanel():changePage(2)
		UIManager.openPanel(PrefabDefine.RoleSystemPanel)
	elseif panel == "SpecialRewardsPanel" then
		UIManager.getMainPanel():changePage(3)
		UIManager.openPanel(PrefabDefine.SpecialRewardsPanel, tab)
	elseif panel == "PurchaseStaminaPanel" then
		UIManager.openPanel(PrefabDefine.PurchaseStaminaPanel)
	elseif panel == "EquipImprovePanel" then
		UIManager.getMainPanel():changePage(2)

		if tab ~= 0 then
			UIManager.openPanel(PrefabDefine.EquipImprovePanel, nil, tab)
		end
	elseif panel == "DomeImprovePanel" then
		UIManager.getMainPanel():changePage(2)
		UIManager.openPanel(PrefabDefine.DomeImprovePanel)
	elseif panel == "TaskPanel" then
		UIManager.getMainPanel():changePage(3)
		UIManager.openPanel(PrefabDefine.TaskPanel)
	elseif panel == "SevenDayPanel" then
		UIManager.getMainPanel():changePage(3)
		UIManager.openPanel(PrefabDefine.SevenDayPanel)
	elseif panel == "MissionOverviewPanel" then
		local main = UIManager.getMainPanel()

		main:changePage(3)

		local page = main:getPageLb(3)

		UIManager.openPanel(PrefabDefine.MissionOverviewPanel, page, page._msId, page._msType)
	elseif panel == "NewbieGiftPanel" then
		local giftId = P._playerGift:getBtnShowNewbieGiftId(D.GiftType.Newbie)

		if giftId then
			UIManager.openPanel(PrefabDefine.NewbieGiftPanel)
		else
			UIManager.getMainPanel():changePage(1)
		end
	elseif panel == "RangerPanel" then
		if UIManager.isInMain() then
			UIManager.getMainPanel():changePage(2)
			UIManager.openPanel(PrefabDefine.RangerPanel, tab)
		else
			UIManager.getPanel(PrefabDefine.RangerPanel.id):changePage(tab)
		end
	end

	GuideManager:tryShowAction()

	V.jumping = false

	return ResultCode.OK
end

function M.createArkShip(parent)
	if not M._goArkShip then
		M._goArkShip = LuaUnity.createGameObject(string.format("Assets/FW/Prefabs/UI/element/Ark.prefab"), parent)
	end

	ArkShipManager:init()

	return M._goArkShip
end

function M.createRangerEgg(eggType, parent)
	local go = LuaUnity.createGameObject(string.format("Assets/FW/Prefabs/UI/element/EggQ%d.prefab", eggType), parent)

	return go
end

function M.createSparkScoutRole(parent)
	if M._goSparkScoutRole then
		return M._goSparkScoutRole
	end

	M._goSparkScoutRole = LuaUnity.createGameObject(string.format("Assets/FW/Prefabs/UI/element/SparkScoutRole.prefab"), parent)

	lc.setPosition(M._goSparkScoutRole, 100, 0)
	SparkScoutManager:init()

	return M._goSparkScoutRole
end

function M.destroySparkScoutRole()
	if not M._goSparkScoutRole then
		return
	end

	GameObject.Destroy(M._goSparkScoutRole)

	M._goSparkScoutRole = nil
end

local spineUIPool = {}
local SpineUIObj = requireLua("SpineUIObj")

local function getPlayerSpineObj(bodySpineId)
	local name = string.format("Player_UISpine_%d", bodySpineId)
	local goSpine = nil
	spineUIPool[name] = spineUIPool[name] or {}
	local pool = spineUIPool[name]

	if #pool > 0 then
		goSpine = pool[#pool]

		table.remove(pool, #pool)
	end

	if goSpine == nil then
		goSpine = LuaUnity.createGameObjectWithDefault(string.format("Assets/FW/SpinePrefabs/Player/%s.prefab", name), MainGameRoot._currentCanvasTop, "Assets/FW/SpinePrefabs/Player/Player_UISpine_120000.prefab")

		SpineUIObj.noCreate(goSpine)

		goSpine.name = name
	end

	return goSpine
end

local function getSpineWeaponObj(name)
	local goSpine = nil
	spineUIPool[name] = spineUIPool[name] or {}
	local pool = spineUIPool[name]

	if #pool > 0 then
		goSpine = pool[#pool]

		table.remove(pool, #pool)
	end

	if goSpine == nil then
		local defaultName = name:gsub("_(%d+)_([LR])$", "_" .. 110000 .. "_%2")
		goSpine = LuaUnity.createGameObjectWithDefault(string.format("Assets/FW/Prefabs/SpineWeapons/%s.prefab", name), MainGameRoot._currentCanvasTop, string.format("Assets/FW/Prefabs/SpineWeapons/%s.prefab", defaultName))
		goSpine.name = name
	end

	return goSpine
end

local function getRangerSpineObj(rangerId)
	local name = string.format("Ranger_UISpine_%d", rangerId)
	local goSpine = nil
	spineUIPool[name] = spineUIPool[name] or {}
	local pool = spineUIPool[name]

	if #pool > 0 then
		goSpine = pool[#pool]

		table.remove(pool, #pool)
	end

	if goSpine == nil then
		goSpine = LuaUnity.createGameObjectWithDefault(string.format("Assets/FW/SpinePrefabs/Ranger/%s.prefab", name), MainGameRoot._currentCanvasTop, "Assets/FW/SpinePrefabs/Player/Ranger_UISpine_150001.prefab")
		goSpine.name = name
	end

	return goSpine
end

function M.getRoleUIWeaponSpine(tfSpineContainer, sex, bodySpineId, part)
	local name = string.format("Player_UIWeapon_%d_%d_%s", sex, bodySpineId, part)
	local spineObj = getSpineWeaponObj(name)

	spineObj:SetParent(tfSpineContainer)
	lc.setLocalScale(spineObj, 1, 1, 1)
	lc.setLocalPosition(spineObj, 0, 0, 0)
	lc.setLocalRotation(spineObj, 0, 0, 0)
	spineObj:SetActive(true)

	return spineObj
end

function M.getGatlinSkinObj(tfSpineContainer, id)
	if not D._skinGatlinConfig[id] or D._skinGatlinConfig[id]._hidden then
		id = D.DEFAULT_GATLIN_SKIN
	end

	local name = string.format("Player_UIWeapon_1_%d", id)
	local spineObj = getSpineWeaponObj(name)

	spineObj:SetParent(tfSpineContainer)
	lc.setLocalScale(spineObj, 1, 1, 1)
	lc.setLocalPosition(spineObj, 0, 0, 0)
	lc.setLocalRotation(spineObj, 0, 0, 0)

	local img = spineObj.transform:Find("Image")

	if img and not CNull(img) then
		LuaUnity.setTPSprite(img:GetComponent("Image"), string.format("cardgun/skin_%d", id))
	end

	spineObj:SetActive(true)

	return spineObj
end

function M.getRoleUISpine(tfSpineContainer, bodySpineId)
	local spineObj = nil

	if bodySpineId < 130000 then
		spineObj = getPlayerSpineObj(bodySpineId)
	elseif bodySpineId < 160000 then
		spineObj = getRangerSpineObj(bodySpineId)
	else
		spineObj = getPlayerSpineObj(bodySpineId)
	end

	spineObj:SetParent(tfSpineContainer)
	lc.setLocalScale(spineObj, 1, 1, 1)
	lc.setLocalPosition(spineObj, 0, 0, 0)
	lc.setLocalRotation(spineObj, 0, 0, 0)
	spineObj:SetActive(true)

	return spineObj
end

function M.recycleRoleUISpine(spineObj)
	if CNull(MainGameRoot._currentCanvasDontClearTop) then
		return
	end

	local name = spineObj.name
	spineUIPool[name] = spineUIPool[name] or {}
	local pool = spineUIPool[name]

	spineObj:SetParent(MainGameRoot._currentCanvasDontClearTop)
	spineObj:SetActive(false)

	pool[#pool + 1] = spineObj
end

local flyVfxPool = {}

local function getResFlyVfx(vfxName)
	local vfx = nil
	flyVfxPool[vfxName] = flyVfxPool[vfxName] or {}
	local pool = flyVfxPool[vfxName]

	if #pool > 0 then
		vfx = pool[#pool]

		table.remove(pool, #pool)
	end

	if vfx == nil then
		vfx = LuaUnity.createGameObject(string.format("Assets/FW/Prefabs/UI_vfx/%s.prefab", vfxName), MainGameRoot._currentCanvasTop)
		vfx.name = vfxName
	end

	return vfx
end

local function flyFinishCallback(vfx)
	local vfxName = vfx.name
	flyVfxPool[vfxName] = flyVfxPool[vfxName] or {}
	local pool = flyVfxPool[vfxName]
	pool[#pool + 1] = vfx
end

local function getParticleByPath(vfxName, sourceTf, targetTf)
	local vfx = getResFlyVfx(vfxName)
	local particleByPath = vfx.transform:GetComponent("ParticleByPath")
	particleByPath.sourceTransform = sourceTf
	particleByPath.targetTransform = targetTf

	particleByPath:SetFinishCallback(flyFinishCallback)

	return particleByPath
end

function M.playChipFlyVfx(sourceTf, targetTf, quality)
	local trailColor = Color.str2Static(M.QUALITY_TRIANGLE[quality])

	ResAnimHelper.flyChip(quality, sourceTf, targetTf, trailColor)

	return 0.6
end

function M.playEquipFlyVfx(sourceTf, targetTf, part, quality)
	local trailColor = Color.str2Static(M.QUALITY_TRIANGLE[quality])

	ResAnimHelper.flyEquip(part, sourceTf, targetTf, trailColor)

	return 0.6
end

function M.playSevenDayExpFlyVfx(sourceTf, targetTf, count, trailColor)
	ResAnimHelper.flyItem(D.ResType.seven_day_exp, sourceTf, targetTf, count, Color.str2Static("397DA4"))
end

function M.playWeekActivityKeyFlyVfx(sourceTf, targetTf, trailColor, moveTime)
	ResAnimHelper.flyItem(D.ResType.week_activity_key, sourceTf, targetTf, 1, Color.str2Static(trailColor or "397DA4"), moveTime)
end

function M.setBuffLinkClick(tmpText, autoAdd)
	local compLink = nil

	if autoAdd then
		compLink = tmpText.gameObject:GetOrAddComponent(typeof(TMP_Text_LinkHandler))
	else
		compLink = tmpText:GetComponent("TMP_Text_LinkHandler")
	end

	if not compLink then
		return
	end

	compLink:SetLinkClick(function (linkId)
		V.showBubbleTips({
			name = SID["TITLE_LINK_" .. linkId],
			desc = SID["TIP_LINK_" .. linkId]
		}, {
			alignment = 1,
			offset = {
				0,
				10,
				0
			}
		})
	end)
end

function M.setTMPClick(tmpText, onClick)
	local compLink = tmpText:GetComponent("TMP_Text_LinkHandler")

	if not compLink then
		return
	end

	compLink:SetLinkClick(onClick)
end

function M.setSkinQualityStar(goStarContainer, quality, star)
	for i = 1, 5 do
		local goStar = goStarContainer:GetChild(i - 1)

		if i <= star then
			goStar:GetChild(0):SetActive(true)
		else
			goStar:GetChild(0):SetActive(false)
		end
	end
end

function M.setRangerQualityStar(goStarContainer, quality, star)
	local colorIdx = math.max(1, math.ceil(star / 5))
	local starIdx = star % 5

	if starIdx == 0 then
		starIdx = 5
	end

	for i = 1, 5 do
		local goStar = goStarContainer:GetChild(i - 1)
		local imgStar = goStar:GetChild(0):GetComponent("Image")
		imgStar:GetComponent("UIGradient").enabled = false

		if star > 0 and i <= starIdx then
			LuaUnity.setTPSprite(imgStar, M.RANGER_STAR_COLOR_IMG[colorIdx], true, nil)

			goStar:GetComponent("Image").color = Color.str2Static(M.RANGER_STAR_COLOR[colorIdx])

			imgStar:SetActive(true)
		elseif colorIdx >= 2 then
			LuaUnity.setTPSprite(imgStar, M.RANGER_STAR_COLOR_IMG[colorIdx - 1], true, nil)

			goStar:GetComponent("Image").color = Color.str2Static(M.RANGER_STAR_COLOR[colorIdx - 1])

			imgStar:SetActive(true)
		else
			LuaUnity.setTPSprite(imgStar, M.RANGER_STAR_COLOR_IMG[colorIdx], true, nil)

			goStar:GetComponent("Image").color = Color.str2Static(M.RANGER_STAR_COLOR[colorIdx])

			imgStar:SetActive(false)
		end
	end
end

function M.setBtnStyle(btn, style, txtSid)
	if style == M.BTN_STYLE.green then
		btn:GetComponent("Image").color = Color.str2Static(V.COMMON_COLOR.btn_green)
		btn.transform:GetChild(0):GetComponent("Image").color = Color.str2Static(V.COMMON_COLOR.btn_green_light)
	elseif style == M.BTN_STYLE.blue then
		btn:GetComponent("Image").color = Color.str2Static(V.COMMON_COLOR.btn_blue)
		btn.transform:GetChild(0):GetComponent("Image").color = Color.str2Static(V.COMMON_COLOR.btn_blue_light)
	elseif style == M.BTN_STYLE.yellow then
		btn:GetComponent("Image").color = Color.str2Static(V.COMMON_COLOR.btn_ad_yellow)
		btn.transform:GetChild(0):GetComponent("Image").color = Color.str2Static(V.COMMON_COLOR.btn_ad_yellow_light)
	elseif style == M.BTN_STYLE.gray then
		btn:GetComponent("Image").color = Color.str2Static(V.COMMON_COLOR.btn_gray)
		btn.transform:GetChild(0):GetComponent("Image").color = Color.str2Static(V.COMMON_COLOR.btn_gray_light)
	end

	if txtSid then
		if type(txtSid) == "number" then
			btn.transform:GetChild(1):GetComponent("TMP_Text"):SetLocalize(txtSid)
		else
			btn.transform:GetChild(1):GetComponent("TMP_Text").text = txtSid
		end
	end
end

function M.loadSkinSkillDesc(txt, cfg, level)
	if P._playerSkin:readSkinType(cfg._id) == D.SkinType.Weapon then
		if cfg._skillLevelParam[level] == 0 then
			txt:SetLocalize(cfg._skillDescSid, -SID.STR_NO_CHANGE)
		else
			txt:SetLocalizeS(cfg._skillDescSid, "+" .. cfg._skillLevelParam[level] .. "%")
		end
	else
		txt:SetLocalizeS(cfg._skillDescSid, cfg._skillLevelParam[level])
	end
end

function M.showSkinSkillDescBubble(cfg, level, btnObj)
	local title = cfg._skillNameSid or cfg._nameSid
	local desc = cfg._skillDescSid
	local str = string.format("%s(%d<sprite name=\"star\">)", LcLocalization.getTextStr(title), level)

	if P._playerSkin:readSkinType(cfg._id) == D.SkinType.Weapon then
		if cfg._skillLevelParam[level] == 0 then
			V.showBubbleTips({
				name = str,
				desc = {
					desc,
					-SID.STR_NO_CHANGE
				}
			}, {
				offset = {
					0,
					20,
					0
				},
				target = btnObj
			})
		else
			V.showBubbleTips({
				name = str,
				desc = {
					desc,
					"+" .. cfg._skillLevelParam[level] .. "%"
				}
			}, {
				offset = {
					0,
					20,
					0
				},
				target = btnObj
			})
		end
	else
		V.showBubbleTips({
			name = str,
			desc = {
				desc,
				cfg._skillLevelParam[level]
			}
		}, {
			offset = {
				0,
				20,
				0
			},
			target = btnObj
		})
	end
end

function M.loadCustomAvatarBG(tfAvatar, color)
	local imgBg = tfAvatar:GetComponent("Image")
	imgBg.color = color

	LuaUnity.setTPSprite(imgBg, "avatar/avatar_bg_white", true)
end

function M.loadAvatar(tfAvatar, avatar, avatarFrame)
	local imgBg = tfAvatar:GetComponent("Image")
	local imgAvatar = tfAvatar:Find("ImgAvatar"):GetComponent("Image")
	local imgAvatarFrame = tfAvatar:Find("ImgAvatarFrame"):GetComponent("Image")
	avatar = avatar or 1
	avatar = math.max(1, avatar)

	LuaUnity.setTPSprite(imgAvatar, "avatar/" .. avatar, true)
	LuaUnity.setTPSprite(imgBg, D.toAvatarBgSprite(avatar), true)

	imgBg.color = Color.White

	if avatarFrame and avatarFrame > 0 then
		imgAvatarFrame:SetActive(true)
		LuaUnity.setTPSprite(imgAvatarFrame, D.toAvatarFrameSprite(avatarFrame), true)
	else
		imgAvatarFrame:SetActive(false)
	end
end

function M.loadWeaponDamages(weaponDatas, tfContainer, panel)
	for i = 1, tfContainer.childCount do
		local weapon = tfContainer:GetChild(i - 1).gameObject

		weapon:SetActive(false)
	end

	for i = 1, #weaponDatas do
		local weaponData = weaponDatas[i]
		local id = weaponData.id
		local stage = weaponData.stage
		local star = weaponData.star
		local dmg = weaponData.dmg
		local dps = weaponData.dps
		local weapon = nil

		if i <= tfContainer.childCount then
			weapon = tfContainer:GetChild(i - 1).gameObject
		else
			weapon = LuaUnity.createGameObject(string.format("Assets/FW/Prefabs/UI/widget/WeaponDamageWidget.prefab"), tfContainer)
		end

		weapon:SetActive(true)
		lc.prefabVarPeer(weapon)

		if D.WEAPON_DOME < id then
			weapon._tfStars:SetVisible(false)
			weapon._tfSkills:SetActive(true)
			weapon._imgRanger:SetActive(true)
			weapon._imgIcon:SetActive(false)
			LuaUnity.setTPSprite(weapon._imgRanger, "item/item_" .. id, true, true)
			weapon._tfSkills:SetActive(true)

			local equipedSkills = D._rangerConfig[id]._mainSkills

			for i = 1, 3 do
				if equipedSkills[i] then
					weapon["_imgSkill" .. i]:SetActive(true)

					local type = D._rangerSkillConfig[equipedSkills[i]]._group + 1

					if type == 3 then
						weapon._goDomeSkill3:SetActive(false)
						weapon._goRangerSkill3:SetActive(true)
						LuaUnity.setTPSprite(weapon._imgRangerSkill3, "weapon/weapon_" .. D._rangerSkillConfig[equipedSkills[i]]._weapon, true, true)
					else
						LuaUnity.setTPSprite(weapon["_imgSkill" .. i], string.format("ranger/RangerSkill-%d-%d", id % 100, i), true)
					end
				else
					weapon["_imgSkill" .. i]:SetActive(false)
				end
			end
		elseif id == D.WEAPON_DOME then
			weapon._imgRanger:SetActive(false)
			weapon._imgIcon:SetActive(true)
			LuaUnity.setTPSprite(weapon._imgIcon, "weapon/small_weapon_" .. P._playerSkin:getEquipedSkin(id), true)
			weapon._tfStars:SetVisible(false)
			weapon._tmpLv.transform.parent:SetVisible(false)
			weapon._tfSkills:SetActive(true)

			local equipedSkills = P._playerSkin:getEquipedSkinSkills(D.SkinType.Dome)

			for i = 1, 3 do
				if equipedSkills[i][1] then
					weapon["_imgSkill" .. i]:SetActive(true)
					LuaUnity.setTPSprite(weapon["_imgSkill" .. i], "skill/item_skill_" .. equipedSkills[i][1])
				else
					weapon["_imgSkill" .. i]:SetActive(false)
				end
			end
		else
			weapon._imgRanger:SetActive(false)
			weapon._imgIcon:SetActive(true)
			LuaUnity.setTPSprite(weapon._imgIcon, "weapon/small_weapon_" .. id, true)
			weapon._tfSkills:SetActive(false)

			weapon._tmpLv.text = stage
			local isMax = BattleManager:getSession()._battleRouge._pool:isMaxStar(id)

			weapon._goMax:SetActive(isMax)
			weapon._tfStars:SetActive(not isMax)

			local starNum = star

			if not isMax then
				for i = 1, 4 do
					weapon._tfStars:GetChild(i):GetChild(0):SetActive(i <= starNum)
				end
			end
		end

		weapon._txtDamage.text = string.formatNumber(dmg)
		weapon._txtDps.text = string.formatNumber(dps)

		panel:setClickWithoutAction(weapon._btnIcon, function ()
			UIManager.openPanel(PrefabDefine.BattleSkillDmgRecordPanel, id)
		end)
	end
end

function V.showMessageBox(param)
	UIManager.openPanel(PrefabDefine.MessageBoxPanel, param)
end

function V.showTopMessageBox(param)
	UIManager.openPanel(PrefabDefine.MessageBoxTopPanel, param)
end

function V.showForbiddenMessageBox(content)
	V.showMessageBox({
		_type = 2,
		_content = content,
		_txtConfirm = SID.TITLE_CONTACT_US,
		_confirmCallback = function ()
			if lc._isCN then
				LuaHelper.OpenCustomerService("forbid_panel")
			else
				lc.openUrl(D.URL_EMAIL_TO)
			end

			lc.setTimer(function ()
				Application.Quit()
			end, 0.1)
		end,
		_txtCancel = SID.EXIT_APP,
		_cancelCallback = function ()
			Application.Quit()
		end
	})
end

function V.setQualityImgText(img, quality)
	if quality ~= D.Quality.COLORFUL then
		LuaUnity.setTPSprite(img, "general/g_bg_13_big")

		img.color = Color.str2Static(V.QUALITY_BG[quality])
	else
		LuaUnity.setTPSprite(img, "general/g_bg_13_big_colorful")

		img.color = Color.White
	end

	local txt = img.transform:GetChild(0):GetComponent("TMP_Text")

	txt:SetLocalize(SID["STR_QUALITY_" .. quality])

	txt.color = Color.str2Static(V.QUALITY_BG_TXT[quality])
end

function M.checkRankVersion(callback)
	local miniVersion = C._appConfig.minRankVersion or "0.0.0"

	if lc._appVersion < lc.versionStr2Number(miniVersion) then
		V.showMessageBox({
			_type = 2,
			_content = SID.UPDATE_VERSION_TIPS,
			_txtConfirm = SID.STR_GOTO_UPDATE,
			_txtCancel = SID.STR_CONTINUE_ENTER,
			_cParams = {
				Application.version,
				miniVersion
			},
			_confirmCallback = function ()
				lc.openUrl(C._appConfig.appUpdateUrl)
			end,
			_cancelCallback = function ()
				callback()
			end
		})
	else
		callback()
	end
end

function M.checkActivityVersion(callback, type)
	local miniVersion = "0.0.0"

	if C._appConfig.minActivityVersion and C._appConfig.minActivityVersion[tostring(type)] then
		miniVersion = C._appConfig.minActivityVersion[tostring(type)]
	end

	if lc._appVersion < lc.versionStr2Number(miniVersion) then
		V.showMessageBox({
			_showClose = true,
			_type = 1,
			_content = SID.UPDATE_VERSION2_TIPS,
			_txtConfirm = SID.STR_GOTO_UPDATE,
			_cParams = {
				Application.version,
				miniVersion
			},
			_confirmCallback = function ()
				lc.openUrl(C._appConfig.appUpdateUrl)
			end
		})
	else
		callback()
	end
end

function M.switchBetweenMainAndBattleScene(from, to)
	local msType = InputBattleData.msType

	if msType == D.MissionType.Common then
		UIManager.openPanel(PrefabDefine.CrossScreenPanel, from, to)
	elseif msType == D.MissionType.Elite then
		UIManager.openPanel(PrefabDefine.CrossScreenPanelPurple, from, to)
	elseif msType == D.MissionType.Dome then
		UIManager.openPanel(PrefabDefine.CrossScreenPanelRed, from, to)
	elseif msType == D.MissionType.GlobalDefense then
		UIManager.openPanel(PrefabDefine.CrossScreenPanelBlue, from, to)
	elseif msType == D.MissionType.ArkRebuild then
		UIManager.openPanel(PrefabDefine.CrossScreenPanelArkRebuild, from, to)
	elseif msType == D.MissionType.CrisisZone then
		UIManager.openPanel(PrefabDefine.CrossScreenPanelGreen, from, to)
	elseif msType == D.MissionType.SparkScout then
		UIManager.openPanel(PrefabDefine.CrossScreenPanelSparkScout, from, to)
	else
		UIManager.openPanel(PrefabDefine.CrossScreenPanel, from, to)
	end
end

function M.deleteShareContent(inputText)
	local result = string.match(inputText, "%*%*(.-)%*%*")

	if result then
		return result
	end

	local tb = string.split(inputText, "\n")

	for k, v in pairs(tb) do
		if not string.startsWith(v, "#") then
			if string.startsWith(v, "%*%*") then
				return string.gsub(v, "%*%*", "")
			elseif not string.startsWith(v, "<<< ") then
				return v
			end
		end
	end

	return ""
end

function M.viewOtherInfo(info)
	if info.level then
		UIManager.openPanel(PrefabDefine.OtherInfoPanel, info)

		return
	end

	local uid = info.firebaseId or info._userId

	if uid == C._userId then
		UIManager.openPanel(PrefabDefine.OtherInfoPanel, P:genRankData())

		return
	end

	local now = C.getCurTime()

	if P._cachedPlayerInfos[uid] and now - P._cachedPlayerInfos[uid].timestamp < 86400 then
		UIManager.openPanel(PrefabDefine.OtherInfoPanel, P._cachedPlayerInfos[uid])
	else
		UIManager.showWaiting(10, SID.CLAIM_TIME_OUT)

		local function callback(jsonStr)
			UIManager.hideWaiting()

			if jsonStr == "" then
				V.showToast(SID.PLAYER_DATA_UNAVAILABLE)
			else
				jsonStr = string.unicodeToUtf8(jsonStr)
				local tbl = LuaTableJson.decodeFromLuaJson(jsonStr)

				UIManager.openPanel(PrefabDefine.OtherInfoPanel, tbl)

				tbl.timestamp = C.getCurTime()
				P._cachedPlayerInfos[uid] = tbl

				lc.setTableKeyValue(C.PrefKey.player_info_cache, P._cachedPlayerInfos)
			end
		end

		if lc._isCN then
			Request.sendGetPlayerInfo(uid, callback)
		else
			LuaHelper.queryDocData("player_infos", uid, callback)
		end
	end
end

function M.uploadPlayerInfo()
	if Client._forbidUpload then
		return
	end

	local uploadInfoDay = lc.getIntKeyValue(C.PrefKey.upload_player_info .. C._userId, 0)
	local today = Client.getDayOffset()

	if uploadInfoDay < today then
		lc.setIntKeyValue(C.PrefKey.upload_player_info .. C._userId, today)

		local playerInfo = P:genRankData()
		local jsonStr = LuaTableJson.encodeToCJson(playerInfo)

		if lc._isCN then
			Request.sendUploadPlayerInfo(jsonStr)
		else
			FirebaseManager:WriteToCollection("player_infos", C._userId, jsonStr)
		end
	end
end

function M.openBattleSettlePanel(msId, msType, result, stats)
	if msType == D.MissionType.CrisisZone then
		if P._playerCrisisZone:hasGotReward() then
			UIManager.openPanel(PrefabDefine.CrisisZoneFinalRewardPanel, function ()
				UIManager.openPanel(PrefabDefine.BattleSettlementPanel, msId, msType, result, stats)
			end)
		else
			UIManager.openPanel(PrefabDefine.BattleSettlementPanel, msId, msType, result, stats)
		end
	elseif BattleManager:isMissionPVP() then
		UIManager.openPanel(PrefabDefine.SparkScoutWinPanel, function ()
			UIManager.openPanel(PrefabDefine.BattleSettlementPanel, msId, msType, result, stats)
		end)
	else
		UIManager.openPanel(PrefabDefine.BattleSettlementPanel, msId, msType, result, stats)
	end
end

M.DROP_IDMAP = {
	[17001.0] = 17053,
	[17003.0] = 17053,
	[17002.0] = 17053
}

local function groupDrop(groups, drop, probility, idMap)
	local itemId = drop._itemId
	local group = nil
	itemId = idMap[itemId] or itemId

	if D.isItem(itemId) then
		group = itemId
	elseif D.isRangerEquip(itemId) then
		group = -SID.STR_RANGER_EQUIP
	elseif D.isEquip(itemId) then
		group = -SID.STR_EQUIPMENT
	end

	if not groups[group] then
		groups[group] = {}
	end

	table.insert(groups[group], {
		drop,
		probility
	})
end

local DropGroupWidget = requireLua("DropGroupWidget")

function M.loadDropInfo(panel, container, dropId)
	local drops = DropHelper.readDropsById(dropId)
	local groups = {}
	local totalWeights = 0

	for i = 1, #drops do
		totalWeights = totalWeights + drops[i]._weight
	end

	for i = 1, #drops do
		local drop = drops[i]
		local isSubDrop = drop._subDrop ~= nil

		if not isSubDrop then
			groupDrop(groups, drop, drop._weight / totalWeights, M.DROP_IDMAP)
		else
			local subDrops = DropHelper.readDropsById(drop._itemId)
			local subTotalWeights = 0

			for i = 1, #subDrops do
				subTotalWeights = subTotalWeights + subDrops[i]._weight
			end

			for j = 1, #subDrops do
				local subDrop = subDrops[j]

				groupDrop(groups, subDrop, subDrop._weight * drop._weight / totalWeights / subTotalWeights, M.DROP_IDMAP)
			end
		end
	end

	local orderedGroups = {}

	for k, v in pairs(groups) do
		table.insert(orderedGroups, {
			k,
			v
		})
	end

	table.sort(orderedGroups, function (a, b)
		local probilityA = 0

		for i = 1, #a[2] do
			probilityA = probilityA + a[2][i][2]
		end

		local probilityB = 0

		for i = 1, #b[2] do
			probilityB = probilityB + b[2][i][2]
		end

		return probilityB < probilityA
	end)

	local childCount = container.childCount

	for i = 1, #orderedGroups do
		local group = orderedGroups[i]
		local itemId = group[1]
		local dropProbilities = group[2]
		local widget = nil

		if i <= childCount then
			widget = container:GetChild(i - 1).gameObject
		else
			widget = DropGroupWidget.create(container)
		end

		if itemId < 0 then
			widget:init(-itemId, dropProbilities)
		else
			widget:init(D._itemConfig[itemId]._nameSid, dropProbilities)
		end

		widget:setExpandClick(panel)
	end
end

function M.loadEnemySprite(img, eId)
	if not D._battleEnemyConfig[eId] then
		return
	end

	local eType = D._battleEnemyConfig[eId]._type

	if eType == 1 then
		LuaUnity.setTPSprite(img, string.format("monster/monster_%d", eId), true)
	elseif eType == 2 then
		LuaUnity.setTPSprite(img, string.format("monsterElite/monster_%d", eId), true)
	elseif eType == 3 then
		LuaUnity.setTPSprite(img, string.format("monsterBoss/monster_%d", eId), true)
	end
end

function M.getSparkGradeTxtParam(gradeId)
	local maxGradeId = P._playerActivitySparkScout:getFinalGrade()

	if gradeId < maxGradeId then
		local showSubGrade = P._playerActivitySparkScout:readShowSubGrade(gradeId)
		local _, _, gradeStarNum = P._playerActivitySparkScout:parseGradeId(gradeId)

		if gradeStarNum == 0 then
			gradeStarNum = nil
		end

		return P._playerActivitySparkScout:readGradeName(gradeId), showSubGrade
	else
		local _, _, gradeStarNum = P._playerActivitySparkScout:parseGradeId(gradeId)

		if gradeStarNum == 0 then
			gradeStarNum = nil
		end

		return P._playerActivitySparkScout:readGradeName(gradeId)
	end
end

function M.loadSparkGradeTitle(txtGrade, gradeId)
	local maxGradeId = P._playerActivitySparkScout:getFinalGrade()

	if gradeId < maxGradeId then
		local showSubGrade = P._playerActivitySparkScout:readShowSubGrade(gradeId)

		txtGrade:SetLocalize(P._playerActivitySparkScout:readGradeName(gradeId), showSubGrade)
	else
		txtGrade:SetLocalize(P._playerActivitySparkScout:readGradeName(gradeId))
	end
end

function M.loadSparkScoutGradeStar(tfGradeStarArea, gradeId, showFullStars)
	local grade, subGrade, curStarNum = P._playerActivitySparkScout:parseGradeId(gradeId)
	local maxGradeId = P._playerActivitySparkScout:getFinalGrade()

	if maxGradeId <= gradeId or not showFullStars then
		M.loadSparkScoutMaxGradeStar(tfGradeStarArea, curStarNum)
	else
		local gradeStarNum = P._playerActivitySparkScout:getGradeStar(gradeId)

		M.loadSparkScoutUnderMaxGradeStar(tfGradeStarArea, gradeStarNum, curStarNum)
	end
end

function M.loadSparkScoutMaxGradeStar(tfGradeStarArea, curStar)
	local count = tfGradeStarArea.childCount

	for i = 1, count - 1 do
		local tf = tfGradeStarArea:GetChild(i - 1)

		tf:SetActive(i == 1)
	end

	tfGradeStarArea:GetChild(0):GetChild(1):SetActive(true)

	local tfStarNum = tfGradeStarArea:GetChild(tfGradeStarArea.childCount - 1)

	tfStarNum:SetActive(true)

	tfStarNum:GetComponent("TMP_Text").text = "x" .. (curStar or 0)
end

function M.loadSparkScoutUnderMaxGradeStar(tfGradeStarArea, gradeStarNum, curStar)
	local count = tfGradeStarArea.childCount - 1

	for i = 1, math.max(count, gradeStarNum) do
		if i <= gradeStarNum then
			local tf = nil

			if count < i then
				tf = GameObject.Instantiate(tfGradeStarArea:GetChild(0), tfGradeStarArea).transform

				tf:SetSiblingIndex(i - 1)
			else
				tf = tfGradeStarArea:GetChild(i - 1)
			end

			tf:SetActive(true)

			local tfStarYellow = tf:GetChild(1)

			lc.setLocalScale(tfStarYellow, i <= curStar and 1 or 0)

			if i <= curStar then
				tfStarYellow:GetComponent("Image").color = Color.White
			end

			tfStarYellow:SetActive(true)
		else
			tfGradeStarArea:GetChild(i - 1):SetActive(false)
		end
	end

	local tfStarNum = tfGradeStarArea:GetChild(tfGradeStarArea.childCount - 1)

	tfStarNum:SetActive(false)
end

function M.loadSparkScoutGrades(tfContainer, playerData, showRankId)
	local goGradeWidget = tfContainer._goGradeWidget
	local tfGradesContainer = tfContainer._tfGradesContainer
	local tfStarArea = tfContainer._tfStarArea
	local avatarWidget = tfContainer._tfAvatarWidget
	local txtName = tfContainer._txtName
	local txtGradeName = tfContainer._txtGradeName
	local imgGrade = tfContainer._imgGrade
	local txtAtk = tfContainer._txtAtk
	local txtNum = tfContainer._txtChipNum
	local name = playerData.name or "???"
	local avatar = playerData.avatar
	local avatarFrame = playerData.avatarFrame
	local gradeId = playerData.gradeId or 110
	local atk = playerData.atk or 0
	local cn = playerData.cn or 0
	local rankId = playerData.rankId
	local cfg = P._playerActivitySparkScout:getGradeCfgById(gradeId)

	if txtName then
		if showRankId and rankId then
			txtName.text = string.format("%s(%d)", name, rankId)
		else
			txtName.text = name
		end
	end

	V.loadAvatar(avatarWidget, avatar, avatarFrame)

	if txtGradeName then
		M.loadSparkGradeTitle(txtGradeName, gradeId)
	end

	if tfStarArea then
		M.loadSparkScoutGradeStar(tfStarArea, gradeId)
	end

	if imgGrade then
		M.loadSparkGradeIconSprite(imgGrade, gradeId)
	end

	if tfGradesContainer then
		M.loadSparkGradeIcon(tfGradesContainer, nil, gradeId)
	end

	if txtAtk then
		txtAtk.text = atk
	end

	if txtNum then
		txtNum.text = cn
	end
end

function M.loadSparkGradeWidget(goGradePeer, gradeId, showFullStars)
	local tfGradesContainer = goGradePeer._tfGradesContainer
	local tfStarArea = goGradePeer._tfStarArea
	local txtGradeName = goGradePeer._txtGradeName
	local imgGradeIcon = goGradePeer._imgGradeIcon

	if txtGradeName then
		M.loadSparkGradeTitle(txtGradeName, gradeId)
	end

	M.loadSparkScoutGradeStar(tfStarArea, gradeId, showFullStars)
	M.loadSparkGradeIconSprite(imgGradeIcon, gradeId)
end

function M.loadSparkGradeIconSprite(imgGradeIcon, gradeId)
	local grade = math.floor(gradeId / 100)
	local subGrade = math.floor((gradeId - grade * 100) / 10)
	grade = Mathf.Clamp(grade, 1, 6)
	subGrade = Mathf.Clamp(grade, 1, 4)

	if grade == 6 then
		LuaUnity.setTPSprite(imgGradeIcon, "midweek/grade6", true)
	else
		local showSubGrade = P._playerActivitySparkScout:readShowSubGrade(gradeId)

		LuaUnity.setTPSprite(imgGradeIcon, string.format("midweek/grade%d_%d", grade, showSubGrade), true)
	end
end

local ReusableWidget = {}
local ReusableWidgetMaxNum = 5

function M.getReusableWidget(namekey, parent, createFunc)
	if not ReusableWidget[namekey] then
		ReusableWidget[namekey] = {}
	end

	local pool = ReusableWidget[namekey]
	local goWidget = pool[#pool]

	if goWidget then
		pool[#pool] = nil

		goWidget.transform:SetParent(parent)
	else
		goWidget = createFunc(namekey)
	end

	return goWidget
end

function M.recycleReusableWidget(goWidget)
	local namekey = goWidget.name

	if not ReusableWidget[namekey] then
		ReusableWidget[namekey] = {}
	end

	local pool = ReusableWidget[namekey]

	if ReusableWidgetMaxNum < #pool then
		local go = pool[#pool]
		pool[#pool] = nil

		GameObject.DestroyImmediate(go)
	end

	pool[#pool + 1] = goWidget
	local tf = goWidget.transform

	tf:SetParent(MainGameRoot._currentCanvasDontClearTop)
	goWidget:SetActive(false)
end

function M.getSparkGradeWidget(gradeId, parent)
	local g1, sg1, gs1 = P._playerActivitySparkScout:parseGradeId(gradeId)
	local loadGrade = g1 * 100 + 10
	local goGradeWidget = M.getReusableWidget(string.format("Grade%dWidget", loadGrade), parent, function (nameKey)
		local goWidget = LuaUnity.createGameObject(string.format("Assets/FW/Prefabs/UI/widget/Grade%dWidget.prefab", loadGrade), parent)
		goWidget.name = nameKey

		return goWidget
	end)

	lc.setLocalScale(goGradeWidget, 1)
	lc.setLocalPosition(goGradeWidget, 0, 0, 0)
	goGradeWidget:SetActive(true)

	return goGradeWidget
end

function M.loadSparkGradeIcon(gradeParent, currentGradeId, targetGradeId, showAnim)
	local module = P._playerActivitySparkScout

	if currentGradeId then
		local g1, sg1, gs1 = module:parseGradeId(currentGradeId)
		local g2, sg2, gs2 = module:parseGradeId(targetGradeId)
		local goGradeWidget = gradeParent:GetChild(0).gameObject
		local loadGrade = g2 * 100 + 10
		sg1 = module:readShowSubGrade(currentGradeId)
		sg2 = module:readShowSubGrade(targetGradeId)

		if g1 ~= g2 then
			if gradeParent.childCount > 0 then
				for i = gradeParent.childCount, 1, -1 do
					local goGradeWidget11 = gradeParent:GetChild(0).gameObject

					M.recycleReusableWidget(goGradeWidget11)
				end
			end

			goGradeWidget = M.getSparkGradeWidget(loadGrade, gradeParent)
		end

		if g1 ~= g2 or sg1 ~= sg2 then
			local img = goGradeWidget.transform:GetChild(0):GetChild(0):Find("ImgLevel"):GetComponent("Image")

			LuaUnity.setTPSprite(img, string.format("midweek/grade-%d_level_%d", loadGrade, sg2), true)
		end

		if showAnim then
			goGradeWidget:GetChild(0):GetComponent("Animation"):Play()
		end
	else
		if gradeParent.childCount > 0 then
			for i = gradeParent.childCount, 1, -1 do
				local goGradeWidget = gradeParent:GetChild(0).gameObject

				M.recycleReusableWidget(goGradeWidget)
			end
		end

		local g2, sg2, gs2 = module:parseGradeId(targetGradeId)
		sg2 = module:readShowSubGrade(targetGradeId)
		local loadGrade = g2 * 100 + 10
		local goGradeWidget = M.getSparkGradeWidget(loadGrade, gradeParent)
		local img = goGradeWidget.transform:GetChild(0):GetChild(0):Find("ImgLevel"):GetComponent("Image")

		LuaUnity.setTPSprite(img, string.format("midweek/grade-%d_level_%d", loadGrade, sg2), true)

		if showAnim then
			goGradeWidget:GetChild(0):GetComponent("Animation"):Play()
		end
	end
end

function M.setTextTimeAgo(text, timestamp)
	local ct = C.getCurTime()
	local agoType, value = C.getTimeAgoArgs(ct - timestamp)
	local sid = nil

	if agoType == 1 then
		sid = SID.TIMER_D_AGO
	elseif agoType == 2 then
		sid = SID.TIMER_H_AGO
	elseif agoType == 3 then
		sid = SID.TIMER_M_AGO
	elseif agoType == 4 then
		sid = SID.TIMER_S_AGO
	else
		sid = SID.TIMER_S_AGO
		value = 1
	end

	text:SetLocalize(sid, value)
end

function M.addRechargeScoreWidget(iapId, parent, offsetX, offsetY, scale)
	local w = parent:Find("AnniversaryRechargeScoreWidget")

	if not P._playerActivity:isAnniversaryOpening() or not P._playerActivityAnniversary:showSystemEntry() then
		if w then
			w:SetActive(false)
		end

		return
	end

	local rechargeScore = D._iapConfig[iapId]._rechargeScore

	if rechargeScore == nil or rechargeScore == 0 then
		return
	end

	offsetX = offsetX or 0
	offsetY = offsetY or 0
	scale = scale or 1

	if w == nil then
		w = LuaUnity.createGameObject("Assets/FW/Prefabs/UI/widget/AnniversaryRechargeScoreWidget.prefab", parent.transform)
	end

	w.name = "AnniversaryRechargeScoreWidget"
	w:GetChild(0):GetChild(1):GetComponent("TMP_Text").text = rechargeScore
	local s = parent.transform.sizeDelta
	local width = s.x
	local height = s.y

	w:SetLocalScale(scale, scale, scale)
	w:SetLocalPosition(width / 2 - width / 10 + offsetX, height / 2 + offsetY, 0)
end

function M.loadItemSprite(img, cid, small)
	if small then
		LuaUnity.setTPSprite(img, D.toSmallSprite(cid), true)
	else
		LuaUnity.setTPSprite(img, D.toSprite(cid), true)
	end
end

function M.loadSkinQualityGradient(tmp, quality)
	LuaHelper.SetTMPColorGradientPreset(tmp, string.format("Assets/FW/Font/ColorGradients/SkinTitleQuality%d.asset", quality))
end

function M.getRightCardPanel()
	return PrefabDefine.RightCardTest1Panel
end
