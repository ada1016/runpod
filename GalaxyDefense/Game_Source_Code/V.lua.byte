end

function M.showResultCode(resCode, param)
	if not resCode then
		return
	end

	if resCode < 10000 then
		local str = string.format("RESULT_CODE_%d", resCode)

		if param then
			M.showToast({
				SID[str],
				param
			})
		else
			M.showToast(SID[str])
		end
	else
		M.showItemNotEnough(resCode, P._playerAsset:getAssetNum(resCode), param)
	end
end

function M.showSystemUnlockTips(systemId)
	local systemConfig = D._systemUnlockConfig[systemId]

	if systemConfig then
		local sid = string.format("TIP_SYSTEM_UNLOCK_TIP_%d", systemConfig._unlockType)

		V.showToast({
			SID[sid],
			systemConfig._unlockVal
		})
	end
end

local diamondPromptKey = "diamond_use"

function M.tryShowDiamondConfirm(costCid, costDiamond, callback)
	local showConfirm = costCid == D.ResType.diamond and D.DIAMOND_USE_CONFIRM_NUM < costDiamond and lc.getIntKeyValue(diamondPromptKey, 0) < C.getCurTime()

	if not showConfirm then
		return false
	end

	UIManager.openPanel(PrefabDefine.PromptsPanel, {
		_checkNet = true,
		_promptKey = diamondPromptKey,
		_title = SID.TITLE_TIP,
		_content = SID.STR_CONFIRM_USE_DIAMOND,
		_cParams = string.format(" <sprite name=\"item_small_10002\">%s ", costDiamond or "???"),
		_txtConfirm = SID.STR_CONFIRM,
		_fcCancel = SID.STR_CANCEL,
		_confirmCallback = callback
	})

	return true
end

function M.tryShowConfirm(promptKey, callback, contentSid, cparams, showResCid)
	local showConfirm = not promptKey or lc.getIntKeyValue(promptKey, 0) < C.getCurTime()

	if not showConfirm then
		return false
	end

	UIManager.openPanel(PrefabDefine.PromptsPanel, {
		_checkNet = showResCid ~= nil,
		_promptKey = promptKey,
		_title = SID.TITLE_TIP,
		_content = contentSid,
		_cParams = cparams or "???",
		_txtConfirm = SID.STR_CONFIRM,
		_fcCancel = SID.STR_CANCEL,
		_confirmCallback = callback,
		_showResCid = showResCid
	})

	return true
end

function M.tryShowConfirmWithParams(promptKey, callback, params)
	local showConfirm = lc.getIntKeyValue(promptKey, 0) < C.getCurTime()

	if not showConfirm then
		return false
	end

	UIManager.openPanel(PrefabDefine.PromptsPanel, {
		_promptKey = promptKey,
		_title = SID.TITLE_TIP,
		_content = params.contentSid,
		_cParams = params.cparams or "???",
		_txtConfirm = params.confirmSid or SID.STR_CONFIRM,
		_fcCancel = params.cancelSid or SID.STR_CANCEL,
		_confirmCallback = callback,
		_showResCid = params.showResCid
	})

	return true
end

