function M.setPlayerName(text, name, colorType, defaultColor, medal)
	if colorType == 1 then
		text.text = string.format(M.SVIP_FOREVER_PLAYER_NAME_MATERIAL_FORMAT, name)
		text.color = Color.static(255, 255, 255, 255)
	elseif colorType == 2 then
		text.text = string.format(M.SVIP_LIMIT_PLAYER_NAME_MATERIAL_FORMAT, name)
		text.color = Color.static(255, 255, 255, 255)
	else
		text.text = name

		if defaultColor then
			text.color = Color.str2Static(defaultColor)
		end
	end

	if medal and medal > 0 then
		text.text = string.format("<sprite name=\"item_small_%d\">%s", medal, text.text)
	end
end

function M.setPlayerNameByRankData(text, data, showRankId)
	if showRankId and data.rankId then
		local nameStr = string.format("%s(%d)", data.name, data.rankId)

		V.setPlayerName(text, nameStr, data.nameColor, "85E1F8", data.medal)
	else
		V.setPlayerName(text, data.name, data.nameColor, "85E1F8", data.medal)
	end
end

function M.getPlayerNameStr(name, colorType, defaultColor)
	if colorType == 1 then
		return string.format(M.SVIP_FOREVER_PLAYER_NAME_MATERIAL_FORMAT_COLOR, "ffffff", name)
	elseif colorType == 2 then
		return string.format(M.SVIP_LIMIT_PLAYER_NAME_MATERIAL_FORMAT_COLOR, "ffffff", name)
	elseif defaultColor then
		return string.format(M.COMMON_RICH_STR_COLOR, defaultColor, name)
	else
		return name
	end
end

function M.formatTimeS2DHMS(seconds)
	if seconds < 0 then
		seconds = 0
	end

	return string.format("%02d:%02d:%02d:%02d", math.floor(seconds / 86400), math.floor(seconds % 86400 / 3600), math.floor(seconds % 3600 / 60), seconds % 60)
end

function M.formatTimeSAuto(seconds)
	if seconds < 0 then
		seconds = 0
	end

	if D.DAY_SECONDS < seconds then
		return SID.TIMER_D_H_M, math.floor(seconds / 86400), math.floor(seconds % 86400 / 3600), math.floor(seconds % 3600 / 60)
	end

	return SID.TIMER_H_M_S, math.floor(seconds / 3600), math.floor(seconds % 3600 / 60), seconds % 60
end

function M.formatTimeS2DHM(seconds)
	if seconds < 0 then
		seconds = 0
	end

	return string.format("%02d:%02d:%02d", math.floor(seconds / 86400), math.floor(seconds % 86400 / 3600), math.floor(seconds % 3600 / 60))
end

function M.formatTimeS2HMS(seconds)
	if seconds < 0 then
		seconds = 0
	end

	return string.format("%02d:%02d:%02d", math.floor(seconds / 3600), math.floor(seconds % 3600 / 60), seconds % 60)
end

function M.getFormatLeftTimeStr(seconds, simple)
	local sid, p1, p2, p3 = M.formatTimeSAuto(seconds)

	if simple then
		return string.format("%02d:%02d:%02d", p1, p2, p3)
	end

	local ts = LcLocalization.getTextStr(sid)
	ts = string.gsub(ts, "{0}", p1)
	ts = string.gsub(ts, "{1}", p2)

	return string.gsub(ts, "{2}", p3)
end

function M.getLeftTimeStr(seconds)
	if seconds < 0 then
		seconds = 0
	end

	if seconds > 86400 then
		return string.gsub(LcLocalization.getTextStr(SID.PERIOD_DAY), "{0}", math.ceil(seconds / 86400))
	elseif seconds > 3600 then
		return string.gsub(LcLocalization.getTextStr(SID.PERIOD_DAY), "{0}", math.ceil(seconds / 3600))
	elseif seconds > 60 then
		return string.gsub(LcLocalization.getTextStr(SID.PERIOD_DAY), "{0}", math.ceil(seconds / 60))
	else
		return string.gsub(LcLocalization.getTextStr(SID.PERIOD_DAY), "{0}", math.floor(seconds))
	end
end

function M.formatLeftTime(txtTime, seconds, secondsDay, sid)
	if seconds < 0 then
		seconds = 0
	end

	if sid then
		local day = math.ceil(seconds / 86400)

		if day > (secondsDay or 3) then
			txtTime:SetLocalize(sid, day)
		else
			txtTime:SetLocalize(sid, M.formatTimeS2HMS(seconds))
		end
	else
		local day = math.ceil(seconds / 86400)

		if day > (secondsDay or 3) then
			txtTime:SetLocalize(SID.LEFT_DAY, day)
		else
			txtTime.text = M.formatTimeS2HMS(seconds)
		end
	end
end

function M.formatTimeS2MS(seconds)
	if seconds < 0 then
		seconds = 0
	end

	return string.format("%02d:%02d", math.floor(seconds / 60), seconds % 60)
end

function M.formatNeedStr1(tmp, current, need)
	if need <= current then
		tmp.text = string.format("<color=#51D270>%s</color>/%s", string.formatNumber(current), string.formatNumber(need))
	else
		tmp.text = string.format("<color=#DD6261>%s</color>/%s", string.formatNumber(current), string.formatNumber(need))
	end
end

function M.formatNeedStr1WithColor(tmp, current, need, color1, color2)
	if type(current) == "table" then
		current = current()
	end

	if need <= current then
		tmp.text = string.format("<color=#%s>%s</color>/%s", color1, string.formatNumber(current), string.formatNumber(need))
	else
		tmp.text = string.format("<color=#%s>%s</color>/%s", color2, string.formatNumber(current), string.formatNumber(need))
	end
end

function M.getNeedStr1(current, need)
	if need <= current then
		return string.format("%d/%d", current, need)
	else
		return string.format("<color=#DD6261>%d</color>/%d", current, need)
	end
end

function M.getLeftStr(current, need)
	return string.format("%d/%d", current, need)
end

function M.getLeftStrRed(current, need)
	if current > 0 then
		return string.format("%d/%d", current, need)
	else
		return string.format("<color=#DD6261>%d</color>/%d", current, need)
	end
end

function M.loadItemCost(imgIcon, txtText, cid, cost, panel, showInfo)
	LuaUnity.setTPSprite(imgIcon, D.toSmallSprite(cid), true)
	V.formatNeedStr1(txtText, math.floor(P._playerAsset:getAssetNum(cid)), cost)
	panel:setClick(imgIcon:GetComponent("Button"), function ()
		if showInfo then
			V.showItemInfoPanel(cid, P._playerAsset:getAssetNum(cid))
		else
			V.showItemInfoPanel(cid, P._playerAsset:getAssetNum(cid), cost)
		end
	end)
end

function M.loadItemNum(parent, itemId, num)
	local tfImg = parent:GetChild(0)

	lc.setLocalScale(tfImg, 1, 1, 1)

	local img = tfImg:GetComponent("Image")
	local txt = parent:GetChild(1):GetComponent("TextMeshProUGUI")

	LuaUnity.setTPSprite(img, "itemSmall/item_small_" .. itemId)

	txt.text = num or 1
end

function M.loadItemNumWithLight(parent, itemId, num)
	local tfImg = parent:GetChild(1)

	lc.setLocalScale(tfImg, 1, 1, 1)

	local img = tfImg:GetComponent("Image")
	local txt = parent:GetChild(2):GetComponent("TextMeshProUGUI")

	LuaUnity.setTPSprite(img, "itemSmall/item_small_" .. itemId)

	txt.text = num or 1
end

function M.loadAdIcon(img, removeAd)
	LuaUnity.setTPSprite(img, removeAd and "general/g_icon_12_2" or "general/g_icon_12", true)
end

function M.loadAdButton1(goAdBtn, gray, grayStrSid, notGrayStrSid)
	local isAdRemoved = P._playerRight:isAdRemoved()
	local bg = goAdBtn:GetChild(0)
	local bgGradient = bg:GetComponent("UIGradient")
	local bgImage = bg:GetComponent("Image")
	local content = goAdBtn:Find("content")
	local text1 = content:GetChild(0):GetComponent("TextMeshProUGUI")
	local text2 = content:GetChild(1):GetComponent("TextMeshProUGUI")
	local imgLight = goAdBtn:Find("imgLight"):GetComponent("Image")

	if gray then
		text1:SetLocalize(grayStrSid or SID.STR_CLAIMED)
	else
		text1.text = string.format("%s %s", D.getTMPSpriteRichText(isAdRemoved and "ad_removed" or "ad"), LcLocalization.getTextStr(notGrayStrSid or SID.STR_FREE))
	end

	bgGradient.enabled = not gray and isAdRemoved

	if isAdRemoved then
		if gray then
			bgImage.color = Color.str2Static(M.COMMON_COLOR.btn_gray)
			text1.color = Color.Black
			text2.color = Color.Black
			imgLight.color = Color.str2Static(M.COMMON_COLOR.btn_gray_light)
		else
			bgImage.color = Color.White
			text1.color = Color.str2Static(M.COMMON_COLOR.btn_ad_remove_text)
			text2.color = Color.str2Static(M.COMMON_COLOR.btn_ad_remove_text)
			imgLight.color = Color.str2Static("FFFFFF_0")
		end
	else
		if gray then
			bgImage.color = Color.str2Static(M.COMMON_COLOR.btn_gray)
			imgLight.color = Color.str2Static(M.COMMON_COLOR.btn_gray_light)
		else
			bgImage.color = Color.str2Static(M.COMMON_COLOR.btn_ad_yellow)
			imgLight.color = Color.str2Static(M.COMMON_COLOR.btn_ad_yellow_light)
		end

		text1.color = Color.Black
		text2.color = Color.str2Static(M.COMMON_COLOR.btn_ad_yellow)
	end
end

function M.loadAdButton2(goAdBtn, params)
	local isAdRemoved = P._playerRight:isAdRemoved()
	local tfGray = goAdBtn:GetChild(0)
	local tfAd = goAdBtn:GetChild(1)
	local tfRemoveAd = goAdBtn:GetChild(2)
	params = params or {}
	local showAd = params.showAd or false

	tfGray:SetActive(not showAd)
	tfRemoveAd:SetActive(showAd and isAdRemoved)
	tfAd:SetActive(showAd and not isAdRemoved)

	if not showAd then
		local btnStyle = params.btnStyle or M.BTN_STYLE.gray

		M.setBtnStyle(tfGray, btnStyle, params.txt)
	else
		local handleTf = tfRemoveAd

		if isAdRemoved then
			handleTf = tfRemoveAd
		else
			handleTf = tfAd
		end

		local txtAfterAd = nil

		if type(params.txt) == "number" then
			txtAfterAd = LcLocalization.getTextStr(params.txt)
		else
			txtAfterAd = params.txt
		end

		local adTxt = string.format("%s %s", D.getTMPSpriteRichText(isAdRemoved and "ad_removed" or "ad"), txtAfterAd)
		handleTf:Find("txt"):GetComponent("TMP_Text").text = adTxt
	end
end

local ItemWidget = requireLua("ItemWidget")

function M.loadFixRewardsWidget(panel, widgets, rewards, claimed, canClaim)
	local len = rewards.c or #rewards

	if claimed == nil then
		claimed = false
	end

	canClaim = canClaim or false

	for i = 1, math.max(#widgets, len) do
		local goWidget = widgets[i]

		if i <= len then
			ItemWidget.noCreate(goWidget)
			panel:setClick(goWidget._btnClick, function ()
				goWidget:rewardclickCallback()
			end)
			goWidget:SetActive(true)

			local data = rewards[i]
			local cid = data.cid or data[1]
			local num = data.num or data[2]

			goWidget:init(cid, num, data[3])
			goWidget:setClaimed(claimed)
			goWidget:setCanClaim(canClaim and not claimed)
		else
			goWidget:SetActive(false)
		end
	end
end

local SimpleItemWidget = requireLua("SimpleItemWidget")

function M.loadRewardsWidget(panel, tfRewardsParent, rewards, claimed, canClaim, scale)
	local len = rewards.c or #rewards

	if claimed == nil then
		claimed = false
	end

	local childCount = tfRewardsParent.childCount
	canClaim = canClaim or false

	for i = 1, math.max(childCount, len) do
		local goWidget = nil

		if i <= childCount then
			goWidget = tfRewardsParent:GetChild(i - 1).gameObject

			SimpleItemWidget.noCreate(goWidget)
		else
			goWidget = SimpleItemWidget.create(tfRewardsParent)
		end

		if i <= len then
			panel:setClick(goWidget._btnClick, function ()
				goWidget:rewardclickCallback()
			end)
			goWidget:SetActive(true)

			local data = rewards[i]
			local cid = data.cid or data[1]
			local num = data.num or data[2]

			goWidget:init(cid, num, data[3])
			goWidget:setClaimed(claimed)
			goWidget:setCanClaim(canClaim and not claimed)

			if scale then
				goWidget:SetLocalScale(scale, scale, scale)
			end
		else
			goWidget:SetActive(false)
		end
	end
end

function M.loadChipNameAndDesc(txtName, txtDesc, chipId)
	local conf = D._gemConfig[chipId]
	local effectConf = D._gemEffectConfig[conf._effect]

	if txtName then
		if P._inSparkScout and effectConf._weaponId ~= 0 then
			txtName:SetLocalize(SID.STR_NAME_CHIP, -D._weaponConfig[effectConf._weaponId]._skillNameSid, -SID["STR_QUALITY_" .. conf._quality])
		else
			txtName:SetLocalize(SID.STR_NAME_CHIP, -SID["STR_QUALITY_" .. conf._quality], -SID["STR_PART_" .. conf._part])
		end
	end

	if txtDesc then
		M.loadChipDescription(txtDesc, effectConf, conf._param, conf._params)
	end
end

function M.loadChipDescription(txt, conf, param, params, ignoreLink)
	if conf._id == 102 or conf._id == 103 or conf._id == 209 or conf._id == 407 or conf._id == 607 then
		if params[2] == 0 then
			txt:SetLocalize(conf._descSid, lc.toStr(params[1]), -SID.STR_NO_CHANGE)
		else
			local numText = params[2] > 0 and "+" .. lc.toStr(params[2]) .. "%" or lc.toStr(params[2]) .. "%"

			txt:SetLocalizeS(conf._descSid, tostring(lc.toStr(params[1])), numText)
		end
	elseif conf._id == 108 then
		if param == 0 then
			txt:SetLocalize(conf._descSid, -SID.STR_NO_CHANGE)
		else
			local numText = param > 0 and "+" .. lc.toStr(param) .. "%" or lc.toStr(param) .. "%"

			txt:SetLocalizeS(conf._descSid, numText)
		end
	elseif param then
		txt:SetLocalizeS(conf._descSid, tostring(lc.toStr(param)))
	elseif lc.lenTable(params) == 2 then
		txt:SetLocalizeS(conf._descSid, tostring(lc.toStr(params[1])), tostring(lc.toStr(params[2])))
	elseif lc.lenTable(params) == 3 then
		txt:SetLocalizeS(conf._descSid, tostring(lc.toStr(params[1])), tostring(lc.toStr(params[2])), tostring(lc.toStr(params[3])))
	end

	if not ignoreLink then
		M.setBuffLinkClick(txt)
	end
end

function M.loadChipRareBatchDescription(txt, conf, batchQuality, batchParam, batchParams, showQuality, ignoreLink)
	if batchParam and #batchParam > 0 then
		txt:SetLocalizeS(conf._descSid, M.getBatchEffectParamStr(batchQuality, batchParam, nil, showQuality))
	elseif lc.lenTable(batchParams[1]) == 2 then
		txt:SetLocalizeS(conf._descSid, M.getBatchEffectParamStr(batchQuality, batchParams, 1, showQuality), M.getBatchEffectParamStr(batchQuality, batchParams, 2, showQuality))
	elseif lc.lenTable(batchParams[1]) == 3 then
		txt:SetLocalizeS(conf._descSid, M.getBatchEffectParamStr(batchQuality, batchParams, 1, showQuality), M.getBatchEffectParamStr(batchQuality, batchParams, 2, showQuality), M.getBatchEffectParamStr(batchQuality, batchParams, 3, showQuality))
	end

	if not ignoreLink then
		M.setBuffLinkClick(txt)
	end
end

function M.getQualityColorRichText(str, quality)
	if quality == D.Quality.COLORFUL then
		return string.format("<material=en_US Outline Shadow Colorful><color=#ffffff>%s</color></material>", str)
	else
		return string.format("<color=#%s>%s</color>", V.QUALITY_BG_COMMON_TXT[quality], str)
	end
end

function M.getBatchEffectParamStr(batchQuality, batchP, arrayIdx, showQuality)
	if #batchQuality == 1 then
		local value = arrayIdx and batchP[1][arrayIdx] or batchP[1]

		if value == 0 then
			return M.getQualityColorRichText(LcLocalization.getTextStr(SID.STR_NO_CHANGE), batchQuality[1])
		else
			value = lc.toStr(value)

			return M.getQualityColorRichText(value, batchQuality[1])
		end
	end

	local str = #batchQuality > 1 and {
		LcLocalization.getTextStr(SID.STR_PARENTHESIS_LEFT),
		LcLocalization.getTextStr(SID.STR_PARENTHESIS_RIGHT)
	}
	showQuality = showQuality or batchQuality[1]
	local haveUnchangedValue = false

	for i = 1, #batchP do
		local qua = batchQuality[i]
		local value = arrayIdx and batchP[i][arrayIdx] or batchP[i]
		local value2Str = lc.toStr(value)
		local sss = nil

		if value == 0 then
			sss = M.getQualityColorRichText(LcLocalization.getTextStr(SID.STR_NO_CHANGE), batchQuality[i])
			haveUnchangedValue = true
		else
			if haveUnchangedValue then
				value2Str = "+" .. value2Str .. "%"
			end

			sss = M.getQualityColorRichText(value2Str, batchQuality[i])
		end

		if showQuality == qua then
			table.insert(str, 1, sss)
		else
			table.insert(str, #str, sss)

			if i < #batchP then
				table.insert(str, #str, ",")
			end
		end
	end

	return table.concat(str)
end

function M.loadAtkClassText(text, id)
	if id > 0 then
		if BattlePropEnum.AtkNatureGuard <= id then
			text:SetLocalize(SID["STR_ATK_NATURE_" .. id - BattlePropEnum.AtkNatureGuard])
		else
			text:SetLocalize(SID.STR_WEAPON_ATK, -D._weaponConfig[id]._skillNameSid)
		end
	else
		text:SetLocalize(-id)
	end
end

function M.loadEquipAttribute(obj, equip)
	local data = {}

	lc.prefabVar(obj, data)
	data._txtTitle:SetLocalize(SID.STR_NAME_EQUIP, -SID["STR_QUALITY_" .. equip:quality()], -SID["STR_PART_" .. equip:part()])

	data._txtBaseAtk.text = equip:atk()
	data._txtLevelAtk.text = P._playerRole:getChipSystemLevelByPart(equip:part())

	data._txtPart:SetLocalize(SID["STR_PART_" .. equip:part()])
	data._txtEquipGrade:SetLocalize(SID.STR_GRADE_X, equip:grade())
	LuaUnity.setTPSprite(data._imgBg, string.format("item/frame-frame_%02d", equip:quality()))
	LuaUnity.setTPSprite(data._imgFrame, string.format("item/frame-frame_%02d_out", equip:quality()))
	LuaUnity.setTPSprite(data._imgIcon, "general/equip1_" .. equip:part(), true)

	local extra = equip:extra()

	if extra then
		data._goExtra:SetActive(true)

		if extra[1] then
			M.loadAtkClassText(data._txtExtraName1, extra[1][1])

			data._txtExtraValue1.text = extra[1][2]
		end

		if extra[2] then
			M.loadAtkClassText(data._txtExtraName2, extra[2][1])
			data._txtExtraValue2.transform.parent:SetActive(true)

			data._txtExtraValue2.text = extra[2][2]
		else
			data._txtExtraValue2.transform.parent:SetActive(false)
		end

		if extra[3] then
			M.loadAtkClassText(data._txtExtraName3, extra[3][1])
			data._txtExtraValue3.transform.parent:SetActive(true)

			data._txtExtraValue3.text = extra[3][2]
		else
			data._txtExtraValue3.transform.parent:SetActive(false)
		end
	else
		data._goExtra:SetActive(false)
	end
end

function M.loadRangerEquipAttribute(obj, equip)
	local peer = {}

	lc.prefabVar(obj, peer)

	local cfg = D._rangerEquipConfig[equip.cid]

	if peer._txtTitle then
		peer._txtTitle:SetLocalize(SID.STR_RANGER_EQUIP_NAME, cfg._level)
	end

	LuaUnity.setTPSprite(peer._imgBg, string.format("item/frame-frame_%02d", cfg._quality))
	LuaUnity.setTPSprite(peer._imgFrame, string.format("item/frame-frame_%02d_out", cfg._quality))
	LuaUnity.setTPSprite(peer._imgIcon, "item/item_" .. equip.cid, true)

	local skill1 = equip.skill1
	local skillCfg = D._rangerEquipSkillConfig[skill1]
	local prop1Value = skillCfg._value[1]

	peer._txtProp1:SetLocalize(skillCfg._descSid)

	peer._txtPropValue1.text = string.format("+%s", skillCfg._propId == BattlePropEnum.Atk and prop1Value or prop1Value .. "%")

	peer._txtEffect1:SetLocalize(SID.STR_EFFECT_X, 1)
	peer._txtPropEffect2:SetLocalize(SID.STR_EFFECT_X, 2)
	peer._txtSkillEffect2:SetLocalize(SID.STR_EFFECT_X, 2)

	if peer._txtUnlock then
		peer._txtUnlock:SetLocalize(SID.TIP_RANGER_EQUIP_EFFECT_LEVEL, cfg._level)
	end

	local skill2 = equip.skill2

	if skill2 then
		skillCfg = D._rangerEquipSkillConfig[skill2]

		if skillCfg._propId < 1000 then
			peer._goSkill2PropContent:SetActive(true)
			peer._goSkill2SkillContent:SetActive(false)

			local prop2Value = skillCfg._value[1]

			peer._txtProp2:SetLocalize(skillCfg._descSid)

			peer._txtPropValue2.text = string.format("+%s", skillCfg._propId == BattlePropEnum.Atk and prop2Value or prop2Value .. "%")
		else
			peer._goSkill2PropContent:SetActive(false)
			peer._goSkill2SkillContent:SetActive(true)
			lc.prefabVar(peer._goSkill2SkillContent, peer)

			if skillCfg._value then
				if #skillCfg._value == 1 then
					peer._txtSkillDesc:SetLocalizeS(skillCfg._descSid, lc.toStr(skillCfg._value[1]))
				elseif #skillCfg._value == 2 then
					peer._txtSkillDesc:SetLocalizeS(skillCfg._descSid, lc.toStr(skillCfg._value[1]), lc.toStr(skillCfg._value[2]))
				elseif #skillCfg._value == 3 then
					peer._txtSkillDesc:SetLocalizeS(skillCfg._descSid, lc.toStr(skillCfg._value[1]), lc.toStr(skillCfg._value[2]), lc.toStr(skillCfg._value[3]))
				else
					peer._txtSkillDesc:SetLocalizeS(skillCfg._descSid, lc.toStr(skillCfg._value[1]), lc.toStr(skillCfg._value[2]), lc.toStr(skillCfg._value[3]), lc.toStr(skillCfg._value[4]))
				end
			else
				peer._txtSkillDesc:SetLocalize(skillCfg._descSid)
			end

			M.setBuffLinkClick(peer._txtSkillDesc)

			local rangerCfg = D._rangerConfig[skillCfg._ranger]
			local quality = rangerCfg._quality

			LuaUnity.setTPSprite(peer._imgRangerFrame, string.format("item/frame-frame_%02d_2", quality))
			LuaUnity.setTPSprite(peer._imgRangerFrameOut, string.format("item/frame-frame_%02d_out_2", quality))
			LuaUnity.setTPSprite(peer._imgRangerIcon, D.toSprite(skillCfg._ranger), true)
			peer._txtActivateTip:SetLocalize(SID.TIP_RANGER_ONLY, -rangerCfg._nameSid)
		end
	else
		peer._goSkill2PropContent:SetActive(false)
		peer._goSkill2SkillContent:SetActive(false)
	end
end

function M.loadRangerEquipText(tmp, skillId)
	local skillCfg = D._rangerEquipSkillConfig[skillId]

	if skillCfg._value then
		tmp:SetLocalize(skillCfg._descSid, unpack(skillCfg._value))

		if skillCfg._effect < 100 then
			tmp.text = string.format("%s +%s%%", tmp.text, lc.toStr(skillCfg._value[1]))
		end
	else
		tmp:SetLocalize(skillCfg._descSid)
	end
end

function M.loadMissionTitleText(tmp, msId, msType)
	if msType == D.MissionType.Dome then
		tmp:SetLocalize(P._playerDome:readMissionName(msId))
	elseif msType == D.MissionType.Common then
		local cfg = P._playerMission:getCfgByType(msType)[msId]

		tmp:SetLocalize(cfg._nameSid, msId % 10000)
	elseif msType == D.MissionType.Elite then
		local cfg = P._playerMission:getCfgByType(msType)[msId]

		tmp:SetLocalize(cfg._nameSid, msId % 10000)
	elseif msType == D.MissionType.ArkRebuild then
		local cfg = P._playerMission:getCfgByType(msType)[msId]

		tmp:SetLocalize(cfg._nameSid, msId % 10000)
	elseif msType == D.MissionType.CrisisZone then
		local cfg = P._playerMission:getCfgByType(msType)[msId]

		tmp:SetLocalize(cfg._nameSid, cfg._difficulty)
	else
		tmp:SetLocalize(P._playerMission:readMissionName(msId, msType))
	end
end

function M.loadPerfectText(tmp, msId, msType)
	if P._playerMission:getMissionId() < msId then
		tmp.text = ""
	else
		local battleData = P._playerMission:getBattleData(msId, msType)
		local type = P._playerMission:getMissionPerfectType(msId, msType)
		local hp = Mathf.Clamp(battleData.leftHp, 0, 100)

		if D.PerfectType.NotCleared < type then
			if hp == 100 then
				tmp:SetLocalize(SID.MISSION_COMPLETE_PERFECT)
			else
				tmp:SetLocalize(SID.MISSION_COMPLETE_X, hp)
			end
		elseif battleData.battleTime == 0 then
			tmp.text = ""
		else
			tmp:SetLocalizeS(SID.MISSION_MAX_TIME, V.formatTimeS2MS(battleData.battleTime))
		end
	end
end

function M.loadWeaponIcon(imgIcon, weaponId, ignorePivot)
	LuaUnity.setTPSprite(imgIcon, string.format("weapon/weapon_%d", weaponId), true, ignorePivot)
end

function M.showToast(sid)
	UIManager.showToast(sid)
end

function M.showEnhanceToast(sid, offset)
