	0,
	0
}

function M.BombShake(shaker, force)
	if Client._shakeCameraOn == 0 then
		return
	end

	local shake_params = M.BOMB_SHAKE_PARAM
	local posInfluence = Vector3.new(shake_params[5], shake_params[6], shake_params[7])
	local rotInfluence = Vector3.new(shake_params[8], shake_params[9], shake_params[10])

	shaker:ShakeOnce(shake_params[1] * 5, shake_params[2], shake_params[3], shake_params[4], posInfluence * force, rotInfluence)
end

