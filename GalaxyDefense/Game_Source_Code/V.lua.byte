function M.showItemInfoPanel(cid, num, require)
	if D.isItem(cid) then
		if D._itemConfig[cid]._type == D.ItemType.Skin and not require then
			V.showSkinInfoPanel(cid)
		elseif D._itemConfig[cid]._type == D.ItemType.Ranger and not require then
			UIManager.openPanel(PrefabDefine.RangerInfoPanel, cid)
		else
			UIManager.openPanel(PrefabDefine.ItemInfoPanel, cid, num, require)
		end
	elseif D.isGem(cid) then
		UIManager.openPanel(PrefabDefine.ChipInfoPanel, cid)
	else
		UIManager.openPanel(PrefabDefine.ItemInfoPanel, cid, num, require)
	end
end

function M.showItemNotEnough(cid, num, require)
	if cid == D.ResType.diamond then
		UIManager.openPanel(PrefabDefine.DiamondPanel)
	elseif cid == D.ResType.energy then
		UIManager.openPanel(PrefabDefine.PurchaseStaminaPanel)
	else
		V.showItemInfoPanel(cid, num, require)
	end
end

function M.showSkinInfoPanel(cid, star)
