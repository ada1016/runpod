		60
	}
}
local mapKeyIndex = {}
local mapKeyDimension = {}
local arrayMt = {
	__index = function (table, key)
		key = tonumber(key)

		if key == nil then
			return nil
		end

		local val = rawget(table, -key)

		if val then
			return table[-key] + lc._encryptOffset + 4081
		end
	end
}
local mt = {
	__index = function (table, key)
		if mapKeyIndex[key] == nil then
			return nil
		end

		local v = table[mapKeyIndex[key]]
		local d = mapKeyDimension[key]

		if d == 0 then
			return v + lc._encryptOffset + 4081
		elseif d == 1 and getmetatable(v) == nil then
			setmetatable(v, arrayMt)
		end

		return v
	end,
	__newindex = function (_, index, value)
		log.f("ERROR", "This is a read-only table!")
		assert(false)
	end
}

setmetatable(M, mt)

return M
