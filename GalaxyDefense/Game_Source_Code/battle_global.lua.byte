local lc = lc
local tonumber = tonumber
local rawget = rawget
local setmetatable = setmetatable
local getmetatable = getmetatable
local SID = SID
local M = {
	_ator_slanting_angle = 20,
	_ator_move_speed = 50,
	_drag_speed = 0.01,
	_booster_move_speed_add_per = 50,
	_battery_slowfielddrone_range_fix = 1.2,
	_battery_slowfielddrone_fly_time = 2,
