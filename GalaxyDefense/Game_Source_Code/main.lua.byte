local require = require

local function requireProto()
	require("net.proto.Msg_pb")
	require("net.proto.Auth_pb")
	require("net.proto.User_pb")
	require("net.proto.Region_pb")

	Msg_pb = Protol.Msg_pb
	Auth_pb = Protol.Auth_pb
	User_pb = Protol.User_pb
	Region_pb = Protol.Region_pb
end

local function initRequire(checkLuaFlag)
	if checkLuaFlag or AppConst.Platform == AppConst.osx or AppConst.Platform == AppConst.webgl then
		function table.new()
			return {}
		end

		function table.clear(tbl)
			for k, v in pairs(tbl) do
				tbl[k] = nil
			end
		end
	else
		require("table.new")
		require("table.clear")
	end

	LuaOut = require("tolua.out")
	json = require("cjson")

	require("core.common_lua.functions")
	require("core.common_lua.stringex")
	require("app._automatical.LuaPath")

	if not checkLuaFlag then
		requireLua("hotfix")
	end

	local requireLua = requireLua

	requireLua("PrefabDefine")
	requireLua("StringEnums")
	requireLua("core_init")
	requireLua("Trace")

	lc._encryptOffset = math.random(-9999, 9999)

	requireLua("DropHelper")
	requireLua("Data")
	requireLua("ResultCode")
	requireLua("Client")
	requireLua("V")
	requireLua("NotificationMgr")
	requireLua("RedDotManager")
	requireLua("TaskHelper")
	requireLua("battle_init")
end

local function launchGame()
	LuaUnity.createGameObject("Assets/FW/Prefabs/UI/MainGameRoot.prefab")
	SceneHelper:EnterLoginScene(function ()
		AudioService:Init()
		AudioService:SetMusicMute(Client._musicFlag == 0)
		AudioService:SetSoundMute(Client._soundFlag == 0)
	end)
end

function mainDebug()
	for i = 1, #_G_ALL_PACKAGES_ARRAY do
		package.loaded[_G_ALL_PACKAGES_ARRAY[i]] = nil
	end

	main()
end

function outputConfigValues(name)
	print("<<<<<<<<<<<", name)

	local config = require(string.format("app._config.%s", name))
	local sort_ids = {}

	for k, v in pairs(config) do
		if type(k) == "number" then
			sort_ids[#sort_ids + 1] = k
		end
	end

	table.sort(sort_ids, function (a, b)
		return a < b
	end)

	local keys = config.mapKeyIndexArray
	local str_vals = {}

	for i = 1, #sort_ids do
		local row = config[sort_ids[i]]

		for j = 1, #keys do
			local v = row[keys[j]]

			if type(v) == "table" then
				local c = v.c or #v

				for i = 1, c do
					local vv = v[i]

					if type(vv) == "table" then
						local cc = vv.c or #vv

						for i = 1, cc do
							local vvv = vv[i]
							str_vals[#str_vals + 1] = tostring(vvv) .. "\n"
						end
					else
						str_vals[#str_vals + 1] = tostring(vv) .. "\n"
					end
				end
			else
				str_vals[#str_vals + 1] = tostring(v) .. "\n"
			end
		end
	end

	Application = UnityEngine.Application
	local file, err = io.open(Application.persistentDataPath .. "/output2/" .. name .. ".txt", "w")
	local result, errMsg = file:write(table.concat(str_vals))

	file:close()
	print("文件保存成功")
end

