function main(checkLuaFlag)
	math.randomseed(tostring(os.time()):reverse():sub(1, 6))

	P = nil

	initRequire(checkLuaFlag)

	if checkLuaFlag then
		return
	end

	if lc._isMobile then
		C._useFirebaseAccount = true
	else
		C._useFirebaseAccount = false
	end

	if AppConst.appId == "10003" then
		-- Nothing
	end

	C._appConfig = json.decode(AppConst.csvStr)

	AudioService:Init()
	D.loadConfig()
	C.init()

	if C._config.useRemoteData then
		C._useFirebaseAccount = true
	end

	if C._config.testAi then
		requireLua("BattleAi").create()
	end

	Trace.AF_traceSession("begin", 0)
	launchGame()
end

function OnApplicationPause(pause)
	if not C then
		return
	end

	print("OnApplicationPause", pause, C.getCurTime())

	if pause then
		if lc._isiOS then
			Time.timeScale = 0
		end

		Client.OnApplicationPause()
	else
		if lc._isiOS then
			Time.timeScale = 1
		end

		Client.OnApplicationFocus()
	end
end

function OnApplicationQuit()
	if not C then
		return
	end

	print("OnApplicationQuit", C.getCurTime())
	Client.OnApplicationPause()
end

function OnLoadResCallStart(isZip)
	SimpleEvent.emit("load.res.call.start", isZip)
end

function OnLoadResCallMessage(msg)
	SimpleEvent.emit("load.res.call.message", msg)
end

function OnLoadResCallProgress(progress)
	SimpleEvent.emit("load.res.call.progress", progress)
end

function OnLoadResCallSuccess()
	SimpleEvent.emit("load.res.call.success")
end

function OnLoadResError(msgType, extraMsg)
	SimpleEvent.emit("load.res.on.error", msgType, extraMsg)
end

function OnLoadResFatalError(msgType)
	SimpleEvent.emit("load.res.on.fatal.error", msgType)
end
