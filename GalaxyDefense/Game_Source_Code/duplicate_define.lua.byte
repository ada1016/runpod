local m = {}

function M.dup(key)
	if m[key] then
		return m[key]
	end

	local tKey = key

	if type(key) == "string" then
		tKey = 0

		for i = 1, #key do
			tKey = (tKey * 131 + string.byte(key, i)) % 16777213
		end

		tKey = "k" .. tKey
		m[key] = tKey
	end

	return tKey
end

M.arrayMt = {
	__index = function (table, key)
		local val = rawget(table, -key)
		key = tonumber(key)

		if key == nil then
			return nil
		end

		if val then
			return table[-key] + lc._encryptOffset + -5276
		end
	end
}

return M
