local mapKeyIndex = {
	k1606272 = 8,
	k4148765 = 9,
	k5884890 = 5,
	k803699 = 11,
	k1643899 = 13,
	k16062074 = 10,
	k9063391 = 2,
	k1546740 = 14,
	k4312826 = 6,
	k4709432 = 12,
	k14956208 = 7,
	k1644150 = 1,
	k2137491 = 3,
	k8655535 = 4
}
local mapKeyDimension = {
	k4709432 = 1,
	k803699 = 1
}
local arrayMt = {
	__index = function (table, key)
		local val = rawget(table, -key)
		key = tonumber(key)

		if key == nil then
			return nil
		end

		if val then
			return table[-key] + lc._encryptOffset + -2158
		end
	end
}
local mt = {
	__call = function (table, key)
		return table[mapKeyIndex[key]]
	end,
	__index = function (table, key)
		local tKey = dup.dup(key)

		if mapKeyIndex[tKey] == nil then
			return nil
		end

		if key == "_descSid" then
			if table[4] == nil then
				return nil
			end

			return SID["SID_TASK_DESCSID_" .. table[4]]
		elseif key == "_mainDescSid" then
			if table[5] == nil then
				return nil
			end

			return SID["SID_TASK_MAINDESCSID_" .. table[5]]
		end

		local val = table[mapKeyIndex[tKey]]

		if val == nil then
			return
		end

		local d = mapKeyDimension[tKey]

		if d == 0 then
			return val + lc._encryptOffset + -2158
		elseif d == 1 then
			if val[0] == nil then
				if getmetatable(val) == nil then
					setmetatable(val, arrayMt)
				end

				val[0] = true
			end
		elseif d == 2 and val[0] == nil then
			for i = 1, #val do
				if getmetatable(val[i]) == nil then
					setmetatable(val[i], arrayMt)
				end
			end

			val[0] = true
		end

		return val
	end,
	__newindex = function (_, index, value)
		log.f("ERROR", "This is a read-only table!")
		assert(false)
	end
}

for k, v in pairs(M) do
	setmetatable(v, mt)
end

return M
