local mapKeyIndex = {
	k8705978 = 6,
	k13849634 = 9,
	k6939003 = 10,
	k12760587 = 12,
	k1208471 = 13,
	k14279902 = 11,
	k9063391 = 8,
	k4312826 = 7,
	k15255765 = 4,
	k10594465 = 2,
	k1644150 = 1,
	k12115177 = 3,
	k8655535 = 5
}
local mapKeyDimension = {}
local arrayMt = {
	__index = function (table, key)
		local val = rawget(table, -key)
		key = tonumber(key)

		if key == nil then
			return nil
		end

		if val then
			return table[-key] + lc._encryptOffset + 6194
		end
	end
}
local mt = {
	__call = function (table, key)
		return table[mapKeyIndex[key]]
	end,
	__index = function (table, key)
		local tKey = dup.dup(key)

		if mapKeyIndex[tKey] == nil then
			return nil
		end

		if key == "_nameSid" then
			if table[4] == nil then
				return nil
			end

			return SID["SID_ITEM_NAMESID_" .. table[4]]
		elseif key == "_descSid" then
			if table[5] == nil then
				return nil
			end

			return SID["SID_ITEM_DESCSID_" .. table[5]]
		end

		local val = table[mapKeyIndex[tKey]]

		if val == nil then
			return
		end

		local d = mapKeyDimension[tKey]

		if d == 0 then
			return val + lc._encryptOffset + 6194
		elseif d == 1 then
			if val[0] == nil then
				if getmetatable(val) == nil then
					setmetatable(val, arrayMt)
				end

				val[0] = true
			end
		elseif d == 2 and val[0] == nil then
			for i = 1, #val do
				if getmetatable(val[i]) == nil then
					setmetatable(val[i], arrayMt)
				end
			end

			val[0] = true
		end

		return val
	end,
	__newindex = function (_, index, value)
		log.f("ERROR", "This is a read-only table!")
		assert(false)
	end
}

for k, v in pairs(M) do
	setmetatable(v, mt)
end

return M
