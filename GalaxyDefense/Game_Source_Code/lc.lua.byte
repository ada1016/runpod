function lc.versionStr2Number(verstionStr)
	local versionArgs = string.split(verstionStr, ".")

	return versionArgs[3] + tonumber(versionArgs[2]) * 100 + tonumber(versionArgs[1]) * 10000
end

function lc.versionAGreaterThanB(va, vb)
	return lc.versionStr2Number(vb) < lc.versionStr2Number(va)
end

lc._isRelease = AppConst.Release
lc._isMobile = false
lc._isiOS = false
lc._isAndroid = false
lc._isCN = AppConst.IsCN
lc._preFrame = 60
lc._appVersionStr = Application.version
lc._appVersion = lc.versionStr2Number(Application.version)

if AppConst.Platform == AppConst.webgl then
	lc._isWebGL = true
	lc._useWebGLVFX = true
	lc._isMobile = not Application.isEditor
	local str = Util.GetDeviceInfo()
	lc._deviceInfo = json.decode(str)
	lc._isWebGLAndroid = lc._deviceInfo.platform == "android" or lc._deviceInfo.platform == "ohos" or lc._deviceInfo.platform == "devtools"
	lc._isWebGLiOS = lc._deviceInfo.platform == "ios"
	lc._isWebGLPC = not lc._isWebGLiOS and not lc._isWebGLAndroid
	lc._preFrame = lc._isWebGLPC and 60 or 30
elseif Application.isMobilePlatform then
	lc._isMobile = true

	if AppConst.Platform == AppConst.ios then
		lc._isiOS = true
	else
		lc._isAndroid = true
	end
end

lc._graphicsQuality = LuaHelper.PrefsGetInt("graphic_quality", -1)
lc._dynamicFPS = 60
lc._highFPS = 60
lc._lowFPS = 30
lc._designWidth = 810
lc._designHeight = 1440
lc._designAspectRatio = lc._designWidth / lc._designHeight
lc._originScreenHeight = Screen.height
lc._originScreenWidth = Screen.width
lc._screenHeight = Screen.height
lc._screenWidth = Screen.width
lc._uiScreenRate = lc._originScreenWidth / lc._designWidth
lc._battleScreenRate = 1
lc._screenRate = lc._uiScreenRate
local screenScale = lc._originScreenHeight / lc._originScreenWidth / (lc._designHeight / lc._designWidth)

if screenScale >= 1 then
	lc._canvasScale = lc._originScreenWidth / lc._designWidth
	lc._floatHeight = lc._screenHeight - lc._designHeight * lc._canvasScale
	lc._floatWidth = 0
else
	lc._canvasScale = lc._originScreenHeight / lc._designHeight
	lc._floatHeight = 0
	lc._floatWidth = lc._screenWidth - lc._designWidth * lc._screenRate
end

lc._bestFitScale = lc._canvasScale

function lc.getUI2ScreenScale()
	return lc._canvasScale * lc._screenRate / lc._uiScreenRate
end

local csArray = Screen.resolutions
local array = {}

for i = 0, csArray.Length - 1 do
	array[i + 1] = {
		width = csArray[i].width,
		height = csArray[i].height,
		refreshRate = csArray[i].refreshRate
	}
end

lc.supportResolutions = array

function lc.setResolution(screenRate)
	if not lc._isMobile or lc._isWebGL then
		return
	end

	local dstWidth = lc._designWidth * screenRate
	lc._screenHeight = dstWidth * lc._screenHeight / lc._screenWidth
	lc._screenWidth = dstWidth

	Screen.SetResolution(lc._screenWidth, lc._screenHeight, true)

	lc._screenRate = screenRate
end

if lc._graphicsQuality == -1 then
	if lc._isAndroid then
		local gpuMemorySize = SystemInfo.graphicsMemorySize
		local systemMemorySize = SystemInfo.systemMemorySize
		local screenRate = 1

		if gpuMemorySize < 2000 then
			lc._graphicsQuality = 1
			lc._dynamicFPS = lc._lowFPS
			screenRate = 0.8 * lc._battleScreenRate
		else
			lc._graphicsQuality = 2
		end

		if lc._graphicsQuality < 2 then
			-- Nothing
		end

		Application.targetFrameRate = lc._dynamicFPS
	else
		lc._graphicsQuality = 2
	end
elseif lc._graphicsQuality == 2 then
	lc._dynamicFPS = lc._highFPS
else
	lc._dynamicFPS = lc._lowFPS
end

function lc.setGraphicsQuality(quality)
	lc._graphicsQuality = quality

	lc.setIntKeyValue("graphic_quality", quality)

	if lc._graphicsQuality == 2 then
		lc._dynamicFPS = lc._highFPS
	else
		lc._dynamicFPS = lc._lowFPS
	end

	Application.targetFrameRate = lc._dynamicFPS
end

Application.targetFrameRate = lc._dynamicFPS

function lc.appendFunctions(dest, ori)
	for k, v in pairs(ori) do
		dest[k] = v
	end
end

local tostring = tostring

function lc.tostring(var, depth, prefix)
	prefix = prefix or ""

	if type(var) ~= "table" then
		return prefix .. tostring(var)
	elseif var.__cname == "list" then
		return lc.tostring(var:values())
	else
		local str = ""

		if depth ~= 0 then
			local prefix_next = prefix .. ", "
			local isFirst = true
			str = str .. prefix .. "{"

			for k, v in pairs(var) do
				str = str .. (isFirst and "" or prefix_next) .. k .. " = "
				isFirst = false

				if type(v) ~= "table" or type(depth) == "number" and depth <= 1 then
					if type(v) == "boolean" then
						str = str .. (v and "true" or "false")
					elseif type(v) == "function" then
						str = str .. "Func"
					else
						str = str .. tostring(v)
					end
				elseif depth == nil then
					str = str .. lc.tostring(v, nil, prefix_next)
				else
					str = str .. lc.tostring(v, depth - 1, prefix_next)
				end
			end

			str = str .. prefix .. "}"
		end

		return str
	end
end

function lc.getDeviceInfoString()
	return Util.GetDeviceInfo()
end

function lc.getDeviceId()
	return SystemInfo.deviceUniqueIdentifier
end

function lc.getUdid()
	if lc._isCN then
		local udid = lc.getStringKeyValue("UDID", "")

		if udid == "" then
			udid = tostring(math.floor(math.random() * 4294967295.0))

			lc.setStringKeyValue("UDID", udid)
			lc.saveSetValues()
		end

		return udid
	elseif lc._isMobile then
		return Util.GetUDID()
	end
end

function lc.getChannelName()
	local appId = C._appId

	if appId == "10001" then
		return "DEV"
	elseif appId == "10002" then
		return "DEV"
	elseif appId == "10003" or appId == "10004" then
		return "ALPHA"
	end

	if lc._isMobile then
		if lc._isiOS then
			return "APPSTORE"
		else
			return "GOOGLEPLAY"
		end
	else
		return "DEV"
	end
end

function lc.addLongPress(objInst, delegate, agrs)
	local listener = objInst.gameObject:GetComponent("LongPressEventListener")

	if listener == nil then
		listener = objInst.gameObject:AddComponent(typeof(LongPressEventListener))
	end

	listener:UnlistenAll()
	listener.onLongPress:AddListener(function ()
		if delegate.onLongPress then
			delegate:onLongPress(agrs)
		end
	end)
end

function lc.addListeners(objInst, delegate, agrs)
	local listener = objInst.gameObject:GetComponent("InputEventListener")

	if listener == nil then
		listener = objInst.gameObject:AddComponent(typeof(InputEventListener))
	end

	listener:UnlistenAll()
	listener.onBeginDrag:AddListener(function (eventData)
		if delegate.onTouchBegan then
			delegate:onTouchBegan(eventData, agrs)
		end
	end)
	listener.onDrag:AddListener(function (eventData)
		if delegate.onTouchMoved then
			delegate:onTouchMoved(eventData, agrs)
		end
	end)
	listener.onEndDrag:AddListener(function (eventData)
		if delegate.onTouchEnded then
			delegate:onTouchEnded(eventData, agrs)
		end
	end)
end

function lc.screenPosToUIPos(objInst, position, camera)
	return Util.ScreenPosToUIPos(objInst.transform, position, camera)
end

function lc.convertToScreenPoint(x, y, z)
	return LuaHelper.ConvertToScreenPoint(x, y, z, LuaOutF, LuaOutF, LuaOutF)
end

function lc.worldToUIPoint()
	return LuaHelper.ConvertToUIPoint(x, y, z, LuaOutF, LuaOutF, LuaOutF)
end

function lc.covert2NodePos(obj, dest)
	local wp = obj.transform:TransformPoint(Vector3.static(0, 0, 0))
	local p = dest.transform:InverseTransformPoint(wp)

	return p
end

function lc.setParticleSystemStoppedEvent(obj, callback)
	obj:GetComponent("ParticleSystemStoppedEvent"):SetStoppedAction(callback)
end

function lc.setAnimationCompletedEvent(obj, callback)
	obj:GetComponent("AnimationEventCallback"):AddAnimationEvent(callback)
end

function lc.isFileExist(name)
	local f = io.open(name, "rb")

	if f then
		f:close()
	end

	return f ~= nil
end

function lc.sequence(...)
	local arg = {
		...
	}
	local seq = DOTween.Sequence()

	for i = 1, #arg do
		local tween = arg[i]

		if type(tween) == "function" then
			seq:AppendCallback(tween)
		elseif type(tween) == "number" then
			seq:AppendInterval(tween)
		else
			seq:Append(tween)
		end
	end

	return seq
end

function lc.delayFunc(dt, callback, target, unscaledTime)
	local seq = lc.sequence(dt, callback)

	if unscaledTime then
		seq:SetUpdate(0, true)
	end

	if target then
		seq:SetLink(target)
	end
end

function lc.runStringCode(code)
	if #code == 0 then
		return "[ERROR] Empty code!"
	end

	local ok, ret = pcall(function ()
		local chunk, err = loadstring(code)

		if chunk == nil then
			return string.format("parse patch error: %s", err)
		end

		return chunk()
	end)

	if ok then
		return ret ~= nil and tostring(ret) or "execute ok"
	else
		return ret
	end
end

function lc.setInterval(callback, n, unscaledTime)
	if unscaledTime == nil then
		unscaledTime = false
	end

	return lc.startNewTimer(callback, n, -1, unscaledTime)
end

function lc.setTimer(callback, n, unscaledTime)
	if unscaledTime == nil then
		unscaledTime = false
	end

	return lc.startNewTimer(callback, n, 1, unscaledTime)
end

function lc.startNewTimer(callback, n, loop, unscaledTime)
	local timer = Timer.New(function ()
		callback()
	end, n, loop, unscaledTime)

	timer:Start()

	return timer
end

function lc.stopTimer(timer)
	if timer == nil then
		return
	end

	timer:Stop()
end

function lc.stopTimers(timers)
	if timers == nil then
		return
	end

	for i = 1, #timers do
		lc.stopTimer(timers[i])
	end
end

local function hexStrToNum(hexStr)
	return (tonumber(hexStr, 16) or 255) / 255
end

local KEY_SHARP = "#"

function lc.hexStrToClr(clrStr)
	if clrStr[1] == KEY_SHARP then
		clrStr = string.sub(clrStr, 2)
	end

	local len = string.len(clrStr)

	if len < 6 then
		return 1, 1, 1, 1
	end

	local r = hexStrToNum(string.sub(clrStr, 1, 2))
	local g = hexStrToNum(string.sub(clrStr, 3, 4))
	local b = hexStrToNum(string.sub(clrStr, 5, 6))
	local a = hexStrToNum(string.sub(clrStr, 7, 8))

	return r, g, b, a
end

function lc.numberLerp(from, to, t)
	t = math.min(1, math.max(0, t))

	return from + (to - from) * t
end

function lc.numberClamp(value, min, max)
	return math.min(max, math.max(min, value))
end

function lc.numberClamp01(value)
	return math.min(1, math.max(0, value))
end

