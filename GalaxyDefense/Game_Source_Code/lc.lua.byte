function lc.encodeString(str)
	str = FileUtils.deflateCompressByte(str, 0, string.len(str))
	str = string.encrypt(LuaHelper.ToLuaByteBuffer(str), userKey)
	str = EncryptHelper.RawBase64Encode(str)
	str = EncryptHelper.AESEncrypt(str, securityKeyForContent)

	return str
end

function lc.decodeString(str)
	str = EncryptHelper.AESDecrypt(str, securityKeyForContent)
	str = LuaHelper.ToLuaByteBuffer(EncryptHelper.RawBase64Decode(str))
	str = string.decrypt(str, userKey)
	str = LuaHelper.ToLuaByteBuffer(FileUtils.deflateDeCompressByte(str, 0, string.len(str)))

	return str
end

local __serialize = nil

function __serialize(obj, out)
	local t = type(obj)

	if t == "number" then
		out[#out + 1] = tostring(obj)
	elseif t == "boolean" then
		out[#out + 1] = tostring(obj)
	elseif t == "string" then
		out[#out + 1] = string.format("%q", obj)
	elseif t == "table" then
		if obj.__cname then
			if obj.__type == "number" then
				out[#out + 1] = tostring(obj())
			end
		else
			out[#out + 1] = "{"
			local count = 0

			for k, v in pairs(obj) do
				if count > 0 then
					out[#out + 1] = ","
				end

				count = count + 1
				local tk = type(k)
				local tv = type(v)

				if tk == "number" then
					out[#out + 1] = string.format("[%d]=", k)

					__serialize(v, out)
				elseif tk == "string" then
					out[#out + 1] = string.format("[\"%s\"]=", k)

					__serialize(v, out)
				else
					error("can not serialize a k" .. k .. " type.")
				end
			end

			out[#out + 1] = "}"
		end
	elseif t ~= "nil" then
		error("can not serialize a t" .. t .. " type.")
	end
end

function lc.serialize(obj)
	local out = table.new(4096, 0)
	out[1] = "return "

	__serialize(obj, out)

	return table.concat(out)
end

function lc.assignTable(tbl, k)
	if tbl[k] == nil then
		tbl[k] = {}
	end

	return tbl[k]
end

function lc.confuseTable(tbl, tag)
	for k, v in pairs(tbl) do
		tbl[k] = ConfusedNumber.create(v, tag)
	end
end

function lc.getSeedRandom(seed, maxVal)
	seed = (seed * 1103515245 + 12345) % 65536

	return seed, seed / 65536 * maxVal
end

function lc.unique(a)
	local b = {}

	for k, v in ipairs(a) do
		if #b == 0 then
			b[1] = v
		else
			local index = 0

			for i = 1, #b do
				if v == b[i] then
					break
				end

				index = index + 1
			end

			if index == #b then
				b[#b + 1] = v
			end
		end
	end

	return b
end

local function swap(t, i, j)
	t[j] = t[i]
	t[i] = t[j]
end

local function partition(t, low, high, compare)
	local pivot = t[low]
	local left = low + 1
	local right = high

	while left <= right do
		if compare(t[left], pivot) then
			left = left + 1
		elseif compare(pivot, t[right]) then
			right = right - 1
		else
			swap(t, left, right)

			left = left + 1
			right = right - 1
		end
	end

	swap(t, low, right)

	return right
end

function lc.stableQuickSort(t, low, high, compare)
	if low < high then
		local pivotIndex = partition(t, low, high, compare)

		lc.stableQuickSort(t, low, pivotIndex - 1, compare)
		lc.stableQuickSort(t, pivotIndex + 1, high, compare)
	end
end

function lc.isNameStrValid(nameStr)
	return nameStr:match("^[%w_]+$") ~= nil
end

function lc.isNetworkNotReachable()
	return LuaHelper.IsNetworkNotReachable()
end

local b64chars = "0123456789+/AaBbCcDdEeFfGgHhIiJjKkLlMmNnOoPpQqRrSsTtUuVvWwXxYyZz"
local pow2 = {
	[0] = 1,
	2,
	4,
	8,
	16,
	32,
	64,
	128,
	256
}

function lc.toBase64(data)
	local len = #data
	data = data .. ({
		"",
		"  ",
		" "
	})[len % 3 + 1]

	return data:gsub(".", function (x)
		local r = ""
		local b64 = nil
		local n = x:byte()

		for i = 8, 1, -1 do
			r = r .. (n % pow2[i] - n % pow2[i - 1] > 0 and "1" or "0")
		end

		return r
	end):gsub("%d%d%d%d%d%d", function (x)
		local c = tonumber(x, 2) + 1

		return b64chars:sub(c, c)
	end)
end

function lc.fromBase64(data)
	return data:gsub(".", function (x)
		local r = ""
		local f = b64chars:find(x) - 1

		for i = 6, 1, -1 do
			r = r .. (f % pow2[i] - f % pow2[i - 1] > 0 and "1" or "0")
		end

		return r
	end):gsub("%d%d%d%d%d%d%d%d", function (x)
		return string.char(tonumber(x, 2))
	end)
end

function lc.lenTable(tbl)
	return tbl.c or #tbl
end

function lc.getVal(val)
	if type(val) == "number" then
		return val
	end

	if val.__cname then
		return val()
	end

	return val
end

function lc.toStr(val)
	if math.abs(math.round(val) - val) < 0.01 then
		return tostring(val)
	elseif math.abs(math.round(val * 10) - val * 10) < 0.01 then
		return string.format("%.1f", val)
	else
		return string.format("%.2f", val)
	end
end

function lc.priceBinning(p)
	local x = math.log(p) / math.log(2)
	local n = 2^((x - 3) / 2)
	n = math.ceil(n)
	local n1 = math.floor(p / n)
	local n2 = p - n1 * (n - 1)
	local t = {}

	for i = 1, n - 1 do
		t[#t + 1] = n1
	end

	if n2 > 0 then
		t[#t + 1] = n2
	end

	return t
end

function lc.placeUIAtScreenYPoint(rt, yPoint)
	local canvas = rt:GetComponentInParent(typeof(UnityEngine.Canvas))
	local screenCenter = Vector2.new(UnityEngine.Screen.width * 0.5, UnityEngine.Screen.height * (yPoint or 0.5))
	local parentRT = rt.parent
	local cam = nil
	local localPoint = Vector2.new(0, 0)
	local ok, p1 = UnityEngine.RectTransformUtility.ScreenPointToLocalPointInRectangle(parentRT, screenCenter, cam, localPoint)

	if ok then
		rt.anchoredPosition = p1
	else
		rt.anchoredPosition = Vector2.static(0, 0)
	end
end

function lc.openUrl(url)
	if lc._isWebGL then
		LuaHelper.SetClipboardData(url)
		V.showToast(SID.URL_COPIED)
	else
		LuaHelper.OpenUrl(url)
	end
end
