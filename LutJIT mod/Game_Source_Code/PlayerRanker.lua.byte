local function timestampToUtcDate(timestamp)
	return os.date("!%Y/%m/%d", timestamp)
end

M.RankTypeDoc = {
	[D.RankType.MainMissionRank] = "group_%s",
	[D.RankType.MonopolyRank] = "group_%s@%s",
	[D.RankType.ArkRebuildRank] = "group_%s@%s",
	[D.RankType.ArkRebuildRankOld] = "group_%s@%s",
	[D.RankType.DomeRank] = "group_%s@%s",
	[D.RankType.CrisisZoneRank] = "global@%s",
	[D.RankType.SparkScoutRank] = "group_%s@%s",
	[D.RankType.InviteRank] = "%s%s"
}
