		self._shieldEnemy = nil
		self._affectedEnemys = nil
	end,
	receiveDamage = function (self, damage)
		local flag = false

		if self._stage == 1 then
			if self._hp / self._maxHp <= self._params[1] / 100 then
				self._stage = 2
				flag = true
			end
		elseif self._stage == 2 and self._hp / self._maxHp <= self._params[2] / 100 then
			self._stage = 3
			flag = true
		end

		if flag then
			self._coutdown = self._params[5]

			if self._view then
				self._view._vfxShield2183 = self._sessionView:addVFX("Enemy_2183_shield", self._view._tf)

				self._view._vfxShield2183:SetLocalScale(0)
				self._view._vfxShield2183.transform:DOScale(self._params[3] * self._scale, 0.2)
			end

			self._hpShieldValue2183 = self._maxHp * self._params[4] / 100
			self._invincibleFrom2183Parent = self
		end
	end,
	step = function (self, dt)
		if self._coutdown then
			self._coutdown = self._coutdown - dt

			if self._coutdown <= 0 then
				self._coutdown = nil

