			self._battleView:removeVFX(self._view._vfx)

			self._view._vfx = nil
		end
	end,
	receiveDamage = function (self, damage)
		if self._receiveDamagePool then
			self._receiveDamagePool = self._receiveDamagePool + math.abs(damage)

			if self._receiveDamagePool / self._maxHp >= self._params[1] / 100 then
				self._receiveDamagePool = self._receiveDamagePool - self._maxHp * self._params[1] / 100
				self.__coutdown = self._params[2]
				self.__countNum = self._params[5]
				self._stopAtkPlayer = true
				self._moveMode = 0

				if self._view then
					self._view:skillEvent(true)

					if self._view._vfx == nil then
						self._view._vfx = self._sessionView:addVFX("Enemy_2582_HP", self._view._tf)
					end
				end
			end
		end
	end,
	step = function (self, dt)
		if self.__countNum and self.__countNum > 0 then
			self.__coutdown = self.__coutdown - dt

			if self.__coutdown <= 0 then
				local recoverHP = self._maxHp * self._params[4] / 100
				local enemys = self._battleSession:getAllEnemys()
				local dis_sqrt = self._params[3]^2
				local cnt = #enemys

				for j = 1, cnt do
					local enemy = enemys[j]

					if not enemy._isToBeDestroyed and BattleMathLib.dis_square(self._position, enemy._position) <= dis_sqrt then
						self.__coutdown = self._params[2]

						enemy:receiveRecoverHP(recoverHP)
					end
				end

				self.__countNum = self.__countNum - 1

				if self.__countNum == 0 then
					self._stopAtkPlayer = nil
					self._moveMode = self._oldMoveMode

					if self._view then
						self._view:skillEvent(false)

						if self._view._vfx then
							self._battleView:removeVFX(self._view._vfx)

							self._view._vfx = nil
						end
					end
				end
			end
		end
	end
}
