M[2583] = {
	init = function (self)
		self._stage = 1
		self._resurrectionCount = 0

		if self._cid == 2583 then
			self._battleSession._enemy2583 = self
		elseif self._cid == 2584 then
			self._battleSession._enemy2584 = self
		end
	end,
	destroy = function (self)
		self._stage = nil
		self._resurrectionCount = nil

		if self._cid == 2583 then
			self._battleSession._enemy2583 = nil
		elseif self._cid == 2584 then
			self._battleSession._enemy2584 = nil
		end
	end,
	step = function (self, dt)
		if self._stage == 2 then
			if self._coutdown then
				self._coutdown = self._coutdown - dt

				if self._coutdown <= 0 then
					self._coutdown = 0.6666666666666666
					self._stage = 3

					if self._cid == 2583 then
						self._battleSession._2583Dormancy = nil
					elseif self._cid == 2584 then
						self._battleSession._2584Dormancy = nil
					end

					self._resurrectionCount = self._resurrectionCount + 1
					self._hp = self._maxHp
					self._hp = math.ceil(self._hp * self._params[2] / 100 / self._resurrectionCount)
					self._atkInterval = self._atkRawInterval

					if self._view then
						if self._view._hpWidget then
							self._view._hpWidget:SetActive(true)
						end

						self._view:playSpriteAnimation(4)
						self._view:hpEvent(self._hp)
					end
				end
			end
		elseif self._stage == 3 and self._coutdown then
			self._coutdown = self._coutdown - dt

			if self._coutdown <= 0 then
				self._stage = 1
				self._conceal = false
				self._invincible = false
				self._stopAction = false
			end
		end
	end,
	dieBefore = function (self)
		if self._stage == 1 then
			self._stage = 2
			self._conceal = true
			self._invincible = true
			self._stopAction = true

			self:clearBuffs()

			self._coutdown = self._params[1]

			if self._view then
				if self._view._hpWidget then
					self._view._hpWidget:SetActive(false)
				end

				self._view:playSpriteAnimation(3)
			end
		end
	end
}
