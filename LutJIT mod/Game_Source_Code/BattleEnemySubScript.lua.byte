			self._flyDir.x = targetPosX - self._position.x
			self._flyDir.y = targetPosY - self._position.y

			self._flyDir:SetNormalize()

			self._position.x = self._position.x + self._flyDir.x * self._flySpeed * dt
			self._position.y = self._position.y + self._flyDir.y * self._flySpeed * dt

			if math.abs(self._position.x - targetPosX) < 0.05 and math.abs(self._position.y - targetPosY) < 0.05 then
				self._flyEndOffsetPositionX = self._flyEndOffsetPositionX + self._position.x - targetPosX
				self._flyEndOffsetPositionY = self._flyEndOffsetPositionY + self._position.y - targetPosY
				self._stage = 3
				self._countdown = 1
			end

			if self._view then
				self._view._obj:SetPosition(self._position.x, self._position.y, 0)
			end

			self._scriptBehavior.updateAngle(self)
		elseif self._stage == 3 then
			local dtAngle = math.abs(self._relativeAngle - self._targetRelativeAngle)
			self._relativeAngle = Mathf.MoveTowardsAngle(self._relativeAngle, self._targetRelativeAngle, dtAngle / 0.8 * dt)
			self._angle = self._relativeAngle + 180
			local rad = math.rad(self._relativeAngle)
			local dis = self._lockEnemy._radius + self._radius + self._params[5]
			self._flyEndOffsetPositionX = dis * math.cos(rad)
			self._flyEndOffsetPositionY = dis * math.sin(rad)
			local enemyPos = self._lockEnemy._position
			self._position.x = enemyPos.x + self._flyEndOffsetPositionX
			self._position.y = enemyPos.y + self._flyEndOffsetPositionY

			if self._view then
				self._view._obj:SetLocalRotation(0, 0, self._angle + 90)
				self._view._obj:SetPosition(self._position.x, self._position.y, 0)
			end

			self._countdown = self._countdown - dt

			if self._countdown <= 0 then
				self._stage = 4
				self._countdown = 1.6666666666666667
			end
		elseif self._stage == 4 then
			local enemyPos = self._lockEnemy._position
			self._position.x = enemyPos.x + self._flyEndOffsetPositionX
			self._position.y = enemyPos.y + self._flyEndOffsetPositionY

			if self._view then
				self._view._obj:SetPosition(self._position.x, self._position.y, 0)
			end

			self._countdown = self._countdown - dt

			if self._countdown <= 0 then
				self._stage = 3
				self._countdown = 0.6666666666666666

				self._scriptBehavior.randomTargetAngle(self)

				local recoverHP = self._maxHp * self._params[4] / 100

				self._lockEnemy:receiveRecoverHP(recoverHP)

				if self._view then
					self._view:playSpriteAnimation(2)

					local vfx = self._sessionView:addVFX("Enemy_1305_HP", self._lockEnemy._view._tf, 1)

					vfx:SetLocalScale(1)
				end
			end
		end
	end,
	seekEnemy = function (self)
		self._lockEnemy = nil
		local insertCount = 0

		opt.array_arg32:clear()

		local enemys = self._battleSession:getAllEnemys()
		local cnt = #enemys

		for j = 1, cnt do
			local enemy = enemys[j]

			if not enemy._isToBeDestroyed and self._id ~= enemy._id and not enemy._isCasting1409 then
				local beLockedBy1409 = enemy._beLockedBy1409 or 0

				if (enemy._type == BattleDefine.EnemyType.Normal and beLockedBy1409 < 1 or enemy._type == BattleDefine.EnemyType.Elite and beLockedBy1409 < 2 or enemy._type == BattleDefine.EnemyType.Boss and beLockedBy1409 < 3) and BattleMathLib.dis_square(self._position, enemy._position) <= self._inRangeSqrt then
					opt.array_arg32[#opt.array_arg32 + 1] = enemy
					insertCount = insertCount + 1

					if insertCount == 32 then
						break
					end
				end
			end
		end

		if insertCount > 0 then
			self._stage = 2
			self._stopAction = true

			self._scriptBehavior.lockEnemy(self, self._battleRandomLib:randomOne(opt.array_arg32))

			self._isCasting1409 = true
		else
			self._countdown = self._params[1]
			self._stopAction = false
			self._angle = -90

			if self._view then
				self._view._obj:SetLocalRotation(0, 0, self._angle + 90)
			end
		end
	end,
	lockEnemy = function (self, enemy)
		self._lockEnemy = enemy
		enemy._beLockedBy1409 = (enemy._beLockedBy1409 or 0) + 1

		self._scriptBehavior.randomTargetAngle(self)

		self._roundRadius = math.sqrt(enemy._position.x - self._position.x)^2 + (enemy._position.y - self._position.y)^2
		local endPosX = enemy._position.x + self._flyEndOffsetPositionX
		local endPosY = enemy._position.y + self._flyEndOffsetPositionY
		local distanceSqrt = math.sqrt((self._position.x - endPosX)^2 + (self._position.y - endPosY)^2)
		self._originDistance = distanceSqrt
	end,
	randomTargetAngle = function (self)
		local angle = self._battleRandomLib:randomMN(30, 150)
		local rad = math.rad(angle)
		local dis = self._lockEnemy._radius + self._radius + self._params[5]
		local x = dis * math.cos(rad)
		local y = dis * math.sin(rad)
		self._targetRelativeAngle = angle
		self._flyEndOffsetPositionX = x
		self._flyEndOffsetPositionY = y
	end,
	updateAngle = function (self)
		local enemy = self._lockEnemy
		local endPosX = enemy._position.x + self._flyEndOffsetPositionX
		local endPosY = enemy._position.y + self._flyEndOffsetPositionY
		local distance = math.sqrt((self._position.x - endPosX)^2 + (self._position.y - endPosY)^2)
		self._towardOffsetY = ORIGIN_TOAWRD_OFFSET_Y / self._originDistance * distance
		local enemyPos = self._lockEnemy._position
		local towardPosX = enemyPos.x
		local towardPosY = enemyPos.y - self._towardOffsetY
		local pos = self._position
		self._towardDir.x = towardPosX - pos.x
		self._towardDir.y = towardPosY - pos.y

		self._towardDir:SetNormalize()

		self._angle = math.deg(math.atan2(self._towardDir.y, self._towardDir.x))
		self._relativeAngle = self._angle + 180

		if self._view then
			self._view._obj:SetLocalRotation(0, 0, self._angle + 90)
		end
	end
}
M[1509] = {
	init = function (self)
		self._stage = 1
		self._coutdown = self._battleRandomLib:randomMN(self._params[1], self._params[2])
	end,
	readyAttack = function (self)
		self._stage = nil
	end,
	destroy = function (self)
		self._stage = nil
		self._countdown = nil
		self._skipDestroyEvent = nil
	end,
	step = function (self, dt)
		if self._stage == 1 then
			self._coutdown = self._coutdown - dt

			if self._coutdown <= 0 then
				self._invincible = true
				self._conceal = true
				self._ignoreAllBuff = true
				self._stopAction = true
				self._stage = 2
				self._countdown = 0.75

				if self._view then
					if self._view._hpWidget then
						self._view._hpWidget:SetActive(false)
					end

					self._view:playSpriteAnimation(3)
				end
			end
		elseif self._stage == 2 then
			self._countdown = self._countdown - dt

			if self._countdown <= 0 then
				self._skipDestroyEvent = true
				self._selfDestroy = true

				self:markToBeDestroyed()

				local battleEnemyGenerator = self._battleSession._battleEnemyGenerator

				for i = 1, 2 do
					local enemy = battleEnemyGenerator:createSummonEnemy(self._params[3])
					local x = self._position.x + (i - 1.5) * self._params[4] * self._scale
					local y = self._position.y
					x, y = self._battleSession:limitEnemyPosition(x, y)

					enemy:setPos(x, y)
					enemy:setScale(self._scale)

					enemy._hp = self._hp

					if enemy._view then
						enemy._view:syncHp()
						enemy._view:posEvent()
						enemy._view:scaleEvent()
					end
				end

				self._selfDestroy = nil
				self._skipDestroyEvent = nil
			end
		end
	end
}
M[1310] = {
