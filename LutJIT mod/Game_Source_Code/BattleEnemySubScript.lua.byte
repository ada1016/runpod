M[2484] = {
	init = function (self)
		self._leftStart = nil
		self._loopCount = 4
		self._moveStage = 1

		if self._battleRandomLib:randomTrue() then
			self._leftStart = true
		else
			self._leftStart = false
		end

		self._moveT = 0

		requireLua("EnemyMovement")[9](self, 0)
		self:setPos(self._position.x, self._position.y + 2)
		self:setDirByAngle(-90)

		self._dir[1] = 0
		self._dir[2] = -1
		self._speedFactor = 24
	end,
	step = function (self)
		if self._isToBeDestroyed then
			return
		end

		if self._moveT == nil then
			return
		end

		if self._moveStage == 1 then
			if self._position.y <= BattleDefine.SCREEN_DEGE_Y2 - 1 then
				self._moveStage = 2
				self._moveMode = 9
				self._speedFactor = 1
			end
		elseif self._moveStage == 2 then
			if self._moveT > self._loopCount - 0.1 and self._position.y >= BattleDefine.SCREEN_DEGE_Y2 - 1.2 then
				self._moveStage = 3
			end
		elseif self._moveStage == 3 then
			self._moveMode = 1
			self._speedFactor = 24
			self._dir[1] = 0
			self._dir[2] = 1

			if self._position.y >= BattleDefine.SCREEN_DEGE_Y2 + 1 then
				self:markToBeDestroyed()
			end
		end
	end,
	destroy = function (self)
		self._moveT = nil
		self._leftStart = nil
	end
}

return M
