local function create_enemy_3401(self, enemyMetaId, x, y, angle)
	local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
	local enemy = battleEnemyGenerator:createSummonEnemy(enemyMetaId)
	enemy._moveMode = 11
	enemy._speed = enemy._initialSpeed * 2

	enemy:setPos(x, y)
	enemy:setDirByAngle(angle)
	enemy:setScale(1)

	if enemy._view then
		enemy._view:rotationEvent()
		enemy._view:posEvent()
		enemy._view:scaleEvent()
	end

	return enemy
end

