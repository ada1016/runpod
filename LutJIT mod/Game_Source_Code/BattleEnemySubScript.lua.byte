				return
			end
		end

		if self._hpShieldValue2183 then
			local dis_sq = self._params[3]^2
			local enemys = self._battleSession:getAllEnemys()
			local cnt = #enemys

			for j = 1, cnt do
				local enemy = enemys[j]

				if enemy._id ~= self._id and not enemy._isToBeDestroyed then
					if BattleMathLib.dis_square(self._position, enemy._position) <= dis_sq then
