M[1505] = {
	init = function (self)
		self._stage = 1
		self._swallowCountDown = 0.4
	end,
	destroy = function (self)
		self._stage = nil
		self._swallowEnemyMetaId = nil
		self._waitSwallowEnemy = nil
	end,
	step = function (self, dt)
		if self._stage == 1 then
			if (self._position.y - BattleDefine.DOME_POSY) * self._battleSession._zoomScale <= self._params[1] then
				self._stage = 2
			end
		elseif self._stage == 2 then
			local swallowEnemy = nil
			local enemys = self._battleSession:getAllEnemys()
			local cnt = #enemys

			for j = 1, cnt do
				local enemy = enemys[j]

				if not enemy._isToBeDestroyed and self._id ~= enemy._id and enemy._type == BattleDefine.EnemyType.Normal and (enemy._atkType == 3 or enemy._atkType == 1 or enemy._atkType == 2 and not enemy._readyAtk) and (enemy._cid ~= self._cid or enemy._cid == self._cid and not enemy._swallowEnemyMetaId) and BattleMathLib.circle_circle_intersect(self._position, enemy._position, self._radius / 2, enemy._radius) then
					swallowEnemy = enemy

					break
				end
			end

			if swallowEnemy then
				self._stage = 3
				swallowEnemy._ignorePVPProtal = true
				self._waitSwallowEnemy = swallowEnemy
				self._swallowCountDown = 0.3
				self._speed = self._speed * self._params[2]
				self._swallowEnemyMetaId = self._waitSwallowEnemy._cid

				self._waitSwallowEnemy:markToBeDestroyed()

				self._waitSwallowEnemy = nil

				if self._view then
					self._view:formEvent()
				end
			end
		elseif self._stage == 3 then
			self._swallowCountDown = self._swallowCountDown - dt

			if self._swallowCountDown <= 0 then
				self._speed = self._initialSpeed
				self._stage = 4
			end
		end
	end,
	markToBeDestroyed = function (self)
		if self._swallowEnemyMetaId then
			local enemyMetaId = self._swallowEnemyMetaId
			self._swallowEnemyMetaId = nil
			local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
			local enemy = battleEnemyGenerator:createSummonEnemy(enemyMetaId)
			local y = self._battleSession:limitEnemyPositionY(self._position.y + 0.5)

			enemy:setPos(self._position.x, y)

			if enemy._view then
				enemy._view:posEvent()
			end
		end
	end
}
M[1206] = {
	takeDamageToPlayer = function (self, bullet)
		if self._cid == 1206 then
			if self._battleSession._120601Num == nil then
				self._battleSession._120601Num = 0
			end

			if self._params[2] < self._battleSession._120601Num then
				return
			end
		elseif self._cid == 2206 then
			if self._battleSession._220601Num == nil then
				self._battleSession._220601Num = 0
			end

			if self._params[2] < self._battleSession._220601Num then
				return
			end
		end

		local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
		local enemy = battleEnemyGenerator:createSummonEnemy(self._params[1])
		local x = bullet._position.x
		local y = bullet._position.y + enemy._radius

		enemy:setPos(x, self._battleSession:limitEnemyPositionY(y))

		if enemy._view then
			enemy._view:posEvent()
		end

		if enemy._cid == 120601 then
			self._battleSession._120601Num = (self._battleSession._120601Num or 0) + 1
		elseif enemy._cid == 220601 then
			self._battleSession._220601Num = (self._battleSession._220601Num or 0) + 1
		end
	end
}
