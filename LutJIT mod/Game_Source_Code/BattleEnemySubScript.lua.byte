local shake_params = {
	0.3,
	2,
	0,
	0.5,
	0,
	0.1,
	0,
	0,
	0,
	0
}
M[21] = {
	init = function (self)
		self._scale = 5
		self._stopSpawn = false
		self._spawnChildId1 = self._params[1]
		self._spawnChildId2 = self._params[2]
		self._beginSpawnChildNum = self._params[3]
		self._onHitSpawnPercent = self._params[4]
		self._onHitSpawnNum = self._params[5]
		self._hpPercent = 100 / self._onHitSpawnPercent
	end,
	step = function (self, dt)
		local sessionView = self._sessionView

		if not self._stopSpawn then
			if sessionView then
				if Client._shakeCameraOn == 1 then
					sessionView._cameraShaker.enabled = true
					local posInfluence = opt.vec3_1:SetXYZ(shake_params[5], shake_params[6], shake_params[7])
					local rotInfluence = opt.vec3_2:SetXYZ(shake_params[8], shake_params[9], shake_params[10])

					if lc._isMobile then
						self._shakeIns = sessionView._cameraShaker:StartShake(shake_params[1] * 2, shake_params[2], shake_params[3], posInfluence, rotInfluence, true)
					else
						self._shakeIns = sessionView._cameraShaker:StartShake(shake_params[1], shake_params[2], shake_params[3], posInfluence, rotInfluence, true)
					end
				end

				self._initialSize = self._battleSession._initialOrthographicSize
				self._nearestScale = 0.9
				self._y0 = self._position.y
				self._y1 = 10
			end

			self._stopSpawn = true

			for i = 1, self._beginSpawnChildNum do
				local rand = self._battleRandomLib:random() * 2 * math.pi
				local x, y = BattleMathLib.random_inside_circle(self._radius)
				local x = self._position.x + x
				local y = self._position.y + y
				local randomTargetX = self._battleRandomLib:randomMN(-3 * self._battleSession._zoomScale, 3 * self._battleSession._zoomScale)
				local targetPosY = self._battleSession._battleActor._position.y
				local angle = math.deg(math.atan2(targetPosY - y, randomTargetX - x))
				local enemyMetaId = self._battleRandomLib:randomTrue() and self._spawnChildId1 or self._spawnChildId2
				local enemy = self._battleSession._battleEnemyGenerator:createSummonEnemy(enemyMetaId)

				enemy:setPos(x, y)
				enemy:setDirByAngle(angle)

				if enemy._view then
					enemy._view:posEvent()
					enemy._view:rotationEvent()
				end
			end
		end

		if self._sessionView then
			local percent = (self._position.y - self._y0) / (self._y1 - self._y0)
			percent = math.max(0, math.min(1 + (self._nearestScale - 1) * percent, 1))

			self._sessionView:zoomFieldExtra(percent)
		end
	end,
	onHit = function (self)
		local hpPercent = math.ceil(self._hp * 100 / self._maxHp / self._onHitSpawnPercent)

		for i = hpPercent + 1, self._hpPercent do
			for j = 1, self._onHitSpawnNum do
				local x, y = BattleMathLib.random_along_circle(self._radius)
				local x = self._position.x + x
				local y = self._position.y + y
				local randomTargetX = self._battleRandomLib:randomMN(-3 * self._battleSession._zoomScale, 3 * self._battleSession._zoomScale)
				local targetPosY = self._battleSession._battleActor._position.y
				local angle = math.deg(math.atan2(targetPosY - y, randomTargetX - x))
				local enemyMetaId = self._battleRandomLib:randomTrue() and self._spawnChildId1 or self._spawnChildId2
				local enemy = self._battleSession._battleEnemyGenerator:createSummonEnemy(enemyMetaId)

				enemy:setPos(x, y)
				enemy:setDirByAngle(angle)

				if enemy._view then
					enemy._view:posEvent()
					enemy._view:rotationEvent()
				end
			end
		end

		if self._hpPercent ~= hpPercent then
			if self._sessionView then
				local posInfluence = Vector3.new(shake_params[5], shake_params[6], shake_params[7])
				local rotInfluence = Vector3.new(shake_params[8], shake_params[9], shake_params[10])

				self._sessionView._cameraShaker:ShakeOnce(shake_params[1] * 10, shake_params[2], shake_params[3], shake_params[4], posInfluence, rotInfluence)
			end

			self._hpPercent = hpPercent
		end
	end,
	markToBeDestroyed = function (self)
		if self._sessionView then
			if self._shakeIns then
				self._shakeIns:StartFadeOut(1)

				self._shakeIns = nil
			end

			self._sessionView._extraZoom = 1

			self._sessionView:zoomField(-1)
		end
	end
}
local spawnChilds22 = {
	1501,
	1502
}
M[22] = {
	init = function (self)
		self._spawn = false
		self._spawnChildNum1 = self._params[1]
		self._spawnChildNum2 = self._params[2]
		self._spawnChildIds = spawnChilds22
		self._children = table.new(32, 0)
		self._childrenHp = table.new(32, 0)
		self._childrenExp = table.new(32, 0)
		self._swallowNum = 0
	end,
	step = function (self, dt)
		if not self._spawn then
			self._spawn = true
			local curPos = self._position
			local dir = {
				self._dir[1],
				self._dir[2]
			}
			local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
			local cnt = self._battleRandomLib:randomMN(self._spawnChildNum1, self._spawnChildNum2)
			local x = self._position.x
			local y = self._position.y

			for i = 1, cnt do
				x = x + dir[1] * 1
				y = y + dir[2] * 1

				if self._battleSession._screenEdgeX2 <= x + self._radius then
					dir[1] = -math.abs(self._dir[1])
					i = i - 1
				elseif x - self._radius <= self._battleSession._screenEdgeX1 then
					dir[1] = math.abs(self._dir[1])
					i = i - 1
				elseif self._battleSession._enemyBornEdgeX1 <= x and x <= self._battleSession._enemyBornEdgeX2 then
					local id = self._spawnChildIds[self._battleRandomLib:randomN(#self._spawnChildIds)]
					local enemy = battleEnemyGenerator:createSummonEnemy(id)

					enemy:setPos(x + self._battleRandomLib:random(), y + self._battleRandomLib:random())

					if enemy._view then
						enemy._view:posEvent()
					end
				end
			end

			self._initScale = self._scale
		end

		if self._swallowNum < self._params[3] then
			local enemys = self._battleSession:getAllEnemys()
			local cnt = #enemys
			local children = self._children
			local childrenHp = self._childrenHp
			local childrenExp = self._childrenExp

			for j = 1, cnt do
				local enemy = enemys[j]

				if not enemy._isToBeDestroyed and self._id ~= enemy._id and enemy._type == BattleDefine.EnemyType.Normal and BattleMathLib.circle_circle_intersect(self._position, enemy._position, self._radius, enemy._radius) and self._swallowNum < self._params[3] then
					self._swallowNum = self._swallowNum + 1

					enemy:markToBeDestroyed()

					children[#children + 1] = enemy._cid
					local scale = (1 + self._swallowNum / 100) * self._initScale

					self:setScale(scale)

					if self._view then
						self._view:scaleEvent()
						Client.playBattleSound("se_Enemy_22_eat")
					end
				end
			end
		end
	end,
	markToBeDestroyed = function (self)
		local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
		local cnt = #self._children

		for i = 1, cnt do
			local x, y = BattleMathLib.random_inside_circle(self._radius)
			x = x + self._position.x
			y = y + self._position.y
			x, y = self._battleSession:limitEnemyPosition(x, y)
			local enemy = battleEnemyGenerator:createSummonEnemy(self._children[i])

			enemy:setPos(x, y)

			if enemy._view then
				enemy._view:posEvent()
			end
		end
	end
}
