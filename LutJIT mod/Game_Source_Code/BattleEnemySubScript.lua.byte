M[2] = {
	init = function (self)
		self.__coutdown = 5
	end,
	step = function (self, dt)
		if self._readyAtk then
			return
		end

		self.__coutdown = self.__coutdown - dt

		if self.__coutdown <= 0 then
			self.__coutdown = 5
			local b = self._battleRandomLib:randomMN(1, 2) == 1

			if b then
				self:addBuff(self._params[1], self._params[2])
			end
		end
	end,
	addBuff = function (self)
		if self._view then
			self._view:skillEvent(true)
		end
	end,
	removeBuff = function (self)
		if self._view then
			self._view:skillEvent(false)
		end
	end,
	destroy = function (self)
		self.__coutdown = nil
	end
}
M[3] = {
	markToBeDestroyed = function (self)
		local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
		local cnt = self._params[1]
		local enemyMetaId = self._params[2]
		local posx = self._position.x
		local posy = self._position.y

		if self._view then
			local obj = self._sessionView:createAndPlayVFX("Enemy_1202_split", 0.3)

			if obj then
				obj:SetPosition(posx, posy, 0)
			end
		end

		for i = 1, cnt do
			local x, y = BattleMathLib.random_inside_circle(1)
			x = x + posx
			y = y + posy
			x, y = self._battleSession:limitEnemyPosition(x, y)
			local enemy = battleEnemyGenerator:createSummonEnemy(enemyMetaId)

			enemy:setPos(x, y)

			if enemy._view then
				enemy._view:posEvent()
			end
		end
	end
}
M[5] = {
	init = function (self)
		self.__stage = 1
		self.__coutdown = self._battleRandomLib:randomMN(self._params[1], self._params[2])
		self._affectedEnemys = nil
		self._haloVFXName = "Enemy_1502_speedup"
		self._halpStepCDMax = self._battleRandomLib:randomMN(40, 60) / 100
		self._haloStepCD = self._halpStepCDMax
	end,
	destroy = function (self)
		self._haloStepCD = nil
		self.__stage = 1
		self.__coutdown = nil
		self._affectedEnemys = nil
		self._haloVFXName = nil
	end,
	step = function (self, dt)
		if self._attacked then
			return
		end

		self.__coutdown = self.__coutdown - dt

		if self.__coutdown <= 0 then
			if self.__stage == 1 then
				self.__stage = 2
				self.__coutdown = self._params[3]
				self._haloEffecting = true
				self._forceSpeedEx = 0
				self._haloStepCD = self._halpStepCDMax

				if self._view then
					self._view:haloEvent(true)
				end
			elseif self.__stage == 2 then
				self.__stage = 1

				self:recalculateSpeed()

				self.__coutdown = self._battleRandomLib:randomMN(self._params[1], self._params[2])

				self:cancelHalo()
			end
		end

		if self._haloEffecting then
			self._haloStepCD = self._haloStepCD - dt

			if self._haloStepCD <= 0 then
				self._haloStepCD = self._halpStepCDMax

				self:stepHalo(dt)
			end
		end
	end,
	markToBeDestroyed = function (self)
		self:cancelHalo()
	end
}
M[7] = {
