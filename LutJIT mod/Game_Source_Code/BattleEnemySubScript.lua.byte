M[1205] = {
	toDestroy = function (self)
		local recoverHP = self._maxHp * self._params[2] / 100
		local allEnemys = self._battleSession:getEnemysInRange(self._position, self._params[1])

		for i = 1, #allEnemys do
			local enemy = allEnemys[i]

			if not enemy._isToBeDestroyed then
				enemy:receiveRecoverHP(recoverHP)
			end
		end
	end
}
M[1105] = {
	init = function (self)
		self._stage = 1
	end,
	receiveDamage = function (self, damage)
		if self._stage ~= 1 then
			return
		end

		if self._hp / self._maxHp <= self._params[1] / 100 then
			self._stage = 2
			self._conceal = true
			self._invincible = true
			self._coutdown = self._params[2] + 1
			self._atkInterval = 999

			if self._view then
				self._view._spAnimation.nextBehavior = 1

				self._view._spAnimation:SetBehavior(3)

				local vfxFade = self._sessionView:addVFX("Enemy_1105_disappear_start", self._view._tf)

				if self._cid == 2105 then
					vfxFade:SetLocalScale(self._scale * 2)
				else
					vfxFade:SetLocalScale(self._scale)
				end

				self._battleView:delayRemoveVFX(vfxFade, 1)
				self._view._flasher:DOFade(0, 0.8)
			end

			if self._enemyBullet then
				self._enemyBullet:markToBeDestroyed()

				self._enemyBullet = nil
			end
		end
	end,
	step = function (self, dt)
		if self._stage == 2 and self._coutdown then
			self._coutdown = self._coutdown - dt

			if self._coutdown <= 0 then
				self._stage = 3
				self._conceal = nil
				self._invincible = nil
				self._atkInterval = self._atkRawInterval

				if self._view then
					self._view._flasher:DOFade(1, 0.8)

					local vfxFade = self._sessionView:addVFX("Enemy_1105_disappear_end", self._view._tf)

					if self._cid == 2105 then
						vfxFade:SetLocalScale(self._scale * 2)
					else
						vfxFade:SetLocalScale(self._scale)
					end

					self._battleView:delayRemoveVFX(vfxFade, 1)
				end
			end
		end
	end,
	destroy = function (self)
		self._coutdown = nil
		self._invincible = nil
		self._conceal = nil
		self._stage = nil
	end,
	attackPlayer = function (self)
		self._conceal = nil
		self._invincible = nil

		if self._view then
			self._view._flasher:KillFade()
			self._view._flasher:DOFade(1, 0.15)
		end
	end
}
M[2482] = {
	init = function (self)
		self._stage = 1
		self._stageDitry = false
		self._enemy = nil
		self._chargeing = false
	end,
	init_end = function (self)
		if self._view then
			self._view._obj:GetChild(1):SetActive(false)
		end
	end,
	receiveDamage = function (self, damage)
		if self._stage == 1 and self._hp / self._maxHp <= 0.5 then
			self._stage = 2
			self._atkRawInterval = self._atkRawInterval / 2

			if self._view then
				self._stageDitry = true
			end
		end
	end,
	markToBeDestroyed = function (self)
		if self._chargeing and self._enemy then
			self._enemy:markToBeDestroyed()

			self._enemy = nil
		end
	end,
	destroy = function (self)
		self._stage = nil
		self._enemy = nil
	end,
	readyAttack = function (self)
		if self._chargeing then
			return
		end

		self._chargeing = true
		local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
		local enemy = battleEnemyGenerator:createSummonEnemy(tonumber(self._bulletPrefab))

		enemy:setPos(self._position.x, self._position.y - 0.35)

		enemy._stopAction = true
		self._enemy = enemy
		enemy._invincible = true
		enemy._parentEnemy = self

		if enemy._view then
			enemy._view:posEvent()
			enemy._view._obj:SetLocalScale(0)
			enemy._view._tf:DOScale(1, self._atkInterval):SetLink(enemy._view._obj)

			if enemy._view._hpWidget then
				enemy._view._hpWidget:SetActive(false)
			end
		end

		if self._view then
			self._view._obj:GetChild(1):SetActive(true)
		end
	end,
	attackPlayer = function (self)
		if self._view then
			self._view._obj:GetChild(1):SetActive(false)
		end

		self._chargeing = false
		self._enemy._invincible = false
		self._enemy._stopAction = false
		self._enemy._parentEnemy = nil

		if self._stageDitry then
			self._stageDitry = false

			if self._view then
				self._view._ator.speed = 2
			end
		end
	end
}
M[248201] = {
	init = function (self)
		self.__coutdown = 2
		self._stage = 1
	end,
	destroy = function (self)
		self.__coutdown = nil
		self._parentEnemy = nil
	end,
	step = function (self, dt)
		if self._parentEnemy then
			self:setPos(self._parentEnemy._position.x, self._parentEnemy._position.y - 0.35)

			if self._view then
				self._view:posEvent()
			end
		end

		if self._stopAction then
			return
		end

		if self.__coutdown then
			self.__coutdown = self.__coutdown - dt

			if self.__coutdown <= 0 then
				self.__coutdown = nil

				if self._view then
					self._view._ator:SetTrigger("play")
				end
			end
		end
	end
}
local children_3301 = {
	1301,
	1302,
	1303
}

local function create_enemy_3301(self)
	local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
	local childId = children_3301[self._battleRandomLib:randomMN(1, 3)]
	local enemy = battleEnemyGenerator:createSummonEnemy(childId)
	enemy._moveMode = -1
	enemy._ignoreRegulateBuf = true
	local angle = self._battleRandomLib:randomMN(0, 360)
	local r = self._battleRandomLib:randomMN(15, 40) / 10
	local x, y = BattleMathLib.point_in_circle_by_angle(r, angle)
	enemy._offsetXWithRoot = x
	enemy._offsetYWithRoot = y
	x = self._position.x + x
	y = self._position.y + y

	enemy:setDirByAngle(self._angle)
	enemy:setPos(x, y)

	if enemy._view then
		enemy._view:posEvent()
		enemy._view:rotationEvent()
	end

	return enemy
end

local function create_enemy_3301_stage2(self)
	local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
	local childId = children_3301[self._battleRandomLib:randomMN(1, 3)]
	local enemy = battleEnemyGenerator:createSummonEnemy(childId)
	enemy._moveMode = 8
	local x = self._battleRandomLib:randomMN(-20, 60) / 10
	local y = self._battleRandomLib:randomMN(10, 40) / 10
	x = self._position.x + x
	y = self._position.y + y

	enemy:setDirByAngle(self._angle)
	enemy:setPos(x, y)

	if enemy._view then
		enemy._view:posEvent()
		enemy._view:rotationEvent()
	end

	return enemy
end

