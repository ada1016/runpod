M[1101] = {
	markToBeDestroyed = function (self)
		local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
		local enemyMetaId = self._params[1]
		local cnt = self._battleRandomLib:randomMN(self._params[2], self._params[3])
		local posx = self._position.x
		local posy = self._position.y

		if self._cid == 2103 then
			self._childrenCount = cnt
		end

		for i = 1, cnt do
			local enemy = battleEnemyGenerator:createSummonEnemy(enemyMetaId)

			enemy:setPos(posx, posy)

			if enemy._view then
				enemy._view:posEvent()
			end

			enemy._scriptBehavior.initPath(enemy)
		end
	end
}
M[4101] = {
	init = function (self)
		self._pBegan = Vector2.retain(0, 0)
		self._pCtrl = Vector2.retain(0, 0)
		self._pEnd = Vector2.retain(0, 0)
		self._runPathTime = 0
	end,
	destroy = function (self)
		Vector2.release(self._pBegan)

		self._pBegan = nil

		Vector2.release(self._pCtrl)

		self._pCtrl = nil

		Vector2.release(self._pEnd)

		self._pEnd = nil
		self._runPathTime = nil
	end,
	initPath = function (self)
		self._runPathTime = 0
		self._pBegan.x = self._position.x
		self._pBegan.y = self._position.y
		local offsetX = self._battleRandomLib:randomMN(10, 20) / 10

		if self._battleRandomLib:randomTrue() then
			self._pCtrl.x = self._pBegan.x - offsetX

			if self._view then
				self._view._ator:SetTrigger("left")
			end
		else
			self._pCtrl.x = self._pBegan.x + offsetX

			if self._view then
				self._view._ator:SetTrigger("right")
			end
		end

		local offsetY = self._battleRandomLib:randomMN(10, 20) / 10

		if self._battleRandomLib:randomTrue() then
			self._pCtrl.y = self._pBegan.y - offsetX
		else
			self._pCtrl.y = self._pBegan.y + offsetX
		end

		self._pEnd.x = self._pCtrl.x
		self._pEnd.y = 0
	end
}
M[2201] = {
	init = function (self)
		self._receiveDamagePool = 0
	end,
	step = function (self, dt)
		if self._skillDuration then
			self._skillDuration = self._skillDuration - dt

			if self._skillDuration <= 0 then
				self._forceSpeedEx = nil
			end
		end
	end,
	receiveDamage = function (self, damage)
		if self._receiveDamagePool then
			self._receiveDamagePool = self._receiveDamagePool + math.abs(damage)

			if self._receiveDamagePool / self._maxHp >= self._params[1] / 100 then
				self._receiveDamagePool = 0
				local enemys = self._battleSession:getAllEnemys()
				local cnt = #enemys

				for j = 1, cnt do
					local enemy = enemys[j]

					if not enemy._isToBeDestroyed and self._id ~= enemy._id and BattleMathLib.dis_square(self._position, enemy._position) <= self._params[2]^2 then
						enemy:addBuff(self._params[3], self._params[4])
					end
				end

				self:addBuff(self._params[3], self._params[4])

				self._forceSpeedEx = 0
				self._skillDuration = 1

				if self._view then
					self._view._ator:SetTrigger("skill")

					local obj = self._sessionView:createAndPlayVFX("Enemy_2201_powder", self._params[4])

					if obj then
						obj:SetLocalScale(self._params[2] * 2)
						obj:SetPosition(self._position.x, self._position.y, 0)
					end
				end
			end
		end
	end,
	destroy = function (self)
		self._skillDuration = nil
		self._receiveDamagePool = nil
	end
}
