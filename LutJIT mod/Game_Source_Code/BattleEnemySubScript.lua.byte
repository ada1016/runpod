M[16] = {
	markToBeDestroyed = function (self)
		local battleEnemyGenerator = self._battleSession._battleEnemyGenerator
		local enemyMetaId1 = self._params[1]
		local enemyMetaId2 = self._params[2]
		local posx = self._position.x
		local posy = self._position.y
		local w = self._params[3]
