		local x = posx - 0.5 * w + 1 * w
		local y = posy
		x, y = self._battleSession:limitEnemyPosition(x, y)

		enemy:setPos(x, y)

		if enemy._view then
			enemy._view:posEvent()
		end

		if self._view then
			local obj = self._sessionView:createAndPlayVFX("Enemy_2182_split", 0.3)

			if obj then
				obj:SetPosition(posx, posy, 0)
			end
		end
	end
