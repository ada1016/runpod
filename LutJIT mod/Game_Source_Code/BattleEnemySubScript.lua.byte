M[9] = {
	init = function (self)
		self._receiveDamagePool = 0
	end,
	receiveDamage = function (self, damage)
		if self._receiveDamagePool then
			self._receiveDamagePool = self._receiveDamagePool + math.abs(damage)

			if self._receiveDamagePool / self._maxHp >= self._params[1] / 100 then
				self._receiveDamagePool = 0

				self:addBuff(self._params[2], self._params[3])
			end
		end
	end,
	destroy = function (self)
		self._receiveDamagePool = nil
	end
}
M[10] = {
	markToBeDestroyed = function (self)
		local enemys = self._battleSession:getAllEnemys()
		local cnt = #enemys

		for j = 1, cnt do
			local enemy = enemys[j]

			if not enemy._isToBeDestroyed and self._id ~= enemy._id and BattleMathLib.dis_square(self._position, enemy._position) <= self._params[1]^2 then
				enemy:addBuff(self._params[2], 36000)
			end
		end

		if self._view then
			local obj = self._sessionView:createAndPlayVFX("Enemy_1504_wave", 0.7)

			if obj then
				obj:SetLocalScale(self._params[1])
				obj:SetPosition(self._position.x, self._position.y, 0)
			end
		end
	end
}
