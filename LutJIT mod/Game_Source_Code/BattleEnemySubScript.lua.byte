			if self._view then
				self._view._umbrellaRoot:SetActive(false)
				self._view._flame:SetActive(true)

				local obj = self._sessionView:createAndPlayVFX("Enemy_1404_fire", 0.5)

				if obj then
					obj:SetPosition(self._position.x, self._position.y, 0)
					obj:SetLocalScale(self._scale)
				end
			end
		end
	end
}
M[14] = {
	init = function (self)
		self._originScale = nil
	end,
	receiveDamage = function (self, damage)
		if self._originScale == nil then
			self._originScale = self._scale
		end

		local scale = (1 + 1 - self._hp / self._maxHp) * self._originScale

		self:setScale(scale)

		if self._view then
			self._view:scaleEvent()
		end
	end,
	destroy = function (self)
		self._originScale = nil
	end
}
