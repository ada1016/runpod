M[17] = {
	init = function (self)
		self._readyCastSkill = false
		self._nextCastSkillCD = self._params[4]
	end,
	destroy = function (self)
		self._readyCastSkill = nil
	end,
	readyAttack = function (self)
		if self._readyAtk and self._readyCastSkill then
			self._readyCastSkill = false
			self._readyAtk = false
			self._castSkillTime = 0.5
			self._nextCastSkillCD = self._params[4]

			if self._view then
				self._view._ator:SetTrigger("skill")

				self._battleSession._skillFinalDmgPerEffectCD = self._params[3]
				self._battleSession._skillFinalDmgPer = self._params[5]
			end
		end
	end,
	step = function (self, dt)
		if self._nextCastSkillCD then
			self._nextCastSkillCD = self._nextCastSkillCD - dt

			if self._nextCastSkillCD <= 0 then
				self._readyCastSkill = true
			end
		end

		if self._castSkillTime then
			self._castSkillTime = self._castSkillTime - dt

			if self._castSkillTime <= 0 then
				self._castSkillTime = nil
				self._jumpDuration = 0.5
				self._knockbackStatus = true
				self._knockbackSpeed = self._params[2] / self._params[1]
				self._knockbackDir[1] = 0
				self._knockbackDir[2] = 1

				if self._view then
					local vfx = self._sessionView:createAndPlayVFX("Enemy_2381_ink", self._params[3] + 0.5)

					if vfx then
						vfx:SetPosition(0, 3.8, 0)
						vfx:SetLocalScale(self._scale)
					end

					Client.playBattleSound("Enemy_2381_ink")
				end
			end
		end

		if self._jumpDuration then
			self._jumpDuration = self._jumpDuration - dt

			if self._jumpDuration <= 0 then
				self._jumpDuration = nil

				if self._view then
					self._knockbackStatus = nil

					self._view._ator:SetTrigger("move")
				end
			end
		end
	end
}
M[18] = {
	init = function (self)
		self._readySkillCD = self._params[2]
		self._readySkill = true
	end,
	step = function (self, dt)
		if self._readySkill == false then
			self._readySkillCD = self._readySkillCD - dt

			if self._readySkillCD <= 0 then
				self._readySkill = true
			end
		end

		if self._portalOutCD then
			self._portalOutCD = self._portalOutCD - dt

			if self._portalOutCD <= 0 then
				self._portalOutCD = nil
				local posx = self._position.x
				local tx = 0

				if posx > 0 then
					local x1 = (self._battleSession._battleFieldEdgeX1 + self._radius) * 10
					tx = self._battleRandomLib:randomMN(x1, 0) / 10
				elseif posx < 0 then
					local x2 = (self._battleSession._battleFieldEdgeX2 - self._radius) * 10
					tx = self._battleRandomLib:randomMN(0, x2) / 10
				else
					local x1 = (self._battleSession._battleFieldEdgeX1 + self._radius) * 10
					local x2 = (self._battleSession._battleFieldEdgeX2 - self._radius) * 10
					tx = self._battleRandomLib:randomMN(x1, x2) / 10
				end

				self._portalInCD = 0.4
				self._position.x = tx

				if self._view then
					self._view._obj:SetActive(false)

					local obj = self._sessionView:createAndPlayVFX("Enemy_2481_move", 0.8)

					if obj then
						obj:SetPosition(tx, self._position.y, 0)
					end
				end
			end
		end

		if self._portalInCD then
			self._portalInCD = self._portalInCD - dt

			if self._portalInCD <= 0 then
				self._portalInCD = nil

				if self._view then
					self._view._obj:SetActive(true)

					self._invincible = false

					for i = 1, self._params[1] do
						self:addBuff(self._params[3], 36000)
					end
				end
			end
		end
	end,
	onHit = function (self)
		if not self._readySkill then
			return
		end

		self._readySkill = false
		self._readySkillCD = self._params[2]
		self._portalOutCD = 0.4
		self._invincible = true

		if self._view then
			local obj = self._sessionView:createAndPlayVFX("Enemy_2481_move", 0.8)

			if obj then
				obj:SetPosition(self._position.x, self._position.y, 0)
			end
		end
	end,
	destroy = function (self)
		self._portalInCD = nil
		self._portalOutCD = nil
		self._readySkillCD = nil
	end
