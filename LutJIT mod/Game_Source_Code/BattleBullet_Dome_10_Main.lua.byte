local M = class("BattleBullet_Dome_10_Main", requireLua("BattleBullet_AtkInterval"))
local SUPER = M.super
local math = math
local Mathf = Mathf
local OFFSET_Y = 2.076
local TOTAL_TIME = 5
local TWO_PI = 2 * math.pi

local function get_boomerang_pos_timed_cw(current_time, total_duration, p, a, b, c)
	local normalized_time = current_time % total_duration
	local t = normalized_time / total_duration * TWO_PI
	local p_rad = math.rad(p)
	local cos_p = math.cos(p_rad)
	local sin_p = math.sin(p_rad)
	local semi_a = a / 2
	local u = semi_a - semi_a * math.cos(t)
	local v = b / 2 * math.sin(t)
	v = v * c
	local x = u * cos_p - v * sin_p
	local y = u * sin_p + v * cos_p

	return x, y
end

