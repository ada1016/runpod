end

function M:readWinAddScore(num)
	local cfg = self:readCurrentCfg()._winAddScore

	if num <= lc.lenTable(cfg) then
		return cfg[num]
	end

	return cfg[lc.lenTable(cfg)]
end

function M:readKillAddScore(num)
	local cfg = self:readCurrentCfg()._killAddScore

	if num <= lc.lenTable(cfg) then
		return cfg[num]
	end

	return cfg[lc.lenTable(cfg)]
end

function M:readExtraAddScore(num)
	local cfg = self:readCurrentCfg()._extraAddScore

	if num <= lc.lenTable(cfg) then
		return cfg[num]
	end

	return 0
end

function M:readCurrentCfg()
	if self._data then
		return D._activitySparkScoutConfig[self._data.subType]
	end

	return D._activitySparkScoutConfig[1]
end

function M:readExchangeGroup(subType)
	return self:readCfg(subType)._exchangeGroup
end

function M:readCfg(subType)
	return D._activitySparkScoutConfig[subType or 1]
end

return M
