function M:readDuelRewards(win)
	local cfg = self:readCurrentCfg()

	if win then
		return cfg._duelRewardCidsWin, cfg._duelRewardNumsWin
	else
		return cfg._duelRewardCidsLose, cfg._duelRewardNumsLose
	end
end

function M:readDuelRewardNums()
