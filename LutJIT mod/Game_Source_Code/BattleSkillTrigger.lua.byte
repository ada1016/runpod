	{
		trigger_skill_id = 1102,
		on_pos = 2,
		trigger_when = BattleTriggerEnum.BulletDestoryOnCurPos,
		onBulletCreate = function (self, bullet)
			bullet._bulletPortalIn = self._bulletPortalIn
			self._bulletPortalIn._bulletPortalOut = bullet

			if bullet._position.x - bullet._size[1] / 2 < self._battleSession._screenEdgeX1 then
				bullet._position.x = self._battleSession._screenEdgeX1 + bullet._size[1] / 2
			end

			if self._battleSession._screenEdgeX2 < bullet._position.x + bullet._size[1] / 2 then
				bullet._position.x = self._battleSession._screenEdgeX2 - bullet._size[1] / 2
			end

			if self._battleSession._screenEdgeY2 < bullet._position.y + bullet._size[1] / 2 then
				bullet._position.y = self._battleSession._screenEdgeY2 - bullet._size[1] / 2
			end

			if bullet._position.y - bullet._size[1] / 2 < self._battleSession._screenEdgeY1 then
				bullet._position.y = self._battleSession._screenEdgeY1 + 0.5
			end
		end,
		check = function (self, subSkill, tEnemy)
			if self._bulletPortalIn then
				return true
			end

			return false
		end
	}
}
