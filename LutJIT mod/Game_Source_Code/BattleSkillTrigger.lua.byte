M[1] = {
	{
		trigger_probability = 10,
		trigger_skill_id = 102,
		version = 2,
		on_pos = 2,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		fc_add_trigger_probability = function (self, subSkill)
			local addPro = 10 * self._battleSkill:getProp(BattlePropEnum.Salvo, 0)

			return subSkill:getProp(BattlePropEnum.TriggerProbabilityAddPer, 0) + addPro
		end,
		check = function (self, subSkill, tEnemy)
			return self._isCouldTrigger
		end
	},
	{
		trigger_skill_id = 104,
		trigger_on = "1-104-1",
		version = 2,
		on_pos = 2,
		trigger_when = BattleTriggerEnum.WhenCast,
		cast_add_num = function ()
			return 1
		end,
		onBulletCreate = function (self, bullet, index)
			local dtAngle = D._battleGlobalConfig._ator_slanting_angle
			local agnle = 0

			if index == 1 then
				if self._isLeft then
					agnle = self._angle - dtAngle
				else
					agnle = self._angle + dtAngle
				end
			elseif index == 2 then
				if self._isLeft then
					agnle = self._angle - dtAngle / 2
				else
					agnle = self._angle + dtAngle / 2
				end
			end

			bullet:setDirByAngle(agnle)

			if bullet._view then
				bullet._view:rotationEvent()
			end
		end
	},
	{
		ignore_cur_enemy = true,
		trigger_on = "1-104-2",
		dir_type = 4,
		trigger_skill_id = 104,
		version = 2,
		on_pos = 2,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		fc_dir_angle = function (self)
			return self._isLeft and self._angle + 90 or self._angle - 90
		end,
		check = function (self, subSkill, tEnemy)
			return self._isCouldTrigger
		end
	},
	{
		trigger_probability = 20,
		trigger_skill_id = 103,
		dir_type = 2,
		version = 2,
		on_pos = 1,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		check = function (self, subSkill, tEnemy)
			return self._isCouldTrigger
		end,
		fc_add_trigger_probability = function (self, subSkill)
			local addNum = self._battleSkill:getProp(BattlePropEnum.Salvo, 0)

			return (addNum + 1) * 20
		end
	},
	{
		trigger_probability = 50,
		trigger_skill_id = 105,
		version = 2,
		on_pos = 1,
		trigger_when = BattleTriggerEnum.KillOnTargetPos,
		fc_add_trigger_probability = function (self, subSkill)
			local addNum = self._battleSkill:getProp(BattlePropEnum.Salvo, 0)

			return addNum * 50
		end,
		check = function (self, subSkill, tEnemy)
			return self._isCouldTrigger
		end
	},
	{
		trigger_skill_id = 106,
		version = 2,
		on_pos = 0,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		check = function (self, subSkill, tEnemy)
			if tEnemy._isToBeDestroyed then
				return false
			end

			return true
		end,
		onBulletCreate = function (self, bullet, index, tEnemy)
			tEnemy:onHit(bullet)
			bullet:hitEnemy(tEnemy)
		end
	}
}
