M[11] = {
	{
		on_pos = 2,
		trigger_skill_id = 1103,
		trigger_when = BattleTriggerEnum.BulletDestoryOnCurPos,
		onBulletCreate = function (self, bullet)
			if bullet._position.x - bullet._radius < self._battleSession._screenEdgeX1 then
				bullet._position.x = self._battleSession._screenEdgeX1 + bullet._radius
			end

			if self._battleSession._screenEdgeX2 < bullet._position.x + bullet._radius then
				bullet._position.x = self._battleSession._screenEdgeX2 - bullet._radius
			end

			if self._battleSession._screenEdgeY2 < bullet._position.y then
				bullet._position.y = self._battleSession._screenEdgeY2 - bullet._radius
			end

			if bullet._position.y < self._battleSession._screenEdgeY1 then
				bullet._position.y = self._battleSession._screenEdgeY1 + 0.5
			end
		end
	},
	{
		dir_type = 6,
		dir_angle = -45,
		trigger_skill_id = 1105,
		on_pos = 2,
		trigger_when = BattleTriggerEnum.BulletDestoryOnCurPos
	},
