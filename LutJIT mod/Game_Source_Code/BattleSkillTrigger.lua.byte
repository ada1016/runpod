M[9] = {
	{
		trigger_skill_id = 903,
		version = 2,
		on_pos = 1,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		onBulletCreate = function (self, bullet)
			if self._battleWeapon:getEffect(901) then
				local params = D.getBattleEffectParams(901)
				local s = (self._damageNum - 1) * params[1] / 100

				bullet:setScale(1 + s)
			end

			if self._battleWeapon:getEffect(902) then
				local params = D.getBattleEffectParams(902)
				bullet._damageAddPer = (self._damageNum - 1) * params[1]
			end
		end
	},
	{
		ignore_cur_enemy = true,
		trigger_skill_id = 901,
		dir_type = 5,
		version = 2,
		on_pos = 2,
		trigger_when = BattleTriggerEnum.HitFirstOnTargetPos,
		cast_add_num = function ()
			return 1
		end,
		onBulletCreate = function (self, bullet, index)
			local tdAngle = 20 * (index - 1.5)

			bullet:setDirByAngle(self._angle + tdAngle)
		end
