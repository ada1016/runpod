M[6] = {
	{
		dir_type = 5,
		trigger_skill_id = 601,
		on_pos = 2,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		onBulletCreate = function (self, bullet)
			bullet:setDirByAngle(self._angle)
			bullet:updateTriangleArea()

			if self._battleWeapon:getEffect(607) and self._view then
				local obj = self._sessionView:createAndPlayVFX("Bullet_6_traction", 1)

				if obj then
					obj:SetPosition(self._position.x, self._position.y, 0)
					obj:SetLocalRotation(0, 0, self._angle)
				end
			end
		end
	},
	{
		dir_type = 5,
		trigger_skill_id = 604,
		on_pos = 1,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		onBulletCreate = function (self, bullet)
			bullet:setDirByAngle(self._angle)
			bullet:updateTriangleArea()
		end
	},
	{
		effect_on = 608,
		trigger_skill_id = 602,
		on_pos = 1,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		cast_add_num = function (self, subSkill)
			local p = self._battleWeapon:getEffect(652)

			return p - 1
		end,
		onBulletCreate = function (self, bullet, index, tEnemy)
			local battleWeapon = self._battleWeapon
			local totalNum = battleWeapon:getEffect(652)
			local len = Vector2.Distance(tEnemy._position, battleWeapon._rotatePos)

			battleWeapon._rotation:SetEuler(0, 0, self._angle + 5 / len * 10 * (index - (1 + totalNum) / 2))
			opt.vec3_1:Set(battleWeapon._rotatePos):AddXYZ(battleWeapon._rotation:MulVec3XYZ(len, 0, 0))
			bullet:setPos(opt.vec3_1.x, opt.vec3_1.y)
		end
	},
	{
		on_pos = 1,
		trigger_skill_id = 608,
		trigger_when = BattleTriggerEnum.HitFirstOnTargetPos,
		fc_cast = function (self, subSkill, tEnemy)
			local angle = self._battleRandomLib:randomMN(0, 360)
			local bullet = subSkill:createBullet()

			bullet:setPos(tEnemy._position.x, tEnemy._position.y)
			bullet:setDirByAngle(angle)

			if bullet._view then
				bullet._view:posEvent()
				bullet._view:rotationEvent()
			end

			local bullet = subSkill:createBullet()

			bullet:setPos(self._position.x, self._position.y)
			bullet:setDirByAngle(angle + 90)

			if bullet._view then
				bullet._view:posEvent()
				bullet._view:rotationEvent()
			end
		end
	}
}
