M[2] = {
	{
		on_pos = 1,
		trigger_skill_id = 203,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		check = function (self, subSkill, tEnemy)
			if not subSkill._battleWeapon:getEffect(202) then
				return false
			end

			local buff = tEnemy:getBuff(BattleDefine.BuffId.rbp_burn)

			if buff == nil then
				return false
			end

			return true
		end
	},
	{
		trigger_probability = 50,
		trigger_skill_id = 204,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		check = function (self, subSkill, tEnemy)
			if tEnemy._skill204Triggered then
				return false
			end

			return true
		end,
		fc_cast = function (self, subSkill, tEnemy)
			tEnemy._skill204Triggered = true

			opt.dict_arg8:clear()

			opt.dict_arg8[tEnemy._id] = true
			local enemy = self._battleSession:randomOneEnemyInRange(tEnemy._position, 3, opt.dict_arg8)

			if enemy == nil then
				enemy = self._battleSession:randomOneEnemy(opt.dict_arg8)
			end

			opt.dict_arg8:clear()

			if enemy == nil then
				return
			end

			local triggerSkill = subSkill._battleWeapon:getSkill(204)
			local bullet = triggerSkill:createBullet()

			bullet:setPos(tEnemy._position.x, tEnemy._position.y)
			bullet:setLineBeganTarget(tEnemy)
			bullet:setTargetEnemy(enemy)

			bullet._subType = 2
			bullet._plasmaType = 3

			bullet:stepMove(0)
			self:addSubBullets(bullet)

			if bullet._view then
				bullet._view:posEvent()
			end
		end
	},
	{
		trigger_probability = 20,
		dir_type = 2,
		trigger_skill_id = 206,
		on_pos = 1,
		trigger_when = BattleTriggerEnum.HitOnTargetPos
	}
}
