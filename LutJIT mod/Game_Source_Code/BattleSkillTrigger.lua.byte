M[10] = {
	{
		on_pos = 2,
		trigger_skill_id = 1001,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		onBulletCreate = function (self, bullet)
			local scale = bullet._scale + (self._bulletAddScale or 0)

			bullet:setScale(scale)

			if self._tmpDamageAddPer then
				bullet._damageAddPer = self._tmpDamageAddPer
			end

			bullet._hitIndex = self._hitIndex
		end
	},
	{
		on_pos = 2,
		trigger_skill_id = 1002,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		onBulletCreate = function (self, bullet)
			local scale = bullet._scale + (self._bulletAddScale or 0)

			bullet:setScale(scale)

			if bullet._view then
				bullet._view._obj:SetLocalScale(bullet._scale, bullet._scale, 1)
			end

			local triggerSkill = bullet._battleWeapon:getSkill(1008)

			if triggerSkill then
				local bullet2 = triggerSkill:createBullet()

				bullet2:setScale(scale * 1.25)
				bullet2:setPos(bullet._position.x, bullet._position.y)

				if bullet2._view then
					bullet2._view:posEvent()
					bullet2._view._obj:SetLocalScale(scale * 1.25, scale * 1.25, 1)
				end
			end
		end
	},
	{
		on_pos = 2,
		trigger_skill_id = 1005,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		onBulletCreate = function (self, bullet)
			local scale = bullet._scale + (self._bulletAddScale or 0)

			bullet:setScale(scale * 1.5)
		end
	},
	{
		on_pos = 2,
		dir_type = 2,
		trigger_skill_id = 1007,
		trigger_when = BattleTriggerEnum.HitOnTargetPos
	},
	{
		effect_on = 1003,
		trigger_skill_id = 1004,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		fc_cast = function (self, subSkill, tEnemy)
			opt.dict_arg32:clear()

			opt.dict_arg32[tEnemy._id] = true
			local params = D.getBattleEffectParams(1003)
			local allEnemys = self._battleSession._battleEnemyFinder:getEnemysInRange(tEnemy._position, params[2])

			for i = 1, params[1] do
				local enemy = self._battleSession:randomOneEnemyFromInput(allEnemys, opt.dict_arg32)

				if enemy == nil then
					break
				end

				opt.dict_arg32[enemy._id] = true
				local triggerSkill = subSkill._battleWeapon:getSkill(1004)
				local bullet = triggerSkill:createBullet()

				bullet:setTargetPosition(self._position, enemy._position)
			end

			opt.dict_arg32:clear()
		end
	},
	{
		effect_on = 1006,
		trigger_skill_id = 1207,
		trigger_weapon = 12,
		trigger_when = BattleTriggerEnum.HitOnTargetPos,
		fc_cast = function (self, subSkill, tEnemy)
			local battleWeapon = self._battleSession:getWeapon(12)

			if battleWeapon == nil then
				return
			end

			local level = battleWeapon:getCloneLevel()

			battleWeapon:createCloneBeeByParam(level, tEnemy._position, 90, self._battleWeapon)
		end
	}
}
M[1001] = {
	{
		trigger_probability = 100,
		trigger_skill_id = 1009,
		on_pos = 1,
		trigger_when = BattleTriggerEnum.HitFirstOnTargetPos,
		onBulletCreate = function (self, bullet, index, tEnemy)
			if self._1009TriggerCount == nil then
				self._1009TriggerCount = 1
			else
				self._1009TriggerCount = self._1009TriggerCount + 1
			end

			bullet:setBeganTargt(tEnemy)
		end,
		check = function (self)
			if self._1009TriggerCount == nil or self._1009TriggerCount < 5 then
				return true
			end

			return false
		end
	},
	{
		trigger_skill_id = 1004,
		on_pos = 1,
		trigger_when = BattleTriggerEnum.BulletDestoryOnCurPos,
		check = function (self)
			if self._battleWeapon:getEffect(1008) then
				local chargeDuration = self._battleWeapon._chargeDurationOrigin

				if chargeDuration > 0.5 then
					return true
				end
			end

			return false
		end,
		fc_cast = function (self, subSkill)
			opt.dict_arg32:clear()

			local params = D.getBattleEffectParams(1003)
			local num = self._battleWeapon:getEffect(1008)
			num = num * math.floor(self._battleWeapon._chargeDurationOrigin / 0.5)
			local allEnemys = self._battleSession._battleEnemyFinder:getEnemysInRange(self._position, params[2])

			for i = 1, num do
				local enemy = self._battleSession:randomOneEnemyFromInput(allEnemys, opt.dict_arg32)

				if enemy == nil then
					break
				end

				opt.dict_arg32[enemy._id] = true
				local triggerSkill = subSkill._battleWeapon:getSkill(1004)
				local bullet = triggerSkill:createBullet()

				bullet:setTargetPosition(self._position, enemy._position)
			end

			opt.dict_arg32:clear()
		end
	}
}
