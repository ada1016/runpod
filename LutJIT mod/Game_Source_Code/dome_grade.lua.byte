local dup = requireLua("duplicate_define")
local lc = lc
local tonumber = tonumber
local rawget = rawget
local setmetatable = setmetatable
local getmetatable = getmetatable
local M = {
	{
		1,
		1,
		80,
		[5] = {
			600000,
			400000,
			200000
		},
		[6] = dup._1064
	},
	{
		2,
		2,
		80,
		[5] = {
			1200000,
			850000,
			500000
		},
		[6] = dup._1064
	},
	{
		3,
		3,
		80,
		[5] = {
			1800000,
			1350000,
			900000
		},
		[6] = dup._1064
	},
	{
		4,
		4,
		50,
		[5] = {
			2400000,
			1600000,
			1200000
		},
		[6] = dup._1064
	},
	{
		5,
		5,
		50,
		[5] = {
			3000000,
			2250000,
			1500000
		},
		[6] = dup._1064
	},
	{
