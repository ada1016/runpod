	goSweepFree = Types.GameObject,
	btnChangeSweepRate = Types.Button,
	tmpSweepRate = Types.TMP_Text,
	tmpSweepTitle = Types.TMP_Text,
	tmpSweepMission = Types.TMP_Text,
	tmpSweepCost = Types.TMP_Text,
	goOffline = Types.GameObject,
	btnOffline = Types.Button,
	goOfflineFull = Types.GameObject,
	goOfflineNotFull = Types.GameObject,
	btnPreviewNextMission = Types.Button,
	btnPreviewLastMission = Types.Button,
	btnMissionIcon = Types.Button,
	imgMissionIcon = Types.RawImage,
	imgMissionIconLock = Types.RawImage,
