local Client = Client
local SPINE_PATH = "Assets/FW/Prefabs/UI/element/MissionBossSpine%s.prefab"
M.args = {
	btnMissionInfo = Types.Button,
	textMissionTitle = Types.TMP_Text,
	textMissionBattleData = Types.TMP_Text,
	animMissionShow = Types.Animation,
	goCommonEnemy = Types.GameObject,
