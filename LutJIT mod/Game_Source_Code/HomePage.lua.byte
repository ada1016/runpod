	textTab2 = Types.TMP_Text,
	goBg1 = Types.GameObject,
	goBg2 = Types.GameObject,
	btnUnClaimRewardTip1 = Types.Button,
	animMissionBox = Types.Animation,
	goComplete = Types.GameObject,
	goCompletePerfect = Types.GameObject,
	textCompleteNotPerfect = Types.TMP_Text,
	goNotComplete = Types.GameObject,
	btnCommonMission = Types.Button,
	goCommonArea = Types.GameObject,
	btnEliteMission = Types.Button,
	btnTask = Types.LCButton,
	btnPlay = Types.Button,
	textCostEnergy = Types.TMP_Text,
	btnNewbieTask = Types.LCButton,
	goNewbieTask = Types.GameObject,
	txtNewbieTaskDesc = Types.TMP_Text,
	txtNewbieTaskProgress = Types.TMP_Text,
	animNewbieTask = Types.Animation,
