function M.AF_tracePurchase(price, productName, orderId)
	af_purchase_values[3]._value = price

	M.AF_traceEvent("af_purchase", af_purchase_values)

	e_purchase_values[1]._value = P._playerMission:getMissionId()
	e_purchase_values[2]._value = Client.getVersion()
	e_purchase_values[3]._value = price
	e_purchase_values[4]._value = productName
	e_purchase_values[5]._value = orderId

	M.AF_traceEvent("e_purchase", e_purchase_values)

	if not lc._isCN then
		local t = lc.priceBinning(price)

		for i = 1, #t do
			LuaHelper.LogInAppPurchase(t[i])
		end
	end

	if lc._isCN then
		local payMethod = "WeChatPay"

		LuaHelper.LogGravityEnginePayEvent(price * 100, "CNY", orderId, productName, payMethod)
	end
end

