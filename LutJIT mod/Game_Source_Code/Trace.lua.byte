local M = {}

declare("Trace", M)

local GA_NewDesignEvent = GameAnalyticsSDK and GameAnalyticsSDK.GameAnalytics.NewDesignEvent or opt.empty_func
local GA_NewBusinessEvent = GameAnalyticsSDK and GameAnalyticsSDK.GameAnalytics.NewBusinessEvent or opt.empty_func
local GA_NewResourceEvent = GameAnalyticsSDK and GameAnalyticsSDK.GameAnalytics.NewResourceEvent or opt.empty_func
local SDKFlowType = GameAnalyticsSDK and GameAnalyticsSDK.GAResourceFlowType or nil
local GA_FlowType_Sink = SDKFlowType and SDKFlowType.Sink or nil
local GA_FlowType_Source = SDKFlowType and SDKFlowType.Source or nil

function M.GA_traceDesignEvent(key, val)
	GA_NewDesignEvent(key, val or 0)
end

local res_name = {
	[10003.0] = "Stamina",
	[10047.0] = "ResonanceShard",
	[10002.0] = "Gem",
	[10001.0] = "Gold",
	[10028.0] = "Titanium",
	[10005.0] = "KeyA",
	[10006.0] = "KeyB",
	[3600000.0] = "RedChip",
	[10012.0] = "Recruitment",
	[10044.0] = "NeurCocoon",
	[3700000.0] = "ColorfulChip",
	[10104.0] = "RebuildArkAnchor"
}
local AF_res_name = {
	[10002.0] = "diamond",
	[10028.0] = "Titanium",
	[10006.0] = "KeyB",
	[10005.0] = "KeyA",
	[10047.0] = "ResonanceShard",
	[3600000.0] = "RedChip",
	[3700000.0] = "ColorfulChip"
}

function M.traceResChanged(itemId, isSub, amount, totalNum, logWay)
	if itemId >= 3600000 and itemId < 3700000 then
		itemId = 3600000
		totalNum = P._playerAsset:getAssetNum(itemId)

		if logWay == D.LogWay.chip_wash then
			return
		end
	end

	if itemId >= 3700000 and itemId < 3800000 then
		itemId = 3700000
		totalNum = P._playerAsset:getAssetNum(3700000)

		if logWay == D.LogWay.chip_wash then
			return
		end
	end

	if res_name[itemId] == nil then
		if D._itemConfig[itemId] and D._itemConfig[itemId]._trace then
			M.AF_traceResource(tostring(itemId), isSub and 2 or 1, amount, totalNum, logWay or D.LogWay.unknow)

			return
		end

		return
	end

	logWay = logWay or D.LogWay.unknow
	local flowType = isSub and GA_FlowType_Sink or GA_FlowType_Source

	GA_NewResourceEvent(flowType, res_name[itemId], amount, res_name[itemId], logWay)
	M.AF_traceResource(AF_res_name[itemId] or tostring(itemId), isSub and 2 or 1, amount, totalNum, logWay)
end

local S_ONE_KEY_VALUE = {
	{
		_key = "strParam",
		_value = 1
	}
}

function M.AF_traceOneKV(name, value)
	S_ONE_KEY_VALUE[1]._value = value

	M.AF_traceEvent(name, S_ONE_KEY_VALUE)
end

local S_TWO_KEY_VALUE = {
	{
		_key = "strParam",
		_value = 1
	},
	{
		_key = "strParam1",
		_value = 1
	}
}

function M.AF_traceTwoKV(name, value1, value2)
	S_TWO_KEY_VALUE[1]._value = value1
	S_TWO_KEY_VALUE[2]._value = value2

	M.AF_traceEvent(name, S_TWO_KEY_VALUE)
end

function M.traceDesign(str, ...)
	local str = string.format(str, ...)

	if lc._isCN then
		local p = string.split(str, ":")

		if p[3] then
			M.AF_traceTwoKV(p[1], p[2], p[3])
		elseif p[2] then
			M.AF_traceOneKV(p[1], p[2])
		else
			M.AF_traceKey(p[1])
		end
	else
		M.GA_traceDesignEvent(str)
	end
end

function M.traceDesign_Activity(str, aid, atype, asubType, ...)
	if aid == 1 then
		str = string.format(str, "1", ...)
	else
		str = string.format(str, string.format("%d_%d", atype, asubType), ...)
	end

	M.traceDesign(str, ...)
end

function M.traceAdRewardReceived(adName)
	M.AF_traceKey("e03_receviedreward")
	M.AF_traceAd("reward", adName)
end

function M.traceAdShow(adName)
	M.AF_traceAd("rewarded", adName)
end

function M.traceAdFail(adName)
	M.AF_traceAd("e_ad_fail", adName)
end

function M.traceIapPurchased(iapId, payMoney)
	GA_NewBusinessEvent("USD", payMoney * 100, "default", D._iapConfig[iapId]._event, P._playerStore:getPurchaseChannel())
end

