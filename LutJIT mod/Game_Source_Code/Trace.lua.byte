function M.AF_traceStage(status, msType, msId, result, level, battery, dragTime, seed)
	e_stage_values[1]._value = msId
	e_stage_values[2]._value = Client.getVersion()
	e_stage_values[3]._value = status
	e_stage_values[4]._value = msType
	e_stage_values[5]._value = result
	e_stage_values[6]._value = level
	e_stage_values[7]._value = battery or 0
	e_stage_values[8]._value = dragTime or 0
	e_stage_values[9]._value = seed or 0

	M.AF_traceEvent("e_stage", e_stage_values)

	if lc._isCN and result and result == "win" then
		e_stage_values_CN[1]._value = msId
		e_stage_values_CN[2]._value = tostring(msType - 1)

		M.AF_traceEvent("$CompleteSection", e_stage_values_CN)
	end
end

