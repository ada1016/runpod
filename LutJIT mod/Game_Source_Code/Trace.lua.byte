local ge_super_properties = {}
local record_minutes = {
	30,
	40,
	50,
	60
}
M.lastOnlineTime = nil

function M.AF_traceEvent(eventName, data)
	data = data or emptyTable
	local eventParams = {}

	for _, info in ipairs(data) do
		eventParams[info._key] = info._value
	end

	if P then
		local onlineTime = P._playerRecord:getOnlineTime()

		if not M.lastOnlineTime then
			M.lastOnlineTime = onlineTime
		end

		e_common_values[1]._value = P._playerStore:getPayCount()
		e_common_values[2]._value = math.floor(onlineTime)
		e_common_values[3]._value = P._playerRecord:getOnlineDay()
		e_common_values[4]._value = P._playerStore:getPayMoney()
		e_common_values[5]._value = P._playerAd:getTotalRewardAdWatchCount()
		e_common_values[6]._value = Client._saveData.version
		e_common_values[7]._value = P:isATest() and "A" or "B"
		e_common_values[8]._value = P:getLevel()
		e_common_values[9]._value = math.floor(Client._saveData.appRunTime or 0)

		if lc._isCN then
			e_common_values[10]._value = C._serverDataVersion or 0
		else
			e_common_values[10]._value = C._saveData.dataVersion2 or 0
		end

		e_common_values[11]._value = math.floor(C._loginTimestamp or 0)
		e_common_values[12]._value = C._userFlag or 0

		if lc._isCN then
			e_common_values[13]._value = C.getVersion()
		else
			e_common_values[14]._value = C._isInBlacklist and 1 or 0
		end

		if not string.startsWith(eventName, "e_playtime_") then
			for i = 1, #record_minutes do
				if onlineTime >= record_minutes[i] * 60 and P._playerRecord:getRecordOnlineTime() < record_minutes[i] * 60 then
					M.AF_traceEvent("e_playtime_" .. record_minutes[i])
				end
			end

			P._playerRecord:setRecordOnlineTime(onlineTime)
		end

		for _, info in ipairs(e_common_values) do
			eventParams[info._key] = info._value
		end
	end

	LuaHelper.LogAFEvent(eventName, eventParams)
end

function M.AF_traceKey(eventName)
	M.AF_traceEvent(eventName)
end

