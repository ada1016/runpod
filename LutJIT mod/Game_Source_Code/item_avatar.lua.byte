local mapKeyIndex = {
	k1677555 = 6,
	k15255765 = 2,
	k13849634 = 9,
	k6677404 = 4,
	k13631784 = 7,
	k14279902 = 11,
	k6939003 = 10,
	k1208471 = 13,
	k4312826 = 8,
	k2172730 = 5,
	k815835 = 14,
	k1644150 = 1,
	k12760587 = 12,
	k8655535 = 3
}
local mapKeyDimension = {}
local arrayMt = {
	__index = function (table, key)
		local val = rawget(table, -key)
		key = tonumber(key)

		if key == nil then
			return nil
		end

		if val then
			return table[-key] + lc._encryptOffset + 5557
		end
	end
}
local mt = {
	__call = function (table, key)
		return table[mapKeyIndex[key]]
	end,
	__index = function (table, key)
		local tKey = dup.dup(key)

		if mapKeyIndex[tKey] == nil then
			return nil
		end

		if key == "_nameSid" then
			if table[2] == nil then
				return nil
			end

			return SID["SID_ITEM_AVATAR_NAMESID_" .. table[2]]
		elseif key == "_descSid" then
			if table[3] == nil then
				return nil
			end

			return SID["SID_ITEM_AVATAR_DESCSID_" .. table[3]]
		elseif key == "_unlockDescSid" then
			if table[4] == nil then
				return nil
			end

			return SID["SID_ITEM_AVATAR_UNLOCKDESCSID_" .. table[4]]
		end

		local val = table[mapKeyIndex[tKey]]

		if val == nil then
			return
		end

		local d = mapKeyDimension[tKey]

		if d == 0 then
			return val + lc._encryptOffset + 5557
		elseif d == 1 then
			if val[0] == nil then
				if getmetatable(val) == nil then
					setmetatable(val, arrayMt)
				end

				val[0] = true
			end
		elseif d == 2 and val[0] == nil then
			for i = 1, #val do
				if getmetatable(val[i]) == nil then
					setmetatable(val[i], arrayMt)
				end
			end

			val[0] = true
		end

		return val
	end,
	__newindex = function (_, index, value)
		log.f("ERROR", "This is a read-only table!")
		assert(false)
	end
}

for k, v in pairs(M) do
	setmetatable(v, mt)
end

return M
