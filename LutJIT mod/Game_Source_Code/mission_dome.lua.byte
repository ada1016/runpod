local mapKeyIndex = {
	k14125457 = 3,
	k8348008 = 16,
	k6988033 = 6,
	k2436351 = 7,
	k6099917 = 14,
	k10701862 = 4,
	k9615522 = 5,
	k9683213 = 20,
	k12956039 = 22,
	k4386482 = 11,
	k10875336 = 17,
	k4797140 = 21,
	k901605 = 8,
	k16583821 = 18,
	k9241073 = 10,
	k10420507 = 9,
	k3851826 = 12,
	k4774420 = 25,
	k13673782 = 13,
	k6183869 = 15,
	k15255765 = 2,
	k6643129 = 24,
	k15261443 = 23,
	k937263 = 19,
	k1644150 = 1
}
local mapKeyDimension = {}
local arrayMt = {
	__index = function (table, key)
		local val = rawget(table, -key)
		key = tonumber(key)

		if key == nil then
			return nil
		end

		if val then
			return table[-key] + lc._encryptOffset + 7173
		end
	end
}
local mt = {
	__call = function (table, key)
		return table[mapKeyIndex[key]]
	end,
	__index = function (table, key)
		local tKey = dup.dup(key)

		if mapKeyIndex[tKey] == nil then
			return nil
		end

		if key == "_nameSid" then
			if table[2] == nil then
				return nil
			end

			return SID["SID_MISSION_DOME_NAMESID_" .. table[2]]
		end

		local val = table[mapKeyIndex[tKey]]

		if val == nil then
			return
		end

		local d = mapKeyDimension[tKey]

		if d == 0 then
			return val + lc._encryptOffset + 7173
		elseif d == 1 then
			if val[0] == nil then
				if getmetatable(val) == nil then
					setmetatable(val, arrayMt)
				end

				val[0] = true
			end
		elseif d == 2 and val[0] == nil then
			for i = 1, #val do
				if getmetatable(val[i]) == nil then
					setmetatable(val[i], arrayMt)
				end
			end

			val[0] = true
		end

		return val
	end,
	__newindex = function (_, index, value)
		log.f("ERROR", "This is a read-only table!")
		assert(false)
	end
}

for k, v in pairs(M) do
	setmetatable(v, mt)
end

return M
