local M = class("BattleBullet_Portal_Out", requireLua("BattleBullet"))
local SUPER = M.super
local BattleMathLib = BattleMathLib
local TablePool = TablePool
local opt = opt

function M:markToBeDestroyed()
	SUPER.markToBeDestroyed(self)
	self._bulletPortalIn:markToBeDestroyed()

	self._bulletPortalIn = nil
end

return M
