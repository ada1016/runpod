local M = {}
local LuaOutF = LuaOut.float
local LuaHelper = LuaHelper
local type = type

function M.setLocalPosition(userdata, x, y, z)
	if type(x) == "table" then
		z = x.z
		y = x.y
		x = x.x
	end

	z = z or 0
	y = y or 0
	x = x or 0

	LuaHelper.SetLocalPosition(userdata, x, y, z)
end

function M.setPosition(userdata, x, y, z)
	if type(x) == "table" then
		z = x.z
		y = x.y
		x = x.x
	end

	z = z or 0
	y = y or 0
	x = x or 0

	LuaHelper.SetPosition(userdata, x, y, z)
end

function M.setAnchoredPosition(userdata, x, y)
	if type(x) == "table" then
		y = x.y
		x = x.x
	end

	y = y or 0
	x = x or 0

	LuaHelper.SetAnchoredPosition(userdata, x, y)
end

function M.setPivot(userdata, x, y)
	if type(x) == "table" then
		y = x.y
		x = x.x
	end

	y = y or 0
	x = x or 0

	LuaHelper.SetPivot(userdata, x, y)
end

function M.setLocalScale(userdata, x, y, z)
	if type(x) == "table" then
		z = x.z
		y = x.y
		x = x.x
	elseif y == nil and z == nil then
		y = x
		z = x
	end

	z = z or 0
	y = y or 0
	x = x or 0

	LuaHelper.SetLocalScale(userdata, x, y, z)
end

function M.setLocalRotation(userdata, x, y, z, w)
	if type(x) == "table" then
		w = x.w
		z = x.z
		y = x.y
		x = x.x
	end

	w = w or 0
	z = z or 0
	y = y or 0
	x = x or 0

	LuaHelper.SetLocalRotation(userdata, x, y, z, w)
end

function M.setRotation(userdata, x, y, z, w)
	if type(x) == "table" then
		w = x.w
		z = x.z
		y = x.y
		x = x.x
	end

	w = w or 0
	z = z or 0
	y = y or 0
	x = x or 0

	LuaHelper.SetRotation(userdata, x, y, z, w)
end

function M.setForward(userdata, x, y, z)
	if type(x) == "table" then
		z = x.z
		y = x.y
		x = x.x
	end

	z = z or 0
	y = y or 0
	x = x or 0

	LuaHelper.SetForward(userdata, x, y, z)
end

