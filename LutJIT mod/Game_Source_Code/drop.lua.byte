		1541 - lc._encryptOffset,
		-8523 - lc._encryptOffset,
		-8523 - lc._encryptOffset,
		600
	},
	{
		1277,
		14702,
		nil,
		1541 - lc._encryptOffset,
		-8521 - lc._encryptOffset,
		-8521 - lc._encryptOffset,
		50
	}
}
local mapKeyIndex = {
	k1644150 = 1,
	k9427419 = 4,
	k3554818 = 2,
	k10527364 = 6,
	k8916744 = 3,
	k488890 = 7,
	k12013215 = 5
}
local mapKeyDimension = {
	k10527364 = 0,
	k9427419 = 0,
	k12013215 = 0
}
local arrayMt = {
	__index = function (table, key)
		local val = rawget(table, -key)
		key = tonumber(key)

		if key == nil then
			return nil
		end

		if val then
			return table[-key] + lc._encryptOffset + 8525
		end
	end
}
local mt = {
	__call = function (table, key)
		return table[mapKeyIndex[key]]
	end,
	__index = function (table, key)
		local tKey = dup.dup(key)

		if mapKeyIndex[tKey] == nil then
			return nil
		end

		local val = table[mapKeyIndex[tKey]]

		if val == nil then
			return
		end

		local d = mapKeyDimension[tKey]

		if d == 0 then
			return val + lc._encryptOffset + 8525
		elseif d == 1 then
			if val[0] == nil then
				if getmetatable(val) == nil then
					setmetatable(val, arrayMt)
				end

				val[0] = true
			end
		elseif d == 2 and val[0] == nil then
			for i = 1, #val do
				if getmetatable(val[i]) == nil then
					setmetatable(val[i], arrayMt)
				end
			end

			val[0] = true
		end

		return val
	end,
	__newindex = function (_, index, value)
		log.f("ERROR", "This is a read-only table!")
		assert(false)
	end
}

for k, v in pairs(M) do
	setmetatable(v, mt)
end

return M
